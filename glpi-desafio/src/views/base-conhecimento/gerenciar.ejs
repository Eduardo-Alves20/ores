<section class="base-page content-with-pagination-wrapper">
  <div class="content-with-pagination">
    <%- include("../partials/breadcrumb", {
      crumbs: [
        { label: "Home", href: "/app" },
        { label: "Base de conhecimento", href: "/base-conhecimento" },
        { label: "Gerenciar FAQ" },
      ],
    }) %>

    <header class="base-head">
      <div>
        <h1 class="page-title">Gerenciar FAQ interno</h1>
        <p class="page-subtitle">Crie, edite e ative/desative duvidas da base sem mexer no codigo.</p>
      </div>
      <div class="base-head-actions">
        <a class="button button-filter-apply base-head-create-btn" href="/base-conhecimento/novo">+ Nova duvida</a>
        <a class="button secondary" href="/base-conhecimento">Voltar para base</a>
      </div>
    </header>

    <% if (flash) { %>
      <div class="alert <%= flash.tipo === 'success' ? 'alert--success' : (flash.tipo === 'error' ? 'alert--danger' : 'alert--info') %>">
        <%= flash.mensagem %>
      </div>
    <% } %>

    <% if (erroGeral) { %>
      <div class="alert alert--danger"><%= erroGeral %></div>
    <% } %>

    <form class="table-card base-filtros" method="GET" action="/base-conhecimento/gerenciar">
      <div class="base-filtros-grid">
        <div class="base-filtro base-filtro--search">
          <label for="q">Buscar topico</label>
          <input id="q" name="q" value="<%= filtros?.q || '' %>" placeholder="Titulo, categoria, tag..." />
        </div>
        <div class="base-filtro">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="ativos" <%= (filtros?.status || 'ativos') === 'ativos' ? 'selected' : '' %>>Apenas ativos</option>
            <option value="inativos" <%= filtros?.status === 'inativos' ? 'selected' : '' %>>Apenas inativos</option>
            <option value="todos" <%= filtros?.status === 'todos' ? 'selected' : '' %>>Todos</option>
          </select>
        </div>
      </div>
      <div class="base-filtros-actions">
        <button class="button button-filter-apply" type="submit">Aplicar filtros</button>
        <a class="button tertiary" href="/base-conhecimento/gerenciar">Limpar filtros</a>
      </div>
    </form>

    <% if (!topicos || !topicos.length) { %>
      <article class="table-card base-empty">
        <h2>Nenhum topico interno encontrado</h2>
        <p>Voce pode criar uma nova duvida para comecar a base interna.</p>
      </article>
    <% } else { %>
      <section class="base-list">
        <% topicos.forEach((topico) => { %>
          <article class="table-card base-item base-item--manage">
            <div class="base-item__top">
              <span class="base-item__tag"><%= topico?.categoria || "Geral" %></span>
              <span class="base-item__source source-interna">Interno</span>
              <span class="base-status <%= topico?.ativo ? 'is-ativo' : 'is-inativo' %>">
                <%= topico?.ativo ? "Ativo" : "Inativo" %>
              </span>
              <h2><a href="/base-conhecimento/<%= topico.slug %>"><%= topico?.titulo || "-" %></a></h2>
            </div>

            <p><%= topico?.resumo || "-" %></p>

            <div class="base-manage-meta">
              <span><strong>Slug:</strong> <code><%= topico?.slug || "-" %></code></span>
              <span><strong>Atualizado:</strong> <%= topico?.updatedAt ? new Date(topico.updatedAt).toLocaleString("pt-BR") : "-" %></span>
            </div>

            <div class="base-item__actions">
              <a class="button secondary" href="/base-conhecimento/<%= topico.slug %>">Abrir</a>
              <a class="button tertiary" href="/base-conhecimento/<%= topico.slug %>/editar">Editar</a>
              <form method="POST" action="/base-conhecimento/<%= topico.slug %>/status" style="margin:0;">
                <input type="hidden" name="ativo" value="<%= topico?.ativo ? '0' : '1' %>" />
                <button class="button <%= topico?.ativo ? 'base-btn-danger' : '' %>" type="submit">
                  <%= topico?.ativo ? "Desativar" : "Ativar" %>
                </button>
              </form>
              <form
                method="POST"
                action="/base-conhecimento/<%= topico.slug %>/excluir"
                style="margin:0;"
                onsubmit="return confirm('Excluir definitivamente o topico &quot;<%= topico?.titulo || '' %>&quot;? Essa acao nao pode ser desfeita.');"
              >
                <button class="button base-btn-delete" type="submit">Excluir</button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </div>
</section>
