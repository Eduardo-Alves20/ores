<section class="base-page base-novo-page">
  <%- include("../partials/breadcrumb", {
    crumbs: [
      { label: "Home", href: "/app" },
      { label: "Base de conhecimento", href: "/base-conhecimento" },
      { label: "Gerenciar FAQ", href: "/base-conhecimento/gerenciar" },
      { label: "Editar topico" },
    ],
  }) %>

  <header class="base-head">
    <div>
      <h1 class="page-title">Editar topico da base</h1>
      <p class="page-subtitle">Atualize a duvida frequente sem precisar editar arquivo manualmente.</p>
    </div>
    <div class="base-show-actions">
      <a class="button secondary" href="/base-conhecimento/gerenciar">Voltar</a>
      <a class="button tertiary" href="/base-conhecimento/<%= topico?.slug %>">Abrir artigo</a>
    </div>
  </header>

  <% if (erroGeral) { %>
    <div class="alert alert--danger"><%= erroGeral %></div>
  <% } %>

  <% if (topico && topico.ativo === false) { %>
    <div class="alert alert--info">Este topico esta inativo e nao aparece na busca da base publica.</div>
  <% } %>

  <form class="table-card base-form" method="POST" action="/base-conhecimento/<%= topico?.slug %>/editar" autocomplete="off">
    <div class="base-form-grid">
      <div class="base-filtro base-filtro--search">
        <label for="titulo">Titulo</label>
        <input id="titulo" name="titulo" value="<%= valores?.titulo || '' %>" minlength="6" maxlength="180" required />
      </div>

      <div class="base-filtro">
        <label for="categoria">Categoria</label>
        <input id="categoria" name="categoria" value="<%= valores?.categoria || '' %>" minlength="2" maxlength="60" placeholder="Ex.: Rede, Email, VPN..." required />
      </div>

      <div class="base-filtro base-filtro--full">
        <label for="resumo">Resumo</label>
        <textarea id="resumo" name="resumo" rows="3" minlength="20" maxlength="400" required><%= valores?.resumo || '' %></textarea>
      </div>

      <div class="base-filtro base-filtro--full">
        <label for="conteudo">Conteudo (passo a passo)</label>
        <textarea
          id="conteudo"
          name="conteudo"
          rows="10"
          minlength="30"
          maxlength="12000"
          placeholder="- Passo 1 ...&#10;- Passo 2 ...&#10;- Passo 3 ..."
          required
        ><%= valores?.conteudo || '' %></textarea>
      </div>

      <div class="base-filtro base-filtro--full">
        <label for="tags">Tags (separadas por virgula)</label>
        <input id="tags" name="tags" value="<%= valores?.tags || '' %>" maxlength="800" placeholder="pdf, assinador, certificado, login..." />
      </div>

      <div class="base-filtro base-filtro--full">
        <label for="sintomas">Sintomas/termos gatilho (virgula)</label>
        <input
          id="sintomas"
          name="sintomas"
          value="<%= valores?.sintomas || '' %>"
          maxlength="1000"
          placeholder="senha invalida, nao autentica, login falhou, acesso negado..."
        />
      </div>

      <div class="base-filtro base-filtro--full">
        <label for="perguntas">Perguntas frequentes relacionadas (uma por linha)</label>
        <textarea
          id="perguntas"
          name="perguntas"
          rows="4"
          maxlength="5000"
          placeholder="Minha senha esta invalida no Zimbra&#10;Nao consigo autenticar no VPN&#10;Esqueci a senha da nuvem"
        ><%= valores?.perguntas || '' %></textarea>
      </div>
    </div>

    <div class="base-filtros-actions">
      <button class="button" type="submit">Salvar alteracoes</button>
      <a class="button tertiary" href="/base-conhecimento/gerenciar">Cancelar</a>
    </div>
  </form>

  <form
    class="base-delete-form"
    method="POST"
    action="/base-conhecimento/<%= topico?.slug %>/excluir"
    onsubmit="return confirm('Excluir definitivamente este topico? Essa acao nao pode ser desfeita.');"
  >
    <button class="button base-btn-delete" type="submit">Excluir definitivamente</button>
  </form>
</section>
