PORT=4000
HOST=localhost
AMBIENTE=DEV
SITE_URL=

MONGO_URI=mongodb://127.0.0.1:27017/ORES?directConnection=true
MONGO_INITDB_ROOT_USERNAME=ores_root
MONGO_INITDB_ROOT_PASSWORD=troque-essa-senha-root
MONGO_URI_DOCKER=mongodb://ores_root:troque-essa-senha-root@mongo:27017/ORES?authSource=admin&directConnection=true
SESSION_NAME=ores.sid

# Seguranca
PASSWORD_PEPPER=troque-por-um-segredo-longo
CLOUDFLARE_TUNNEL_TOKEN=

# Notificacoes externas (deixe desligado ate ter as credenciais oficiais)
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_EMAIL_PROVIDER=resend
NOTIFICATIONS_EMAIL_FROM=Agenda ORES <agenda@notify.institutoORES.ong.br>
NOTIFICATIONS_EMAIL_REPLY_TO=agenda@institutoORES.ong.br
