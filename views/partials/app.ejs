<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include("./seo.ejs") %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />
    <%
      const appendAssetVersion = (href) => {
        const rawHref = String(href || "");
        if (!rawHref.startsWith("/")) return rawHref;
        return `${rawHref}${rawHref.includes("?") ? "&" : "?"}v=${assetVersion || "1"}`;
      };
    %>
    <link rel="stylesheet" href="<%= appendAssetVersion('/css/index.css') %>" />
    <link rel="stylesheet" href="<%= appendAssetVersion('/css/app.css') %>" />
    <% if (typeof extraCss !== "undefined" && Array.isArray(extraCss)) { %>
      <% extraCss.forEach((href) => { %>
        <link rel="stylesheet" href="<%= appendAssetVersion(href) %>" />
      <% }) %>
    <% } %>
  </head>
  <body class="app-shell <%= pageClass || '' %>">
    <button
      class="mobile-nav-toggle"
      type="button"
      aria-label="Abrir menu"
      aria-expanded="false"
      data-mobile-nav-toggle
    >
      <i class="fa-solid fa-bars"></i>
    </button>

    <button
      class="sidebar-backdrop"
      type="button"
      aria-label="Fechar menu"
      hidden
      data-sidebar-backdrop
    ></button>

    <aside class="sidebar" data-sidebar>
      <div class="sidebar-brand">
        <span class="sidebar-brand-mark">G</span>
        <div class="sidebar-brand-copy">
          <strong>GESA</strong>
          <small>gestao social assistencial</small>
        </div>
      </div>

      <%
        const userPerms = Array.isArray(currentUser?.permissions) ? currentUser.permissions : [];
        const hasPerm = (perm) => userPerms.includes("*") || userPerms.includes(perm);
        const normalizedProfile = String(currentUser?.perfil || "").toLowerCase();
        const canOpenAdminCenter = ["admin", "superadmin"].includes(normalizedProfile);
        const profileLabel = normalizedProfile === "admin"
          ? "admin_alento"
          : normalizedProfile === "superadmin"
            ? "SuperAdmin"
            : normalizedProfile === "atendente"
              ? "Atendente"
              : normalizedProfile === "tecnico"
                ? "Tecnico"
                : normalizedProfile || "usuario";
        const moduleBadge = ["admin", "superadmin"].includes(normalizedProfile) ? "Admin" : "Usuario";
        const helpDeskHref = moduleLinks?.helpDeskUrl ? "/modulos/help-desk/acessar" : "/modulos/help-desk";
        const hdiHref = moduleLinks?.hdiUrl ? "/modulos/hdi/acessar" : "/modulos/hdi";
        const usuariosGroupOpen = ["usuarios-familia", "usuarios-voluntario"].includes(navKey);
        const showPortalMenu = normalizedProfile === "usuario" && (
          hasPerm("portal.meus_dados") || hasPerm("portal.minha_familia")
        );
        const showWorkspaceMenu = normalizedProfile !== "usuario" || [
          "dashboard.view",
          "familias.view",
          "agenda.view",
          "relatorios.view",
          "busca.global",
          "acessos.view",
          "usuarios.manage",
        ].some((perm) => hasPerm(perm));
        const userInitials = String(currentUser?.nome || "Admin Gesa")
          .trim()
          .split(/\s+/)
          .filter(Boolean)
          .slice(0, 2)
          .map((part) => part.charAt(0).toUpperCase())
          .join("") || "AG";
      %>
      <nav class="sidebar-nav">
        <% if (showPortalMenu) { %>
          <% if (hasPerm("portal.minha_familia")) { %>
            <a href="/minha-familia" class="sidebar-link <%= navKey === 'minha-familia' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-heart"></i></span>
              <span>Minha Familia</span>
            </a>
          <% } %>
          <% if (hasPerm("portal.meus_dados")) { %>
            <a href="/meus-dados" class="sidebar-link <%= navKey === 'meus-dados' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-address-card"></i></span>
              <span>Meus Dados</span>
            </a>
          <% } %>
        <% } %>
        <% if (showWorkspaceMenu) { %>
          <% if (hasPerm("dashboard.view")) { %>
            <a href="/painel" class="sidebar-link <%= navKey === 'home' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-house"></i></span>
              <span>Tela de Inicio</span>
            </a>
          <% } %>
          <% if (hasPerm("familias.view")) { %>
            <a href="/familias" class="sidebar-link <%= navKey === 'assistidos' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-people-group"></i></span>
              <span>Assistidos</span>
            </a>
          <% } %>
          <% if (hasPerm("acessos.view")) { %>
            <div class="sidebar-group <%= usuariosGroupOpen ? 'is-open' : '' %>" data-sidebar-group>
              <button
                type="button"
                class="sidebar-link sidebar-group-toggle <%= usuariosGroupOpen ? 'is-active' : '' %>"
                data-sidebar-group-toggle
                aria-expanded="<%= usuariosGroupOpen ? 'true' : 'false' %>"
              >
                <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-address-book"></i></span>
                <span>Usuarios</span>
                <span class="sidebar-group-chevron" aria-hidden="true"><i class="fa-solid fa-chevron-down"></i></span>
              </button>
              <div class="sidebar-submenu" data-sidebar-group-panel <%= usuariosGroupOpen ? '' : 'hidden' %>>
                <a href="/acessos/familias" class="sidebar-link sidebar-link-child <%= navKey === 'usuarios-familia' ? 'is-active' : '' %>">
                  <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-people-roof"></i></span>
                  <span>Familias</span>
                </a>
                <a href="/acessos/voluntarios" class="sidebar-link sidebar-link-child <%= navKey === 'usuarios-voluntario' ? 'is-active' : '' %>">
                  <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-user-group"></i></span>
                  <span>Voluntarios</span>
                </a>
              </div>
            </div>
          <% } %>
          <% if (hasPerm("acessos.approve")) { %>
            <a href="/acessos/aprovacoes" class="sidebar-link <%= navKey === 'aprovacoes' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-circle-check"></i></span>
              <span>Aprovacoes</span>
              <% if (Number(pendingApprovalCount || 0) > 0) { %>
                <small class="sidebar-link-badge sidebar-link-badge-alert"><%= pendingApprovalCount %></small>
              <% } %>
            </a>
          <% } %>
          <% if (currentUser?.perfil === 'superadmin') { %>
            <a href="/seguranca/funcoes" class="sidebar-link <%= navKey === 'seguranca-funcoes' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-user-shield"></i></span>
              <span>Seguranca de Acesso</span>
            </a>
          <% } %>
          <% if (hasPerm("agenda.view")) { %>
            <a href="/agenda" class="sidebar-link <%= navKey === 'agenda' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-calendar-days"></i></span>
              <span>Agenda</span>
            </a>
            <a href="/agenda/presencas" class="sidebar-link <%= navKey === 'agenda-presencas' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-user-check"></i></span>
              <span>Presencas</span>
            </a>
          <% } %>
          <% if (canOpenAdminCenter) { %>
            <a href="/administracao" class="sidebar-link <%= navKey === 'admin' ? 'is-active' : '' %>">
              <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-gear"></i></span>
              <span>Administracao</span>
            </a>
          <% } %>
        <% } %>

        <div class="sidebar-section-label">Modulos integrados</div>

        <a
          href="<%= helpDeskHref %>"
          class="sidebar-link <%= navKey === 'modulo-helpdesk' ? 'is-active' : '' %>">
          <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-headset"></i></span>
          <span>Help Desk</span>
          <small class="sidebar-link-badge"><%= moduleBadge %></small>
        </a>

        <a
          href="<%= hdiHref %>"
          class="sidebar-link <%= navKey === 'modulo-hdi' ? 'is-active' : '' %>">
          <span class="sidebar-link-icon" aria-hidden="true"><i class="fa-solid fa-diagram-project"></i></span>
          <span>HDI</span>
          <small class="sidebar-link-badge"><%= moduleBadge %></small>
        </a>
      </nav>

      <form method="post" action="/auth/logout" class="sidebar-logout">
        <button type="submit" class="logout-btn">
          <span class="logout-btn-icon" aria-hidden="true"><i class="fa-solid fa-right-from-bracket"></i></span>
          <span>Sair do Sistema</span>
        </button>
      </form>
    </aside>

    <div class="app-main">
      <header class="topbar">
        <div class="topbar-heading">
          <span class="topbar-kicker">Operacao social</span>
          <h1 class="topbar-title"><%= sectionTitle || title || "Tela" %></h1>
        </div>
        <div class="topbar-actions">
          <% if (hasPerm("notificacoes.view")) { %>
            <a
              href="/notificacoes"
              class="topbar-icon-btn <%= navKey === 'notificacoes' ? 'is-active' : '' %>"
              title="Notificacoes"
              aria-label="Notificacoes"
            >
              <i class="fa-solid fa-bell"></i>
            </a>
          <% } %>
          <a href="/perfil" class="topbar-user topbar-profile-link <%= navKey === 'perfil' ? 'is-active' : '' %>">
            <span class="topbar-user-avatar"><%= userInitials %></span>
            <div class="topbar-user-meta">
              <strong><%= currentUser?.nome || 'Admin Gesa' %></strong>
              <small><%= profileLabel || 'Gestor Social' %></small>
            </div>
          </a>
        </div>
      </header>

      <main class="app-content">
        <%- body %>
      </main>
    </div>

    <%
      const __normalizeFlash = (value) => {
        if (Array.isArray(value)) {
          return value
            .map((item) => String(item || "").trim())
            .filter(Boolean);
        }
        const single = String(value || "").trim();
        return single ? [single] : [];
      };

      const __appFlashPayload = {
        success: []
          .concat(typeof successMessage !== "undefined" ? __normalizeFlash(successMessage) : []),
        error: []
          .concat(typeof errorMessage !== "undefined" ? __normalizeFlash(errorMessage) : [])
          .concat(typeof senhaErrorMessage !== "undefined" ? __normalizeFlash(senhaErrorMessage) : []),
        warning: []
          .concat(typeof warningMessage !== "undefined" ? __normalizeFlash(warningMessage) : []),
        info: []
          .concat(typeof infoMessage !== "undefined" ? __normalizeFlash(infoMessage) : []),
      };
    %>
    <script>
      window.__APP_FLASH = <%- JSON.stringify(__appFlashPayload) %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="<%= appendAssetVersion('/js/ui-alerts.js') %>" defer></script>
    <script src="<%= appendAssetVersion('/js/app-shell.js') %>" defer></script>
    <% if (typeof extraJs !== "undefined" && Array.isArray(extraJs)) { %>
      <% extraJs.forEach((src) => { %>
        <script src="<%= appendAssetVersion(src) %>" defer></script>
      <% }) %>
    <% } %>
  </body>
</html>
