<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include("./seo.ejs") %>
    <meta name="csrf-token" content="<%= csrfToken || '' %>" />
    <meta name="csrf-header-name" content="<%= csrfHeaderName || 'X-CSRF-Token' %>" />
    <meta name="csrf-field-name" content="<%= csrfFieldName || '_csrf' %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />
    <%
      const appendAssetVersion = (href) => {
        const rawHref = String(href || "");
        if (!rawHref.startsWith("/")) return rawHref;
        return `${rawHref}${rawHref.includes("?") ? "&" : "?"}v=${assetVersion || "1"}`;
      };
    %>
    <link rel="stylesheet" href="<%= appendAssetVersion('/css/index.css') %>" />
    <link rel="stylesheet" href="<%= appendAssetVersion('/css/auth.css') %>" />
    <% if (typeof extraCss !== "undefined" && Array.isArray(extraCss)) { %>
      <% extraCss.forEach((href) => { %>
        <link rel="stylesheet" href="<%= appendAssetVersion(href) %>" />
      <% }) %>
    <% } %>
  </head>
  <body class="app app-light <%= pageClass || '' %>">
    <%- body %>
    <%
      const __normalizeFlash = (value) => {
        if (Array.isArray(value)) {
          return value
            .map((item) => String(item || "").trim())
            .filter(Boolean);
        }
        const single = String(value || "").trim();
        return single ? [single] : [];
      };

      const __appFlashPayload = {
        success: []
          .concat(typeof successMessage !== "undefined" ? __normalizeFlash(successMessage) : []),
        error: []
          .concat(typeof errorMessage !== "undefined" ? __normalizeFlash(errorMessage) : []),
        warning: []
          .concat(typeof warningMessage !== "undefined" ? __normalizeFlash(warningMessage) : []),
        info: []
          .concat(typeof infoMessage !== "undefined" ? __normalizeFlash(infoMessage) : []),
      };
    %>
    <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> id="app-flash-data" type="application/json"><%- serializeForInlineScript(__appFlashPayload) %></script>
    <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> src="<%= appendAssetVersion('/js/csrf.js') %>" defer></script>
    <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> src="<%= appendAssetVersion('/js/ui-alerts.js') %>" defer></script>
    <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> src="<%= appendAssetVersion('/js/auth.js') %>" defer></script>
    <% if (typeof extraJs !== "undefined" && Array.isArray(extraJs)) { %>
      <% extraJs.forEach((src) => { %>
        <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> src="<%= appendAssetVersion(src) %>" defer></script>
      <% }) %>
    <% } %>
  </body>
</html>

