<%
  const resolveSeoMeta =
    typeof buildSeo === "function"
      ? buildSeo
      : (overrides = {}) => {
          const defaultTitle = "GESA | Fundacao ORES";
          const defaultDescription =
            "Sistema web de gestao social da Fundacao ORES para familias, voluntarios, atendimentos e agenda.";
          const normalizePath = (value, fallback = "/") => {
            const normalized = String(value || "").trim();
            if (!normalized) return fallback;
            if (/^https?:\/\//i.test(normalized)) return normalized;
            return normalized.startsWith("/") ? normalized : `/${normalized}`;
          };
          const normalizeSchemas = (value) => {
            if (!value) return [];
            return Array.isArray(value) ? value.filter(Boolean) : [value];
          };
          const noindexValue = typeof overrides.noindex === "boolean" ? overrides.noindex : true;
          return {
            title: String(overrides.title || "").trim() || defaultTitle,
            description: String(overrides.description || "").trim() || defaultDescription,
            canonicalUrl: normalizePath(overrides.canonicalPath),
            imageUrl: normalizePath(overrides.imagePath, "/assets/og-default.svg"),
            imageAlt:
              String(overrides.imageAlt || "").trim() ||
              "Identidade visual do GESA, sistema de gestao social da Fundacao ORES.",
            robots: noindexValue
              ? "noindex, nofollow, noarchive"
              : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
            locale: "pt_BR",
            type: String(overrides.type || "").trim() || "website",
            siteName: "GESA | Fundacao ORES",
            themeColor: String(overrides.themeColor || "").trim() || "#b24a32",
            noindex: noindexValue,
            schemas: normalizeSchemas(overrides.schemas),
          };
        };

  const seoMeta = resolveSeoMeta({
    title: typeof title !== "undefined" ? title : undefined,
    description: typeof metaDescription !== "undefined" ? metaDescription : undefined,
    canonicalPath: typeof canonicalPath !== "undefined" ? canonicalPath : undefined,
    noindex: typeof noindex !== "undefined" ? noindex : undefined,
    imagePath: typeof seoImagePath !== "undefined" ? seoImagePath : undefined,
    imageAlt: typeof seoImageAlt !== "undefined" ? seoImageAlt : undefined,
    type: typeof seoType !== "undefined" ? seoType : undefined,
    themeColor: typeof themeColor !== "undefined" ? themeColor : undefined,
    schemas: typeof seoSchemas !== "undefined" ? seoSchemas : undefined,
  });
%>
<title><%= seoMeta.title %></title>
<meta name="description" content="<%= seoMeta.description %>" />
<meta name="robots" content="<%= seoMeta.robots %>" />
<meta name="application-name" content="GESA" />
<meta name="theme-color" content="<%= seoMeta.themeColor %>" />
<link rel="icon" type="image/svg+xml" href="/static/images/logo-ores.svg" />
<link rel="shortcut icon" href="/static/images/logo-ores.svg" />
<link rel="apple-touch-icon" href="/static/images/logo-ores.svg" />
<link rel="canonical" href="<%= seoMeta.canonicalUrl %>" />
<meta property="og:locale" content="<%= seoMeta.locale %>" />
<meta property="og:type" content="<%= seoMeta.type %>" />
<meta property="og:title" content="<%= seoMeta.title %>" />
<meta property="og:description" content="<%= seoMeta.description %>" />
<meta property="og:url" content="<%= seoMeta.canonicalUrl %>" />
<meta property="og:site_name" content="<%= seoMeta.siteName %>" />
<meta property="og:image" content="<%= seoMeta.imageUrl %>" />
<meta property="og:image:alt" content="<%= seoMeta.imageAlt %>" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<%= seoMeta.title %>" />
<meta name="twitter:description" content="<%= seoMeta.description %>" />
<meta name="twitter:image" content="<%= seoMeta.imageUrl %>" />
<% seoMeta.schemas.forEach((schema) => { %>
  <script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> type="application/ld+json"><%- serializeForInlineScript(schema) %></script>
<% }) %>
