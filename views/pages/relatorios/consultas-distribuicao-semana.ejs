<section class="dashboard-home consultation-dashboard-page consultation-weekday-page" data-page="relatorios-consultas-semana">
  <header class="dashboard-hero consulta-hero card-elevated">
    <div class="consulta-hero-copy">
      <p class="dashboard-overline">Análise por dia da semana</p>
      <h2 class="dashboard-hero-title"><%= header?.title || "Distribuição semanal das consultas" %></h2>
      <p class="dashboard-hero-subtitle"><%= header?.subtitle || "Leitura aprofundada da agenda por mês." %></p>

      <div class="dashboard-hero-stats">
        <% (header?.stats || []).forEach((item) => { %>
          <article class="dashboard-hero-stat">
            <span><%= item.label %></span>
            <strong><%= item.value %></strong>
          </article>
        <% }) %>
      </div>

      <div class="consulta-detail-actions">
        <a href="<%= header?.backHref || '/relatorios/consultas' %>" class="btn btn-muted">Voltar para o dashboard</a>
      </div>
    </div>

    <aside class="consulta-filter-card">
      <div class="dashboard-panel-head compact">
        <div>
          <p class="dashboard-panel-overline">Filtros do mês</p>
          <h3>Refine o recorte</h3>
          <p>Escolha o mês, o profissional e busque um paciente específico para aprofundar a leitura.</p>
        </div>
      </div>

      <form class="consulta-filter-form" method="get" action="<%= filters?.action || '' %>">
        <input type="hidden" name="pagina" value="1" />
        <div class="consulta-filter-grid consulta-filter-grid-compact">
          <label class="input-group">
            <span>Mês</span>
            <select class="input-control" name="mes">
              <% (filters?.monthOptions || []).forEach((item) => { %>
                <option value="<%= item.value %>" <%= Number(filters?.mes || 0) === Number(item.value) ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </label>

          <label class="input-group">
            <span>Ano</span>
            <select class="input-control" name="ano">
              <% (filters?.yearOptions || []).forEach((item) => { %>
                <option value="<%= item %>" <%= Number(filters?.ano || 0) === Number(item) ? 'selected' : '' %>><%= item %></option>
              <% }) %>
            </select>
          </label>

          <% if (filters?.canViewAll) { %>
            <label class="input-group">
              <span>Profissional</span>
              <select class="input-control" name="responsavelId">
                <option value="">Toda a equipe</option>
                <% (filters?.professionalOptions || []).forEach((item) => { %>
                  <option value="<%= item.value %>" <%= String(filters?.responsavelId || '') === String(item.value) ? 'selected' : '' %>><%= item.label %></option>
                <% }) %>
              </select>
            </label>
          <% } %>

          <label class="input-group">
            <span>Paciente / matrícula</span>
            <input class="input-control" type="search" name="buscaPaciente" value="<%= filters?.buscaPaciente || '' %>" placeholder="Nome do paciente, família ou matrícula" />
          </label>

          <label class="input-group">
            <span>Dia da semana</span>
            <select class="input-control" name="diaSemana">
              <% (filters?.weekdayOptions || []).forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(filters?.diaSemana || '') === String(item.key) ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </label>

          <label class="input-group">
            <span>Status</span>
            <select class="input-control" name="status">
              <% (filters?.statusOptions || []).forEach((item) => { %>
                <option value="<%= item.value %>" <%= String(filters?.status || '') === String(item.value) ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </label>

          <label class="input-group">
            <span>Relatório</span>
            <select class="input-control" name="relatorio">
              <% (filters?.reportOptions || []).forEach((item) => { %>
                <option value="<%= item.value %>" <%= String(filters?.relatorio || '') === String(item.value) ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </label>

          <label class="input-group">
            <span>Por página</span>
            <select class="input-control" name="limite">
              <% (detailTable?.pageSizeOptions || [10, 20, 50]).forEach((item) => { %>
                <option value="<%= item %>" <%= Number(filters?.limite || 0) === Number(item) ? 'selected' : '' %>><%= item %> itens</option>
              <% }) %>
            </select>
          </label>
        </div>

        <div class="consulta-filter-actions">
          <button type="submit" class="btn btn-primary">Atualizar análise</button>
          <a href="<%= filters?.action || '' %>" class="btn btn-muted">Limpar</a>
        </div>
      </form>
    </aside>
  </header>

  <section class="dashboard-summary-grid">
    <% (summaryCards || []).forEach((card) => { %>
      <article class="dashboard-summary-card card-elevated">
        <div class="dashboard-summary-icon" aria-hidden="true"><i class="<%= card.icon %>"></i></div>
        <div class="dashboard-summary-copy">
          <span class="dashboard-summary-title"><%= card.title %></span>
          <strong class="dashboard-summary-value"><%= card.value %></strong>
          <small class="dashboard-summary-caption"><%= card.caption %></small>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="dashboard-grid dashboard-grid-primary">
    <article class="dashboard-panel card-elevated">
      <header class="dashboard-panel-head">
        <div>
          <p class="dashboard-panel-overline">Tendência mensal</p>
          <h3><%= timelinePanel?.title %></h3>
          <p><%= timelinePanel?.subtitle %></p>
        </div>
      </header>

      <div class="dashboard-chart-kpis">
        <% (timelinePanel?.kpis || []).forEach((item) => { %>
          <article class="dashboard-chart-kpi">
            <span><%= item.label %></span>
            <strong><%= item.value %></strong>
          </article>
        <% }) %>
      </div>

      <div class="dashboard-line-chart-shell">
        <div class="dashboard-chart-tooltip" hidden data-consulta-line-tooltip></div>
        <div class="dashboard-line-chart" data-consulta-line-chart></div>
      </div>

      <div class="dashboard-chart-legend">
        <% (timelinePanel?.legend || []).forEach((item) => { %>
          <span><i style="background:<%= item.color %>;"></i><%= item.label %></span>
        <% }) %>
      </div>
    </article>

    <article class="dashboard-panel card-elevated">
      <header class="dashboard-panel-head">
        <div>
          <p class="dashboard-panel-overline">Distribuição</p>
          <h3>Status do recorte</h3>
          <p>Resumo visual de presença, faltas, pendências, remarcações e cancelamentos no mês filtrado.</p>
        </div>
      </header>

      <% if (Number(statusDistribution?.total || 0) > 0) { %>
        <div class="dashboard-donut-layout">
          <div class="dashboard-donut-chart" style="--dashboard-donut:<%= statusDistribution.gradient %>;">
            <div class="dashboard-donut-center">
              <strong><%= statusDistribution.totalLabel %></strong>
              <span>consulta(s)</span>
            </div>
          </div>

          <div class="dashboard-donut-legend">
            <% (statusDistribution?.items || []).forEach((item) => { %>
              <article class="dashboard-donut-item">
                <span class="dashboard-donut-swatch" style="background:<%= item.color %>;"></span>
                <span class="dashboard-donut-copy">
                  <strong><%= item.label %></strong>
                  <small><%= item.valueLabel %> registro(s)</small>
                </span>
                <span class="dashboard-donut-share"><%= item.share %>%</span>
              </article>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="dashboard-empty-state compact">
          <i class="fa-solid fa-chart-pie" aria-hidden="true"></i>
          <p>Nenhuma consulta encontrada para este recorte.</p>
        </div>
      <% } %>
    </article>
  </section>

  <section class="dashboard-grid dashboard-grid-secondary">
    <article class="dashboard-panel card-elevated">
      <header class="dashboard-panel-head">
        <div>
          <p class="dashboard-panel-overline">Semana</p>
          <h3>Distribuição por dia</h3>
          <p>Clique em um dia para focar a análise e ver apenas as consultas daquele recorte semanal.</p>
        </div>
      </header>

      <% if (Array.isArray(weekdayRows) && weekdayRows.some((item) => Number(item.total || 0) > 0)) { %>
        <div class="consulta-weekday-grid consulta-weekday-grid-detailed">
          <% weekdayRows.forEach((item) => { %>
            <a href="<%= item.href %>" class="consulta-weekday-card consulta-weekday-link <%= item.active ? 'is-active' : '' %>">
              <div class="consulta-weekday-top">
                <strong><%= item.shortLabel %></strong>
                <span><%= item.totalLabel %> consulta(s)</span>
              </div>
              <div class="consulta-weekday-stats">
                <span><b><%= item.presentesLabel %></b> presenças</span>
                <span><b><%= item.faltasLabel %></b> ausências</span>
                <span><b><%= item.ajusteLabel %></b> em ajuste</span>
                <span><b><%= item.comparecimentoLabel %></b> de comparecimento</span>
              </div>
              <div class="dashboard-bar-track">
                <span class="dashboard-bar-fill" style="width:<%= item.share %>%;"></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="dashboard-empty-state compact">
          <i class="fa-solid fa-calendar-week" aria-hidden="true"></i>
          <p>Nenhuma distribuição disponível para este recorte.</p>
        </div>
      <% } %>
    </article>

    <article class="dashboard-panel card-elevated">
      <header class="dashboard-panel-head">
        <div>
          <p class="dashboard-panel-overline">Pacientes em destaque</p>
          <h3>Quem mais apareceu no recorte</h3>
          <p>Ajuda a identificar recorrência de pacientes e famílias quando você filtra um mês ou um profissional.</p>
        </div>
      </header>

      <% if (Array.isArray(patientRows) && patientRows.length) { %>
        <div class="dashboard-bar-list">
          <% patientRows.forEach((item) => { %>
            <a href="<%= item.href %>" class="dashboard-bar-card consulta-bar-link">
              <div class="dashboard-bar-top">
                <div class="dashboard-bar-person">
                  <span class="dashboard-avatar soft"><%= item.initials %></span>
                  <div>
                    <strong><%= item.label %></strong>
                    <small><%= item.subtitle %></small>
                  </div>
                </div>
                <strong class="dashboard-bar-value"><%= item.totalLabel %></strong>
              </div>
              <div class="consulta-bar-meta">
                <span><b><%= item.comparecimentoLabel %></b> comparecimento</span>
                <span><b><%= item.faltasLabel %></b> faltas</span>
                <span><b><%= item.relatoriosLabel %></b> relatórios</span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="dashboard-empty-state compact">
          <i class="fa-solid fa-user-group" aria-hidden="true"></i>
          <p>Nenhum paciente encontrado com esse recorte.</p>
        </div>
      <% } %>
    </article>
  </section>

  <section class="dashboard-panel card-elevated dashboard-table-panel">
    <header class="dashboard-panel-head">
      <div>
        <p class="dashboard-panel-overline">Consultas do recorte</p>
        <h3>Lista detalhada do mês</h3>
        <p>Consulta a consulta para você validar o comportamento do mês, do dia da semana ou do paciente pesquisado.</p>
      </div>
      <span class="consulta-mode-badge">Página <%= detailTable?.pagination?.page || 1 %> de <%= detailTable?.pagination?.totalPages || 1 %></span>
    </header>

    <div class="dashboard-table-wrap consulta-table-wrap">
      <table class="dashboard-table consulta-table" data-stack-mobile="true">
        <thead>
          <tr>
            <th>Consulta</th>
            <th>Quando</th>
            <th>Tipo</th>
            <th>Status</th>
            <th>Relatório</th>
            <th>Profissional</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody>
          <% if (Array.isArray(detailTable?.rows) && detailTable.rows.length) { %>
            <% detailTable.rows.forEach((row) => { %>
              <tr>
                <td data-label="Consulta">
                  <span class="dashboard-table-stack">
                    <strong><%= row.titulo %></strong>
                    <small class="dashboard-table-note"><%= row.patientName %><%= row.patientCode ? ` • ${row.patientCode}` : '' %></small>
                  </span>
                </td>
                <td data-label="Quando"><%= row.dateTimeLabel %></td>
                <td data-label="Tipo"><%= row.typeLabel %></td>
                <td data-label="Status"><span class="status-badge status-<%= row.presenceTone %>"><%= row.presenceLabel %></span></td>
                <td data-label="Relatório"><span class="status-badge status-<%= row.reportTone %>"><%= row.reportLabel %></span></td>
                <td data-label="Profissional"><%= row.professionalName %></td>
                <td data-label="Ação"><a href="<%= row.familyHref %>" class="dashboard-table-action consulta-detail-link">Abrir ficha</a></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="dashboard-table-empty"><%= detailTable?.emptyMessage || 'Nenhuma consulta encontrada.' %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="consulta-table-footer">
      <p class="consulta-table-summary"><%= detailTable?.summaryLabel || '0 resultados' %></p>

      <% if (Number(detailTable?.pagination?.totalPages || 1) > 1) { %>
        <nav class="consulta-pagination" aria-label="Paginação da análise semanal">
          <a class="consulta-pagination-link btn btn-muted <%= !detailTable?.pagination?.hasPrevPage ? 'is-disabled' : '' %>" href="<%= detailTable?.pagination?.hasPrevPage ? detailTable.pagination.prevHref : '#' %>">Anterior</a>
          <% (detailTable?.pagination?.pages || []).forEach((item) => { %>
            <a class="consulta-pagination-link btn <%= item.current ? 'btn-primary' : 'btn-muted' %>" href="<%= item.href %>"><%= item.number %></a>
          <% }) %>
          <a class="consulta-pagination-link btn btn-muted <%= !detailTable?.pagination?.hasNextPage ? 'is-disabled' : '' %>" href="<%= detailTable?.pagination?.hasNextPage ? detailTable.pagination.nextHref : '#' %>">Próxima</a>
        </nav>
      <% } %>
    </div>
  </section>
</section>

<script id="consultation-dashboard-data" type="application/json"><%- JSON.stringify(consultationDashboardData || {}) %></script>
