<section class="family-portal-page">
  <header class="family-portal-hero module-card">
    <div class="family-portal-hero-copy">
      <span class="badge-soft">Portal externo da família</span>
      <h2>Bem-vindo(a), <%= resumoFamilia?.responsavel || usuario?.nome || "Familia" %></h2>
      <p>
        Aqui você acompanha os dados principais da família, os dependentes vinculados,
        as próximas consultas e as atualizacoes mais recentes da agenda.
      </p>
    </div>
    <div class="family-portal-hero-actions">
      <a href="/minha-familia/consultas" class="btn btn-primary">
        <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
        <span>Ver consultas</span>
      </a>
      <a href="/minha-familia/notificacoes" class="btn btn-muted">
        <i class="fa-solid fa-bell" aria-hidden="true"></i>
        <span>Notificacoes</span>
        <% if (Number(notificationCount || 0) > 0) { %>
          (<%= notificationCount %>)
        <% } %>
      </a>
    </div>
  </header>

  <% if (!familia) { %>
    <section class="module-card family-empty-state">
      <h3>Família ainda não vinculada</h3>
      <p>
        Não encontramos um cadastro familiar associado ao seu acesso. Fale com a equipe
        da ONG para concluir esse vinculo e liberar o acompanhamento externo.
      </p>
    </section>
  <% } else { %>
    <section class="family-kpi-grid">
      <article class="module-card family-kpi-card">
        <span class="family-kpi-label">Dependentes</span>
        <strong class="family-kpi-value"><%= totais?.dependentes || 0 %></strong>
      </article>
      <article class="module-card family-kpi-card">
        <span class="family-kpi-label">Próximas consultas</span>
        <strong class="family-kpi-value"><%= totais?.proximasConsultas || 0 %></strong>
      </article>
      <article class="module-card family-kpi-card">
        <span class="family-kpi-label">Consultas realizadas</span>
        <strong class="family-kpi-value"><%= totais?.consultasRealizadas || 0 %></strong>
      </article>
      <article class="module-card family-kpi-card">
        <span class="family-kpi-label">Notificacoes não lidas</span>
        <strong class="family-kpi-value"><%= totais?.notificacoes || 0 %></strong>
      </article>
    </section>

    <section class="family-main-grid">
      <article class="module-card family-panel">
        <header class="family-panel-head">
          <div>
            <h3>Dados da família</h3>
            <p>Informacoes basicas do responsavel e do endereço cadastrado.</p>
          </div>
        </header>

        <div class="family-info-grid">
          <div class="family-info-item">
            <span>Responsavel</span>
            <strong><%= resumoFamilia?.responsavel || "-" %></strong>
          </div>
          <div class="family-info-item">
            <span>Parentesco</span>
            <strong><%= resumoFamilia?.parentesco || "-" %></strong>
          </div>
          <div class="family-info-item">
            <span>Telefone</span>
            <strong><%= resumoFamilia?.telefone || "-" %></strong>
          </div>
          <div class="family-info-item">
            <span>Email</span>
            <strong><%= resumoFamilia?.email || "-" %></strong>
          </div>
          <div class="family-info-item family-info-item-wide">
            <span>Endereço</span>
            <strong><%= resumoFamilia?.endereco || "-" %></strong>
          </div>
        </div>
      </article>

      <article class="module-card family-panel">
        <header class="family-panel-head">
          <div>
            <h3>Dependentes vinculados</h3>
            <p>Lista de dependentes associados a esta família.</p>
          </div>
        </header>

        <% if (!dependentes || !dependentes.length) { %>
          <p class="empty-hint">Nenhum dependente vinculado no momento.</p>
        <% } else { %>
          <div class="family-dependent-list">
            <% dependentes.forEach((item) => { %>
              <article class="family-dependent-card">
                <div>
                  <strong><%= item.nome %></strong>
                  <p>Nascimento: <%= item.dataNascimentoLabel || "-" %></p>
                </div>
                <div class="family-dependent-meta">
                  <span class="status-badge <%= item.ativo ? 'status-active' : 'status-inactive' %>">
                    <%= item.ativo ? "Ativo" : "Inativo" %>
                  </span>
                  <span class="status-badge status-neutral"><%= item.tipoDeficienciaLabel %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </article>
    </section>

    <section class="family-split-grid">
      <article class="module-card family-panel">
        <header class="family-panel-head">
          <div>
            <h3>Próximas consultas</h3>
            <p>Agenda futura da família.</p>
          </div>
          <a href="/minha-familia/consultas" class="btn btn-muted">
            <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
            <span>Ver tudo</span>
          </a>
        </header>

        <% if (!proximasConsultas || !proximasConsultas.length) { %>
          <p class="empty-hint">Nenhuma consulta futura marcada no momento.</p>
        <% } else { %>
          <div class="family-appointment-list">
            <% proximasConsultas.forEach((item) => { %>
              <article class="family-appointment-card tone-<%= item.tone %>">
                <div class="family-appointment-main">
                  <strong><%= item.titulo %></strong>
                  <p><%= item.dataHoraLabel %></p>
                </div>
                <div class="family-appointment-meta">
                  <span><strong>Dependente:</strong> <%= item.dependenteNome %></span>
                  <span><strong>Profissional:</strong> <%= item.profissionalNome %></span>
                  <span><strong>Status:</strong> <%= item.statusAgendamentoLabel %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </article>

      <article class="module-card family-panel">
        <header class="family-panel-head">
          <div>
            <h3>Atualizacoes recentes</h3>
            <p>Últimos status de consultas e movimentacoes da agenda.</p>
          </div>
          <a href="/minha-familia/notificacoes" class="btn btn-muted">
            <i class="fa-solid fa-bell" aria-hidden="true"></i>
            <span>Abrir notificacoes</span>
          </a>
        </header>

        <% if (!notificacoesRecentes || !notificacoesRecentes.length) { %>
          <p class="empty-hint">Nenhuma notificacao recente registrada.</p>
        <% } else { %>
          <div class="family-notification-preview-list">
            <% notificacoesRecentes.forEach((item) => { %>
              <a href="<%= item.href %>" class="family-notification-preview <%= item.lida ? 'is-read' : 'is-unread' %>">
                <div>
                  <strong><%= item.titulo %></strong>
                  <p><%= item.mensagem %></p>
                </div>
                <span><%= item.criadoEmLabel %></span>
              </a>
            <% }) %>
          </div>
        <% } %>
      </article>
    </section>

    <section class="module-card family-panel">
      <header class="family-panel-head">
        <div>
          <h3>Histórico recente de consultas</h3>
          <p>Status recentes, sem exibir anotacoes internas da equipe.</p>
        </div>
        <a href="/minha-familia/consultas" class="btn btn-muted">
          <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
          <span>Ver histórico completo</span>
        </a>
      </header>

      <% if (!historicoRecente || !historicoRecente.length) { %>
        <p class="empty-hint">Ainda não ha movimentacoes recentes para exibir.</p>
      <% } else { %>
        <div class="family-appointment-list">
          <% historicoRecente.forEach((item) => { %>
            <article class="family-appointment-card tone-<%= item.tone %>">
              <div class="family-appointment-main">
                <strong><%= item.titulo %></strong>
                <p><%= item.dataHoraLabel %></p>
              </div>
              <div class="family-appointment-meta">
                <span><strong>Dependente:</strong> <%= item.dependenteNome %></span>
                <span><strong>Profissional:</strong> <%= item.profissionalNome %></span>
                <span><strong>Agendamento:</strong> <%= item.statusAgendamentoLabel %></span>
                <span><strong>Presença:</strong> <%= item.statusPresencaLabel %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% } %>
</section>
