<section class="auth-viewport">
  <div class="auth-bubble bubble-a"></div>
  <div class="auth-bubble bubble-b"></div>
  <div class="auth-bubble bubble-c"></div>
  <div class="auth-bubble bubble-d"></div>
  <div class="auth-bubble bubble-e"></div>

  <div class="auth-card card-elevated">
    <h1 class="auth-brand">GESA</h1>
    <p class="auth-subtitle">Sistema de GestÃ£o da FundaÃ§Ã£o Alento</p>

    <% if (errorMessage && errorMessage.length) { %>
      <div class="auth-error">
        <%= errorMessage[0] %>
      </div>
    <% } %>

    <form method="post" action="/auth/login" autocomplete="off" class="form-stack">
      <label for="email" class="input-label">Usuario ou Email</label>
      <div class="field-icon-wrap">
        <i class="fa-regular fa-user field-icon"></i>
        <input
          class="input-control"
          id="email"
          name="email"
          type="text"
          placeholder="Digite seu usuario ou e-mail"
          required
        />
      </div>

      <div class="label-row">
        <label for="senha" class="input-label">Senha</label>
        <a href="#" class="mini-link">Esqueceu a senha?</a>
      </div>
      <div class="field-icon-wrap">
        <i class="fa-regular fa-lock field-icon"></i>
        <input
          class="input-control"
          id="senha"
          name="senha"
          type="password"
          placeholder="********"
          required
        />
        <i class="fa-regular fa-eye-slash field-icon-right"></i>
      </div>

      <button type="submit" class="btn btn-primary btn-block">
        Entrar
      </button>

      <a href="#" class="create-link">Criar Conta</a>
    </form>
  </div>
</section>

