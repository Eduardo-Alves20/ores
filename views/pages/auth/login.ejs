<section class="auth-viewport">
  <div class="auth-bubble bubble-a"></div>
  <div class="auth-bubble bubble-b"></div>
  <div class="auth-bubble bubble-c"></div>
  <div class="auth-bubble bubble-d"></div>
  <div class="auth-bubble bubble-e"></div>

  <div class="auth-card card-elevated">
    <h1 class="auth-brand">GESA</h1>
    <p class="auth-subtitle">Sistema de Gestão da Fundação Alento</p>

    <% if (errorMessage && errorMessage.length) { %>
      <div class="auth-error">
        <%= errorMessage[0] %>
      </div>
    <% } %>

    <% if (successMessage && successMessage.length) { %>
      <div class="auth-success">
        <%= successMessage[0] %>
      </div>
    <% } %>

    <form method="post" action="/auth/login" autocomplete="off" class="form-stack">
      <%- renderCsrfField() %>
      <label for="email" class="input-label">CPF, Usuário ou Email</label>
      <div class="field-icon-wrap">
        <i class="fa-solid fa-user field-icon"></i>
        <input
          class="input-control"
          id="email"
          name="email"
          type="text"
          placeholder="Digite CPF, usuário ou e-mail"
          required
        />
      </div>

      <div class="label-row">
        <label for="senha" class="input-label">Senha</label>
        <a href="#" class="mini-link">Esqueceu a senha?</a>
      </div>
      <div class="field-icon-wrap">
        <i class="fa-solid fa-lock field-icon"></i>
        <input
          class="input-control"
          id="senha"
          name="senha"
          type="password"
          placeholder="********"
          required
        />
        <button
          class="field-icon-toggle"
          type="button"
          data-password-toggle="senha"
          aria-label="Mostrar senha"
          aria-pressed="false"
        >
          <i class="fa-solid fa-eye-slash field-icon-right" data-password-icon></i>
        </button>
      </div>

      <div class="auth-actions">
        <button type="submit" class="btn btn-primary btn-block auth-action-btn">
          Entrar
        </button>

        <a href="/cadastro" class="btn btn-accent btn-block auth-action-btn">
          Criar conta
        </a>
      </div>
    </form>
  </div>
</section>
