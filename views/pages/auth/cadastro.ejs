                    <i class="fa-solid fa-envelope-open-text" aria-hidden="true"></i>
                    <span>
                      O e-mail <strong data-cadastro-email-preview><%= getRootValue('voluntario', 'email') || 'informado abaixo' %></strong> será usado nas comunicações sobre a análise do cadastro.
                    </span>
                  </div>

                  <div class="cadastro-wizard-grid">
                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-email">
                      <span class="input-label">E-mail<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-email"
                        name="email"
                        type="email"
                        maxlength="140"
                        placeholder="voce@email.com"
                        value="<%= getRootValue('voluntario', 'email') %>"
                        autocomplete="email"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-telefone">
                      <span class="input-label">Telefone<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-telefone"
                        name="telefone"
                        type="text"
                        maxlength="20"
                        placeholder="(00) 00000-0000"
                        value="<%= getRootValue('voluntario', 'telefone') %>"
                        inputmode="tel"
                        autocomplete="tel"
                        data-mask="phone"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-login">
                      <span class="input-label">Usuário para login<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-login"
                        name="login"
                        type="text"
                        maxlength="40"
                        placeholder="Como você quer entrar no sistema"
                        value="<%= getRootValue('voluntario', 'login') %>"
                        autocomplete="username"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-senha">
                      <span class="input-label">Senha<span class="cadastro-required">*</span></span>
                      <div class="field-icon-wrap">
                        <input
                          class="input-control cadastro-input"
                          id="cadastro-voluntario-senha"
                          name="senha"
                          type="password"
                          maxlength="120"
                          placeholder="<%= senhaPlaceholder %>"
                          autocomplete="new-password"
                          required
                        />
                        <button
                          class="field-icon-toggle"
                          type="button"
                          data-password-toggle="cadastro-voluntario-senha"
                          aria-label="Mostrar senha"
                          aria-pressed="false"
                        >
                          <i class="fa-solid fa-eye-slash field-icon-right" data-password-icon></i>
                        </button>
                      </div>
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-confirmar-senha">
                      <span class="input-label">Confirmar senha<span class="cadastro-required">*</span></span>
                      <div class="field-icon-wrap">
                        <input
                          class="input-control cadastro-input"
                          id="cadastro-voluntario-confirmar-senha"
                          name="confirmarSenha"
                          type="password"
                          maxlength="120"
                          placeholder="Repita sua senha"
                          autocomplete="new-password"
                          required
                        />
                        <button
                          class="field-icon-toggle"
                          type="button"
                          data-password-toggle="cadastro-voluntario-confirmar-senha"
                          aria-label="Mostrar senha"
                          aria-pressed="false"
                        >
                          <i class="fa-solid fa-eye-slash field-icon-right" data-password-icon></i>
                        </button>
                      </div>
                    </label>
                  </div>

                  <section class="cadastro-secure-upload-block cadastro-secure-upload-block-final">
                    <div class="cadastro-secure-upload-head">
                      <h3>Documentos e foto com proteção reforçada</h3>
                      <p>
                        O documento e a foto ficam fora da área pública, criptografados em repouso e visíveis apenas
                        para administração e assistência social autorizada no fluxo de aprovação.
                      </p>
                    </div>

                    <div class="cadastro-wizard-grid">
                      <label class="field-wrap cadastro-field span-2 cadastro-secure-upload-card" for="cadastro-voluntario-documento">
                        <span class="input-label">Documento de identidade<span class="cadastro-required">*</span></span>
                        <input
                          class="input-control cadastro-input"
                          id="cadastro-voluntario-documento"
                          name="documentoIdentidadeArquivo"
                          type="file"
                          accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp"
                          required
                          data-cadastro-secure-upload-input="documentoIdentidade"
                        />
                        <small class="cadastro-secure-upload-copy">Aceita RG ou CNH em PDF, JPG, PNG ou WEBP.</small>
                        <div class="cadastro-secure-upload-summary" data-cadastro-secure-upload-summary="documentoIdentidade">
                          <strong data-cadastro-secure-upload-name="documentoIdentidade">Nenhum documento selecionado.</strong>
                          <span data-cadastro-secure-upload-size="documentoIdentidade"></span>
                        </div>
                      </label>

                      <label class="field-wrap cadastro-field span-2 cadastro-secure-upload-card" for="cadastro-voluntario-foto">
                        <span class="input-label">Foto do rosto ou meio corpo<span class="cadastro-required">*</span></span>
                        <input
                          class="input-control cadastro-input"
                          id="cadastro-voluntario-foto"
                          name="fotoPerfilArquivo"
                          type="file"
                          accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                          capture="user"
                          required
                          data-cadastro-secure-upload-input="fotoPerfil"
                        />
                        <small class="cadastro-secure-upload-copy">Você pode tirar a foto na hora pelo celular ou enviar uma imagem pronta para perfil e crachá.</small>
                        <div class="cadastro-secure-upload-summary cadastro-secure-upload-summary-photo" data-cadastro-secure-upload-summary="fotoPerfil">
                          <img
                            class="cadastro-secure-upload-preview"
                            src=""
                            alt="Pré-visualização da foto do voluntário"
                            hidden
                            data-cadastro-secure-upload-preview="fotoPerfil"
                          />
                          <div class="cadastro-secure-upload-summary-body">
                            <strong data-cadastro-secure-upload-name="fotoPerfil">Nenhuma foto selecionada.</strong>
                            <span data-cadastro-secure-upload-size="fotoPerfil"></span>
                          </div>
                        </div>
                      </label>
                    </div>
                  </section>

                  <div class="cadastro-wizard-inline-note cadastro-wizard-inline-note-strong">
                    Ao enviar, seu cadastro segue para análise da equipe da Alento. Você será avisado quando o acesso estiver liberado.
                  </div>
                </section>
              </div>

              <div class="cadastro-wizard-actions">
                <button
                  type="button"
                  class="btn btn-muted"
                  data-cadastro-wizard-back
                  <%= currentVolunteerStepIndex <= 0 ? "disabled" : "" %>
                >
                  Anterior
                </button>

                <div class="cadastro-wizard-actions-end">
                  <button type="button" class="btn btn-muted" data-cadastro-back="escolha">Trocar perfil</button>
                  <button
                    type="button"
                    class="btn btn-accent"
                    data-cadastro-wizard-next
                    <%= currentVolunteerStepIndex === volunteerWizardSteps.length - 1 ? "hidden" : "" %>
                  >
                    Próximo
                  </button>
                  <button
                    type="submit"
                    class="btn btn-accent cadastro-submit-btn"
                    data-cadastro-wizard-submit
                    <%= currentVolunteerStepIndex === volunteerWizardSteps.length - 1 ? "" : "hidden" %>
                  >
                    Enviar cadastro
                  </button>
                </div>
              </div>
            </section>
          <% } else { %>
            <section
              class="cadastro-card cadastro-form-card card-elevated <%= activeVariantPanel === 'dados' ? 'is-active' : '' %>"
              data-cadastro-panel="dados"
            >
              <header class="cadastro-card-head theme-<%= variant.theme %>">
                <button
                  type="button"
                  class="cadastro-back-btn"
                  data-cadastro-back="escolha"
                  aria-label="Voltar para escolher o perfil"
                >
                  <i class="fa-solid fa-arrow-left"></i>
                </button>

                <span class="cadastro-card-icon" aria-hidden="true">
                  <i class="<%= variant.icon %>"></i>
                </span>

                <div>
                  <h2><%= variant.headerTitle %></h2>
                </div>
              </header>

              <div class="cadastro-card-body">
                <div class="cadastro-field-grid">
                  <% (variant.profileFields || []).forEach((field) => { %>
                    <% const fieldName = field.extraKey ? `dadosCadastro[${field.extraKey}]` : field.key; %>
                    <% const fieldValue = field.extraKey ? getExtraValue(variant.key, field.extraKey) : getRootValue(variant.key, field.key); %>
                    <% const fieldId = `cadastro-${variant.key}-${field.extraKey || field.key}`; %>

                    <label class="field-wrap cadastro-field" for="<%= fieldId %>">
                      <span class="input-label">
                        <%= field.label %><% if (field.required) { %><span class="cadastro-required">*</span><% } %>
                      </span>

                      <% if (field.type === "textarea") { %>
                        <textarea
                          class="input-control cadastro-input"
                          id="<%= fieldId %>"
                          name="<%= fieldName %>"
                          rows="3"
                          placeholder="<%= field.placeholder || '' %>"
                          <%= field.required ? "required" : "" %>
                        ><%= fieldValue %></textarea>
                      <% } else { %>
                        <input
                          class="input-control cadastro-input"
                          id="<%= fieldId %>"
                          name="<%= fieldName %>"
                          type="<%= field.type || 'text' %>"
                          maxlength="<%= field.maxlength || 140 %>"
                          placeholder="<%= field.placeholder || '' %>"
                          value="<%= fieldValue %>"
                          <%= field.required ? "required" : "" %>
                          <%= field.inputmode ? `inputmode="${field.inputmode}"` : "" %>
                          <%= field.autocomplete ? `autocomplete="${field.autocomplete}"` : "" %>
                          <%= field.mask ? `data-mask="${field.mask}"` : "" %>
                        />
                      <% } %>
                    </label>
                  <% }) %>
                </div>

                <div class="cadastro-actions">
                  <button
                    type="button"
                    class="btn btn-accent btn-block cadastro-submit-btn"
                    data-cadastro-next
                  >
                    Continuar cadastro
                  </button>
                </div>
              </div>
            </section>

            <section
              class="cadastro-card cadastro-form-card card-elevated <%= activeVariantPanel === 'acesso' ? 'is-active' : '' %>"
              data-cadastro-panel="acesso"
            >
              <header class="cadastro-card-head theme-<%= variant.theme %>">
                <button
                  type="button"
                  class="cadastro-back-btn"
                  data-cadastro-back="dados"
                  aria-label="Voltar para os dados do cadastro"
                >
                  <i class="fa-solid fa-arrow-left"></i>
                </button>

                <span class="cadastro-card-icon" aria-hidden="true">
                  <i class="<%= variant.icon %>"></i>
                </span>

                <div>
                  <h2><%= variant.accessTitle %></h2>
                  <p><%= variant.accessDescription %></p>
                </div>
              </header>

              <div class="cadastro-card-body">
                <% if (variant.key !== "familia") { %>
                  <div class="cadastro-access-note">
                    <i class="fa-solid fa-envelope-open-text" aria-hidden="true"></i>
                    <span>
                      O e-mail <strong data-cadastro-email-preview><%= getRootValue(variant.key, "email") || "informado acima" %></strong> será usado no processo.
                    </span>
                  </div>
                <% } %>

                <div class="cadastro-field-grid">
                  <% (variant.accessFields || []).forEach((field) => { %>
                    <% const fieldValue = getRootValue(variant.key, field.key); %>
                    <% const fieldId = `cadastro-${variant.key}-${field.key}`; %>

                    <label class="field-wrap cadastro-field" for="<%= fieldId %>">
                      <span class="input-label">
                        <%= field.label %><% if (field.required) { %><span class="cadastro-required">*</span><% } %>
                      </span>

                      <% if (field.toggle) { %>
                        <div class="field-icon-wrap">
                          <input
                            class="input-control cadastro-input"
                            id="<%= fieldId %>"
                            name="<%= field.key %>"
                            type="password"
                            maxlength="120"
                            placeholder="<%= field.placeholder || '' %>"
                            value=""
                            <%= field.required ? "required" : "" %>
                            <%= field.autocomplete ? `autocomplete="${field.autocomplete}"` : "" %>
                            data-cadastro-access-input
                          />
                          <button
                            class="field-icon-toggle"
                            type="button"
                            data-password-toggle="<%= fieldId %>"
                            aria-label="Mostrar senha"
                            aria-pressed="false"
                          >
                            <i class="fa-solid fa-eye-slash field-icon-right" data-password-icon></i>
                          </button>
                        </div>
                      <% } else { %>
                        <input
                          class="input-control cadastro-input"
                          id="<%= fieldId %>"
                          name="<%= field.key %>"
                          type="<%= field.type || 'text' %>"
                          maxlength="<%= field.maxlength || 140 %>"
                          placeholder="<%= field.placeholder || '' %>"
                          value="<%= fieldValue %>"
                          <%= field.required ? "required" : "" %>
                          <%= field.autocomplete ? `autocomplete="${field.autocomplete}"` : "" %>
                          data-cadastro-access-input
                        />
                      <% } %>
                    </label>
                  <% }) %>
                </div>

                <div class="cadastro-submit-block">
                  <p class="cadastro-submit-copy">
                    Seu cadastro segue para análise da equipe e você será avisado quando o acesso estiver liberado.
                  </p>
                  <button type="submit" class="btn btn-accent btn-block cadastro-submit-btn">
                    Finalizar cadastro
                  </button>
                </div>
              </div>
            </section>
          <% } %>
        </form>
      <% }) %>
    </div>

    <div class="cadastro-footer-link">
      <span>Já tem acesso?</span>
      <a href="/login">Entrar agora</a>
    </div>
  </div>
</section>
