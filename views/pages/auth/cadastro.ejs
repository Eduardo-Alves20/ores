<%
  const ambienteSenha = String(ambiente || "").toUpperCase();
  const senhaModoDev = ["DEV", "DEVELOPMENT", "LOCAL", "TEST", "TESTE"].includes(ambienteSenha);
  const senhaPlaceholder = senhaModoDev ? "Mínimo de 4 caracteres" : "Mínimo de 10 caracteres";
  const currentFormData = formData && typeof formData === "object" ? formData : {};
  const currentExtraData =
    currentFormData?.dadosCadastro &&
    typeof currentFormData.dadosCadastro === "object" &&
    !Array.isArray(currentFormData.dadosCadastro)
      ? currentFormData.dadosCadastro
      : {};
  const currentType = String(currentFormData?.tipoCadastro || "").trim().toLowerCase();
  const volunteerWizardSteps = [
    {
      key: "profissional",
      label: "Profissional",
      subtitle: "Nome, função e área",
      icon: "fa-solid fa-user-tie",
    },
    {
      key: "atividade",
      label: "Atividade",
      subtitle: "Nome e descrição",
      icon: "fa-solid fa-clipboard-list",
    },
    {
      key: "objetivo",
      label: "Objetivo",
      subtitle: "Resultados pretendidos",
      icon: "fa-solid fa-bullseye",
    },
    {
      key: "publico",
      label: "Público",
      subtitle: "Quem participa",
      icon: "fa-solid fa-people-group",
    },
    {
      key: "metodologia",
      label: "Método",
      subtitle: "Passo a passo",
      icon: "fa-solid fa-list-check",
    },
    {
      key: "cronograma",
      label: "Cronograma",
      subtitle: "Dias, horário e período",
      icon: "fa-regular fa-calendar-days",
    },
    {
      key: "recursos",
      label: "Recursos",
      subtitle: "Materiais e apoio",
      icon: "fa-solid fa-toolbox",
    },
    {
      key: "resultados",
      label: "Resultados",
      subtitle: "Benefícios esperados",
      icon: "fa-solid fa-sparkles",
    },
    {
      key: "avaliacao",
      label: "Avaliação",
      subtitle: "Monitoramento",
      icon: "fa-solid fa-chart-column",
    },
    {
      key: "indicadores",
      label: "Indicadores",
      subtitle: "Como medir resultado",
      icon: "fa-solid fa-ruler-combined",
    },
    {
      key: "desafios",
      label: "Desafios",
      subtitle: "Riscos e estratégias",
      icon: "fa-regular fa-lightbulb",
    },
    {
      key: "integracao",
      label: "Integração",
      subtitle: "Articulação com a equipe",
      icon: "fa-solid fa-handshake",
    },
    {
      key: "observacoes",
      label: "Observações",
      subtitle: "Informações adicionais",
      icon: "fa-regular fa-note-sticky",
    },
    {
      key: "validacao",
      label: "Validação",
      subtitle: "Acesso, documento e foto",
      icon: "fa-solid fa-file-shield",
    },
  ];
  const volunteerWizardStepKeys = volunteerWizardSteps.map((step) => step.key);
  const rawCurrentStep = String(currentFormData?.fluxoEtapa || "").trim().toLowerCase();
  const currentVolunteerStep = volunteerWizardStepKeys.includes(rawCurrentStep)
    ? rawCurrentStep
    : volunteerWizardSteps[0].key;
  const currentVolunteerStepIndex = Math.max(volunteerWizardStepKeys.indexOf(currentVolunteerStep), 0);
  const currentVolunteerProgress = volunteerWizardSteps.length
    ? ((currentVolunteerStepIndex + 1) / volunteerWizardSteps.length) * 100
    : 100;
  const currentPanel = !currentType
    ? "escolha"
    : currentType === "voluntario"
      ? currentVolunteerStep
      : rawCurrentStep === "acesso"
        ? "acesso"
        : "dados";
  const currentProgressStep = currentPanel === "escolha" ? 1 : currentPanel === "acesso" ? 3 : 2;

  const cadastroVariants = [
    {
      key: "familia",
      label: "Família",
      selectDescription: "Cadastro para famílias que serão acompanhadas pela ONG",
      headerTitle: "Cadastro - Família",
      accessTitle: "Acesso - Família",
      accessDescription: "Informe como essa família vai acessar o sistema depois da aprovação.",
      icon: "fa-regular fa-heart",
      theme: "family",
      profileFields: [
        {
          key: "nome",
          label: "Nome do responsavel",
          type: "text",
          placeholder: "Maria da Silva",
          required: true,
          autocomplete: "name",
        },
        {
          key: "cpf",
          label: "CPF",
          type: "text",
          placeholder: "000.000.000-00",
          required: true,
          inputmode: "numeric",
          mask: "cpf",
        },
        {
          key: "telefone",
          label: "Telefone",
          type: "text",
          placeholder: "(00) 00000-0000",
          required: true,
          inputmode: "tel",
          autocomplete: "tel",
          mask: "phone",
        },
        {
          extraKey: "endereco",
          label: "Endereco",
          type: "text",
          placeholder: "Rua, numero, bairro",
          required: true,
          autocomplete: "street-address",
        },
        {
          extraKey: "quantidade_membros",
          label: "Quantidade de membros na família",
          type: "text",
          placeholder: "Ex: 4",
          required: true,
          inputmode: "numeric",
        },
        {
          extraKey: "principal_necessidade",
          label: "Principal necessidade",
          type: "text",
          placeholder: "Descreva brevemente",
          required: true,
        },
      ],
      accessFields: [
        {
          key: "email",
          label: "E-mail de acesso",
          type: "email",
          placeholder: "familia@email.com",
          required: true,
          autocomplete: "email",
        },
        {
          key: "login",
          label: "Usuário para login",
          type: "text",
          placeholder: "maria.silva",
          required: true,
          autocomplete: "username",
        },
        {
          key: "senha",
          label: "Senha",
          type: "password",
          placeholder: senhaPlaceholder,
          required: true,
          autocomplete: "new-password",
          toggle: true,
        },
        {
          key: "confirmarSenha",
          label: "Confirmar senha",
          type: "password",
          placeholder: "Repita a senha",
          required: true,
          autocomplete: "new-password",
          toggle: true,
        },
      ],
    },
    {
      key: "voluntario",
      label: "Voluntário",
      selectDescription: "Quero doar meu tempo e minhas habilidades para ajudar",
      icon: "fa-solid fa-users",
      theme: "volunteer",
    },
    {
      key: "orgao_publico",
      label: "Órgão Público",
      selectDescription: "Representante de instituição ou órgão governamental",
      headerTitle: "Cadastro - órgão Público",
      accessTitle: "Acesso - órgão Público",
      accessDescription: "Defina os dados de acesso do representante para seguir no fluxo de homologação.",
      icon: "fa-regular fa-building",
      theme: "public",
      profileFields: [
        {
          extraKey: "orgao_nome",
          label: "Nome do órgão / instituição",
          type: "text",
          placeholder: "Secretaria de Assistencia Social",
          required: true,
        },
        {
          key: "nome",
          label: "Nome do representante",
          type: "text",
          placeholder: "Ana Oliveira",
          required: true,
          autocomplete: "name",
        },
        {
          extraKey: "cargo",
          label: "Cargo",
          type: "text",
          placeholder: "Coordenadora",
          required: true,
        },
        {
          key: "email",
          label: "E-mail institucional",
          type: "email",
          placeholder: "contato@orgao.gov.br",
          required: true,
          autocomplete: "email",
        },
        {
          key: "telefone",
          label: "Telefone",
          type: "text",
          placeholder: "(00) 0000-0000",
          required: false,
          inputmode: "tel",
          autocomplete: "tel",
          mask: "phone",
        },
      ],
      accessFields: [
        {
          key: "login",
          label: "Usuário para login",
          type: "text",
          placeholder: "ana.oliveira",
          required: true,
          autocomplete: "username",
        },
        {
          key: "senha",
          label: "Senha",
          type: "password",
          placeholder: senhaPlaceholder,
          required: true,
          autocomplete: "new-password",
          toggle: true,
        },
        {
          key: "confirmarSenha",
          label: "Confirmar senha",
          type: "password",
          placeholder: "Repita a senha",
          required: true,
          autocomplete: "new-password",
          toggle: true,
        },
      ],
    },
  ];

  const isCurrentVariant = (variantKey) => currentType === variantKey;
  const getRootValue = (variantKey, key) => (isCurrentVariant(variantKey) ? String(currentFormData?.[key] || "") : "");
  const getExtraValue = (variantKey, key) => (isCurrentVariant(variantKey) ? String(currentExtraData?.[key] || "") : "");
  const isTruthyExtra = (variantKey, key) =>
    ["1", "true", "sim", "on", "yes"].includes(getExtraValue(variantKey, key).trim().toLowerCase());
%>

<section class="auth-viewport auth-viewport-cadastro">
  <div class="auth-bubble bubble-a"></div>
  <div class="auth-bubble bubble-b"></div>
  <div class="auth-bubble bubble-c"></div>
  <div class="auth-bubble bubble-d"></div>
  <div class="auth-bubble bubble-e"></div>

  <div
    class="cadastro-shell <%= currentType === 'voluntario' ? 'is-volunteer-active' : '' %>"
    data-cadastro-root
    data-active-type="<%= currentType %>"
    data-active-step="<%= currentPanel %>"
  >
    <header class="cadastro-hero">
      <div class="cadastro-hero-icon" aria-hidden="true">
        <i class="fa-regular fa-heart"></i>
      </div>
      <h1 class="cadastro-hero-title">Bem-vindo à nossa rede</h1>
      <p class="cadastro-hero-subtitle">Cada pessoa faz a diferença</p>

      <div class="cadastro-progress" aria-label="Progresso do cadastro" data-cadastro-progress <%= currentType === 'voluntario' ? 'hidden' : '' %>>
        <% for (let step = 1; step <= 3; step += 1) { %>
          <span
            class="cadastro-progress-item <%= currentProgressStep === step ? 'is-active' : '' %>"
            data-cadastro-progress-item
            data-step="<%= step %>"
          ></span>
        <% } %>
      </div>

      <div class="cadastro-hero-journey" data-cadastro-volunteer-journey <%= currentType === 'voluntario' ? '' : 'hidden' %>>
        <i class="fa-solid fa-route" aria-hidden="true"></i>
        <span>Cadastro guiado de voluntário em <%= volunteerWizardSteps.length %> etapas</span>
      </div>
    </header>

    <% if (errorMessage && errorMessage.length) { %>
      <div class="auth-error cadastro-flash"><%= errorMessage[0] %></div>
    <% } %>

    <% if (successMessage && successMessage.length) { %>
      <div class="auth-success cadastro-flash"><%= successMessage[0] %></div>
    <% } %>

    <div class="cadastro-flow">
      <section
        class="cadastro-card cadastro-choice-card card-elevated"
        data-cadastro-stage="escolha"
        <%= currentType ? "hidden" : "" %>
      >
        <header class="cadastro-card-head cadastro-card-head-plain">
          <div>
            <h2>Como você quer participar?</h2>
            <p>Escolha o perfil que melhor te representa</p>
          </div>
        </header>

        <div class="cadastro-choice-list">
          <% cadastroVariants.forEach((variant) => { %>
            <button
              type="button"
              class="cadastro-choice-option theme-<%= variant.theme %>"
              data-cadastro-select="<%= variant.key %>"
            >
              <span class="cadastro-choice-icon" aria-hidden="true">
                <i class="<%= variant.icon %>"></i>
              </span>
              <span class="cadastro-choice-copy">
                <strong><%= variant.label %></strong>
                <small><%= variant.selectDescription %></small>
              </span>
              <span class="cadastro-choice-arrow" aria-hidden="true">
                <i class="fa-solid fa-chevron-right"></i>
              </span>
            </button>
          <% }) %>
        </div>
      </section>

      <% cadastroVariants.forEach((variant) => { %>
        <% const showVariant = currentType === variant.key; %>
        <% const activeVariantPanel = showVariant ? currentPanel : variant.key === "voluntario" ? volunteerWizardSteps[0].key : "dados"; %>
        <form
          method="post"
          action="/cadastro"
          autocomplete="off"
          enctype="multipart/form-data"
          class="cadastro-form-shell <%= variant.key === 'voluntario' ? 'cadastro-form-shell-volunteer' : '' %>"
          data-cadastro-form
          data-cadastro-variant="<%= variant.key %>"
          data-cadastro-layout="<%= variant.key === 'voluntario' ? 'volunteer-wizard' : 'standard' %>"
          <%= showVariant ? "" : "hidden" %>
        >
          <%- renderCsrfField() %>
          <input type="hidden" name="tipoCadastro" value="<%= variant.key %>" />
          <input type="hidden" name="fluxoEtapa" value="<%= activeVariantPanel %>" data-cadastro-step-input />

          <% if (variant.key === "voluntario") { %>
            <section class="cadastro-volunteer-wizard card-elevated" data-cadastro-wizard-root>
              <header class="cadastro-wizard-hero">
                <div class="cadastro-wizard-hero-main">
                  <button
                    type="button"
                    class="cadastro-back-btn cadastro-wizard-choice-back"
                    data-cadastro-back="escolha"
                    aria-label="Voltar para escolher o perfil"
                  >
                    <i class="fa-solid fa-arrow-left"></i>
                  </button>

                  <div>
                    <span class="cadastro-wizard-eyebrow">Planejamento e cadastro do voluntário</span>
                    <h2>Formulário de planejamento das atividades</h2>
                    <p>
                      Seguimos o roteiro técnico enviado no documento para entender sua proposta de atividade,
                      organizar o cadastro e fechar tudo com acesso protegido e validação segura.
                    </p>
                  </div>
                </div>

                <div class="cadastro-wizard-meta">
                  <span class="cadastro-wizard-counter" data-cadastro-wizard-counter>
                    Etapa <%= currentVolunteerStepIndex + 1 %> de <%= volunteerWizardSteps.length %>
                  </span>
                  <strong class="cadastro-wizard-meta-title" data-cadastro-wizard-label>
                    <%= volunteerWizardSteps[currentVolunteerStepIndex].label %>
                  </strong>
                </div>
              </header>

              <nav class="cadastro-wizard-nav" aria-label="Etapas do cadastro do voluntário">
                <% volunteerWizardSteps.forEach((step, index) => { %>
                  <% const isCurrentStep = activeVariantPanel === step.key; %>
                  <% const isCompletedStep = index < currentVolunteerStepIndex; %>
                  <button
                    type="button"
                    class="cadastro-wizard-step <%= isCurrentStep ? 'is-current' : '' %> <%= isCompletedStep ? 'is-complete' : '' %>"
                    data-cadastro-wizard-step
                    data-step-index="<%= index %>"
                    data-step-key="<%= step.key %>"
                    aria-current="<%= isCurrentStep ? 'step' : 'false' %>"
                  >
                    <span class="cadastro-wizard-step-badge" aria-hidden="true">
                      <i class="<%= step.icon %>"></i>
                    </span>
                    <span class="cadastro-wizard-step-copy">
                      <strong><%= step.label %></strong>
                      <small><%= step.subtitle %></small>
                    </span>
                  </button>
                <% }) %>
              </nav>

              <div class="cadastro-wizard-progress" aria-hidden="true">
                <span
                  class="cadastro-wizard-progress-fill"
                  data-cadastro-wizard-progress-fill
                  style="width: <%= currentVolunteerProgress %>%"
                ></span>
              </div>

              <div class="cadastro-wizard-panels">
                <section
                  class="cadastro-wizard-panel <%= activeVariantPanel === 'profissional' ? 'is-current' : '' %>"
                  data-cadastro-wizard-panel
                  data-step-index="0"
                  data-step-key="profissional"
                  <%= activeVariantPanel === 'profissional' ? '' : 'hidden' %>
                >
                  <header class="cadastro-wizard-panel-head">
                    <span class="cadastro-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-user-tie"></i>
                    </span>
                    <div>
                      <h3>Identificação do profissional</h3>
                      <p>Começamos pelos dados básicos do profissional responsável pela proposta e pelo cadastro.</p>
                    </div>
                  </header>

                  <div class="cadastro-wizard-grid">
                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-nome">
                      <span class="input-label">Nome do profissional<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-nome"
                        name="nome"
                        type="text"
                        maxlength="140"
                        placeholder="Digite seu nome completo"
                        value="<%= getRootValue('voluntario', 'nome') %>"
                        autocomplete="name"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-funcao">
                      <span class="input-label">Função<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-funcao"
                        name="dadosCadastro_funcao"
                        type="text"
                        maxlength="120"
                        placeholder="Ex: Psicólogo, arte-educador, terapeuta ocupacional"
                        value="<%= getExtraValue('voluntario', 'funcao') %>"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-area">
                      <span class="input-label">Área de atuação<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-area"
                        name="dadosCadastro_area_atuacao"
                        type="text"
                        maxlength="160"
                        placeholder="Ex: Saúde mental, educação especial, inclusão, esporte"
                        value="<%= getExtraValue('voluntario', 'area_atuacao') %>"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-cpf">
                      <span class="input-label">CPF</span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-cpf"
                        name="cpf"
                        type="text"
                        maxlength="14"
                        placeholder="000.000.000-00"
                        value="<%= getRootValue('voluntario', 'cpf') %>"
                        inputmode="numeric"
                        data-mask="cpf"
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-data-nascimento">
                      <span class="input-label">Data de nascimento</span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-data-nascimento"
                        name="dadosCadastro_data_nascimento"
                        type="date"
                        value="<%= getExtraValue('voluntario', 'data_nascimento') %>"
                      />
                    </label>
                  </div>
                </section>
                <section
                  class="cadastro-wizard-panel <%= activeVariantPanel === 'atividade' ? 'is-current' : '' %>"
                  data-cadastro-wizard-panel
                  data-step-index="1"
                  data-step-key="atividade"
                  <%= activeVariantPanel === 'atividade' ? '' : 'hidden' %>
                >
                  <header class="cadastro-wizard-panel-head">
                    <span class="cadastro-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-clipboard-list"></i>
                    </span>
                    <div>
                      <h3>Identificação da atividade</h3>
                      <p>Descreva com clareza a atividade que será proposta e o que será realizado na prática.</p>
                    </div>
                  </header>

                  <div class="cadastro-wizard-grid">
                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-nome-atividade">
                      <span class="input-label">Nome da atividade<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-nome-atividade"
                        name="dadosCadastro_nome_atividade"
                        type="text"
                        maxlength="180"
                        placeholder="Ex: Oficina de Arte Terapia"
                        value="<%= getExtraValue('voluntario', 'nome_atividade') %>"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-descricao-atividade">
                      <span class="input-label">Descrição da atividade (o que será realizado)<span class="cadastro-required">*</span></span>
                      <textarea
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-descricao-atividade"
                        name="dadosCadastro_descricao_atividade"
                        rows="5"
                        maxlength="1200"
                        placeholder="Descreva detalhadamente o que será realizado com os participantes."
                        required
                      ><%= getExtraValue('voluntario', 'descricao_atividade') %></textarea>
                    </label>
                  </div>
                </section>

                <section
                  class="cadastro-wizard-panel <%= activeVariantPanel === 'objetivo' ? 'is-current' : '' %>"
                  data-cadastro-wizard-panel
                  data-step-index="2"
                  data-step-key="objetivo"
                  <%= activeVariantPanel === 'objetivo' ? '' : 'hidden' %>
                >
                  <header class="cadastro-wizard-panel-head">
                    <span class="cadastro-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-bullseye"></i>
                    </span>
                    <div>
                      <h3>Objetivo</h3>
                      <p>Mostre o propósito central da proposta e os resultados específicos que você espera alcançar.</p>
                    </div>
                  </header>

                  <div class="cadastro-wizard-grid">
                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-objetivo-geral">
                      <span class="input-label">Objetivo geral da atividade<span class="cadastro-required">*</span></span>
                      <textarea
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-objetivo-geral"
                        name="dadosCadastro_objetivo_geral"
                        rows="4"
                        maxlength="900"
                        placeholder="Qual é o objetivo principal dessa atividade?"
                        required
                      ><%= getExtraValue('voluntario', 'objetivo_geral') %></textarea>
                    </label>

                    <label class="field-wrap cadastro-field span-2" for="cadastro-voluntario-objetivos-especificos">
                      <span class="input-label">Objetivos específicos (se houver)</span>
                      <textarea
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-objetivos-especificos"
                        name="dadosCadastro_objetivos_especificos"
                        rows="4"
                        maxlength="900"
                        placeholder="Liste os objetivos específicos que complementam a proposta."
                      ><%= getExtraValue('voluntario', 'objetivos_especificos') %></textarea>
                    </label>
                  </div>
                </section>

                <section
                  class="cadastro-wizard-panel <%= activeVariantPanel === 'publico' ? 'is-current' : '' %>"
                  data-cadastro-wizard-panel
                  data-step-index="3"
                  data-step-key="publico"
                  <%= activeVariantPanel === 'publico' ? '' : 'hidden' %>
                >
                  <header class="cadastro-wizard-panel-head">
                    <span class="cadastro-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-people-group"></i>
                    </span>
                    <div>
                      <h3>Público-alvo</h3>
                      <p>Explique para quem a atividade é pensada e qual será o perfil das pessoas atendidas.</p>
                    </div>
                  </header>

                  <div class="cadastro-wizard-grid">
                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-faixa-etaria">
                      <span class="input-label">Faixa etária<span class="cadastro-required">*</span></span>
                      <input
                        class="input-control cadastro-input"
                        id="cadastro-voluntario-faixa-etaria"
                        name="dadosCadastro_faixa_etaria"
                        type="text"
                        maxlength="120"
                        placeholder="Ex: 6 a 12 anos"
                        value="<%= getExtraValue('voluntario', 'faixa_etaria') %>"
                        required
                      />
                    </label>

                    <label class="field-wrap cadastro-field" for="cadastro-voluntario-participantes-turma">
                      <span class="input-label">Número estimado de participantes por turma<span class="cadastro-required">*</span></span>
                      <input
