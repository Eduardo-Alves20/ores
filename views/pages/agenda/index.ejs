<section class="page-shell agenda-layout" data-page="agenda">
  <header class="agenda-header">
    <div>
      <h2>Agenda de Atendimentos</h2>
      <p>Gerencie visitas, compromissos e retornos com fluxo dinâmico por perfil.</p>
    </div>
    <div class="agenda-toolbar">
      <label class="field-wrap">
        <span class="input-label">Profissional</span>
        <select id="agenda-responsavel-filtro" class="input-control"></select>
      </label>
      <button type="button" class="btn btn-muted" id="agenda-hoje-btn">Hoje</button>
      <%# Disponibilidade do medico/profissional desativada temporariamente. Bloco preservado para rollback. %>
      <% if (false && agendaConfig?.permissions?.canManageAvailability) { %>
        <button type="button" class="btn btn-muted" id="agenda-disponibilidade-btn">Minha Disponibilidade</button>
      <% } %>
      <% if (agendaConfig?.permissions?.canManageRooms) { %>
        <button type="button" class="btn btn-muted" id="agenda-salas-btn">Salas</button>
      <% } %>
    </div>
  </header>

  <section class="agenda-presenca-overview card-elevated">
    <header class="agenda-presenca-overview-head">
      <div>
        <p class="agenda-day-overline">Presença da Semana</p>
        <h3 id="agenda-presenca-semana-titulo">Carregando semana...</h3>
      </div>
      <div class="agenda-presenca-kpis" id="agenda-presenca-kpis">
        <span class="agenda-presenca-kpi is-total">0 agendados</span>
        <span class="agenda-presenca-kpi is-presente">0 presentes</span>
        <span class="agenda-presenca-kpi is-falta">0 faltas</span>
        <span class="agenda-presenca-kpi is-pendente">0 pendentes</span>
      </div>
    </header>

    <div class="agenda-presenca-week-grid" id="agenda-presenca-semana-lista">
      <p class="empty-hint">Carregando resumo semanal...</p>
    </div>
  </section>

  <section class="agenda-board card-elevated">
    <section class="agenda-calendar-panel">
      <header class="agenda-calendar-head">
        <div class="agenda-month-picker-wrap" id="agenda-mes-picker-wrap">
          <button
            type="button"
            class="agenda-month-picker-toggle"
            id="agenda-mes-picker-toggle"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="agenda-mes-picker-popover"
          >
            <h3 id="agenda-mes-titulo">Calendário</h3>
            <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
          </button>

          <div class="agenda-month-picker-popover card-elevated" id="agenda-mes-picker-popover" hidden>
            <label class="field-wrap">
              <span class="input-label">Mês</span>
              <select class="input-control" id="agenda-mes-picker-mes"></select>
            </label>

            <label class="field-wrap">
              <span class="input-label">Ano</span>
              <select class="input-control" id="agenda-mes-picker-ano"></select>
            </label>

            <div class="agenda-month-picker-actions">
              <button type="button" class="btn btn-muted" id="agenda-mes-picker-cancelar">Cancelar</button>
              <button type="button" class="btn btn-primary" id="agenda-mes-picker-aplicar">Ir</button>
            </div>
          </div>
        </div>
        <div class="agenda-calendar-actions">
          <button type="button" class="btn btn-muted" id="agenda-mes-prev" aria-label="Mês anterior">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button type="button" class="btn btn-muted" id="agenda-mes-next" aria-label="Próximo mês">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        </div>
      </header>

      <div class="agenda-weekdays">
        <span>Dom</span>
        <span>Seg</span>
        <span>Ter</span>
        <span>Qua</span>
        <span>Qui</span>
        <span>Sex</span>
        <span>Sáb</span>
      </div>

      <section class="agenda-status-legend" aria-label="Legenda de status da agenda">
        <span class="agenda-status-legend-item is-agendado">Agendado</span>
        <span class="agenda-status-legend-item is-presente">Presente</span>
        <span class="agenda-status-legend-item is-falta">Falta</span>
        <span class="agenda-status-legend-item is-falta-justificada">Falta justificada</span>
        <span class="agenda-status-legend-item is-pendente">Pendente</span>
        <span class="agenda-status-legend-item is-cancelado">Cancelado</span>
      </section>

      <div class="agenda-calendar-grid" id="agenda-calendar-grid"></div>
    </section>

    <aside class="agenda-day-panel">
      <header class="agenda-day-head">
        <div>
          <p class="agenda-day-overline">Eventos do Dia</p>
          <h3 id="agenda-dia-titulo">-</h3>
        </div>
        <% if (agendaConfig?.permissions?.canCreate) { %>
          <button type="button" class="btn btn-primary" id="agenda-novo-btn">Novo Agendamento</button>
        <% } else { %>
          <span class="badge-soft">Modo visualizacao</span>
        <% } %>
      </header>

      <div class="agenda-day-list" id="agenda-dia-lista">
        <p class="empty-hint">Carregando agenda...</p>
      </div>
    </aside>
  </section>
</section>

<div class="agenda-modal-backdrop" id="agenda-modal-backdrop" hidden>
  <section class="agenda-modal agenda-scheduling-modal card-elevated" role="dialog" aria-modal="true" aria-labelledby="agenda-modal-title">
    <header class="agenda-modal-head">
      <h3 id="agenda-modal-title">Novo Agendamento</h3>
      <button type="button" class="btn btn-muted agenda-modal-close-btn" id="agenda-modal-close" aria-label="Fechar modal de agendamento">
        <i class="fa-solid fa-xmark"></i>
        <span>Fechar</span>
      </button>
    </header>

    <div class="agenda-modal-steps" id="agenda-modal-steps" aria-hidden="true">
      <div class="agenda-step-item is-active" data-step-item="1">
        <span class="agenda-step-dot" data-step-dot="1">1</span>
        <span class="agenda-step-label">Tipo</span>
      </div>
      <span class="agenda-step-line" data-step-line></span>
      <div class="agenda-step-item" data-step-item="2">
        <span class="agenda-step-dot" data-step-dot="2">2</span>
        <span class="agenda-step-label">Detalhes</span>
      </div>
    </div>

    <form id="agenda-form" class="agenda-form agenda-form-wizard">
      <div class="agenda-form-feedback" id="agenda-form-feedback" role="alert" aria-live="polite" hidden></div>
      <section class="agenda-form-step" id="agenda-form-step-1">
        <p class="agenda-step-question">Qual o tipo de agendamento?</p>
        <div class="agenda-type-grid" id="agenda-type-grid" role="group" aria-label="Tipos de agendamento"></div>
      </section>

      <section class="agenda-form-step" id="agenda-form-step-2" hidden>
        <div class="agenda-type-summary-chip" id="agenda-type-summary">
          <span class="agenda-type-summary-icon" id="agenda-type-summary-icon">
            <i class="fa-solid fa-calendar-check"></i>
          </span>
          <span id="agenda-type-summary-label">Tipo</span>
        </div>

        <div class="agenda-form-grid">
          <label class="field-wrap span-2" data-agenda-field="titulo">
            <span class="input-label">Titulo *</span>
            <input class="input-control" type="text" name="titulo" required maxlength="140" />
            <small class="agenda-field-feedback" id="agenda-feedback-titulo" hidden></small>
          </label>

          <label class="field-wrap" data-agenda-field="data">
            <span class="input-label">Data *</span>
            <input class="input-control" type="date" name="data" required />
            <small class="agenda-field-feedback" id="agenda-feedback-data" hidden></small>
          </label>

          <label class="field-wrap" data-agenda-field="hora">
            <span class="input-label">Hora *</span>
            <input class="input-control" type="time" name="hora" required />
            <small class="agenda-field-feedback" id="agenda-feedback-hora" hidden></small>
          </label>

          <label class="field-wrap span-2 agenda-type-select-hidden" id="agenda-tipo-select-wrap" hidden>
            <span class="input-label">Tipo de atendimento</span>
            <select class="input-control" name="tipoAtendimento" id="agenda-tipo-select"></select>
          </label>

          <label class="field-wrap" data-agenda-field="responsavel">
            <span class="input-label">Responsavel</span>
            <select class="input-control" name="responsavelId" id="agenda-responsavel-select"></select>
          </label>

          <label class="field-wrap" data-agenda-field="sala">
            <span class="input-label" id="agenda-sala-label">Sala de atendimento</span>
            <select class="input-control" name="salaId" id="agenda-sala-select">
              <option value="">Carregando salas...</option>
            </select>
            <small class="agenda-field-feedback" id="agenda-feedback-sala" hidden></small>
          </label>

          <div class="agenda-room-hint span-2" id="agenda-sala-hint" data-agenda-field="sala_hint">
            As salas livres para este horario aparecem automaticamente aqui.
          </div>

          <label class="field-wrap span-2" data-agenda-field="familia_busca">
            <span class="input-label">Buscar familia</span>
            <input class="input-control" type="search" name="familiaBusca" id="agenda-familia-busca" placeholder="Nome do responsavel, telefone..." />
          </label>

          <label class="field-wrap" data-agenda-field="familia">
            <span class="input-label">Familia</span>
            <select class="input-control" name="familiaId" id="agenda-familia-select">
              <option value="">Sem familia vinculada</option>
            </select>
          </label>

          <label class="field-wrap" data-agenda-field="paciente">
            <span class="input-label">Paciente</span>
            <select class="input-control" name="pacienteId" id="agenda-paciente-select">
              <option value="">Sem paciente especifico</option>
            </select>
          </label>

          <label class="field-wrap span-2" data-agenda-field="local">
            <span class="input-label">Local / Endereco</span>
            <input class="input-control" type="text" name="local" maxlength="240" />
          </label>

          <label class="field-wrap span-2" data-agenda-field="observacoes">
            <span class="input-label">Observacoes</span>
            <textarea class="input-control textarea-control" name="observacoes" rows="4" maxlength="3000"></textarea>
          </label>
        </div>

        <p class="agenda-form-hint">
          Dica: voce pode arrastar no painel da direita ou arrastar o dia (quando houver 1 evento) para soltar em outra data no calendario.
        </p>
        <p class="agenda-save-hint">As alteracoes so sao aplicadas quando voce clicar em "Salvar Agendamento".</p>
      </section>

      <div class="agenda-form-actions agenda-form-actions-wizard">
        <button type="button" class="btn btn-muted" id="agenda-form-cancel">Cancelar</button>
        <button type="button" class="btn btn-muted" id="agenda-step-back" hidden>
          <i class="fa-solid fa-arrow-left"></i>
          <span>Voltar</span>
        </button>
        <button type="button" class="btn btn-primary" id="agenda-step-next">Continuar</button>
        <button type="submit" class="btn btn-primary" id="agenda-form-submit" hidden>Salvar Agendamento</button>
      </div>

      <p class="agenda-form-hint agenda-wizard-hint" id="agenda-step-hint-1">
        Dica: voce pode arrastar os eventos no calendario para reagendar.
      </p>
      <p class="agenda-form-hint agenda-wizard-hint" id="agenda-step-hint-2" hidden>
        Revise os dados antes de salvar.
      </p>
    </form>
  </section>
</div>

<div class="agenda-modal-backdrop" id="agenda-presenca-backdrop" hidden>
  <section class="agenda-modal agenda-presenca-modal card-elevated" role="dialog" aria-modal="true" aria-labelledby="agenda-presenca-title">
    <header class="agenda-modal-head">
      <div>
        <h3 id="agenda-presenca-title">Registrar Presença</h3>
        <p class="agenda-modal-subtitle" id="agenda-presenca-subtitle">Carregando detalhes do agendamento...</p>
      </div>
      <button type="button" class="btn btn-muted agenda-modal-close-btn" id="agenda-presenca-close" aria-label="Fechar modal de presença">
        <i class="fa-solid fa-xmark"></i>
        <span>Fechar</span>
      </button>
    </header>

    <div class="agenda-presenca-shell">
      <section class="agenda-presenca-status-box">
        <p class="agenda-presenca-label">Status atual</p>
        <div class="agenda-presenca-badges">
          <span class="status-badge status-neutral" id="agenda-presenca-status-agendamento">Agendado</span>
          <span class="status-badge status-neutral" id="agenda-presenca-status-presenca">Pendente</span>
        </div>
      </section>

      <label class="field-wrap">
        <span class="input-label">Justificativa oficial</span>
        <select class="input-control" id="agenda-presenca-justificativa">
          <option value="">Sem justificativa oficial</option>
          <% (agendaConfig?.attendanceJustifications || []).forEach((item) => { %>
            <option value="<%= item.nome %>"><%= item.nome %></option>
          <% }) %>
        </select>
      </label>

      <label class="field-wrap">
        <span class="input-label">Observação interna</span>
        <textarea class="input-control textarea-control" id="agenda-presenca-observacao" rows="4" maxlength="1000" placeholder="Opcional. Ex.: família avisou atraso, atendimento realizado normalmente, falta justificada..."></textarea>
      </label>

      <% if (agendaConfig?.permissions?.canRegisterAttendance) { %>
        <div class="agenda-presenca-actions">
          <button type="button" class="btn btn-primary" data-agenda-presenca-action="presente">Marcar Presente</button>
          <button type="button" class="btn btn-warning" data-agenda-presenca-action="falta">Marcar Falta</button>
          <button type="button" class="btn btn-muted" data-agenda-presenca-action="falta_justificada">Falta Justificada</button>
          <button type="button" class="btn btn-muted" data-agenda-presenca-action="pendente">Voltar para Pendente</button>
        </div>
        <p class="agenda-save-hint">O status é salvo no momento em que você clica em um dos botões acima.</p>
      <% } else { %>
        <p class="agenda-form-hint">Modo visualizacao. Somente perfis autorizados registram presença.</p>
      <% } %>

      <section class="agenda-presenca-history">
        <header class="agenda-presenca-history-head">
          <h4>Histórico do agendamento</h4>
        </header>
        <div class="agenda-presenca-history-list" id="agenda-presenca-history-list" aria-live="polite">
          <p class="empty-hint">Nenhum histórico carregado.</p>
        </div>
      </section>
    </div>
  </section>
</div>

<script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> id="agenda-presenca-justificativas" type="application/json"><%- serializeForInlineScript(agendaConfig?.attendanceJustifications || []) %></script>

<%# Modal de disponibilidade desativada temporariamente para medico/profissional. Bloco preservado para rollback. %>
<% if (false && agendaConfig?.permissions?.canManageAvailability) { %>
  <div class="agenda-modal-backdrop" id="agenda-disponibilidade-backdrop" hidden>
    <section class="agenda-modal agenda-availability-modal card-elevated" role="dialog" aria-modal="true" aria-labelledby="agenda-disponibilidade-title">
      <header class="agenda-modal-head">
        <div>
          <h3 id="agenda-disponibilidade-title">Minha disponibilidade</h3>
          <p class="agenda-modal-subtitle">Defina os dias e horarios em que voce atende para o portal da familia mostrar apenas janelas livres.</p>
        </div>
        <button type="button" class="btn btn-muted agenda-modal-close-btn" id="agenda-disponibilidade-close" aria-label="Fechar modal de disponibilidade">
          <i class="fa-solid fa-xmark"></i>
          <span>Fechar</span>
        </button>
      </header>

      <div class="agenda-presenca-shell agenda-availability-shell">
        <div class="agenda-availability-status">
          <label class="agenda-availability-toggle">
            <input type="checkbox" id="agenda-disponibilidade-ativo" />
            <span>Disponibilizar meus horarios para agendamento da familia</span>
          </label>
          <p class="agenda-form-hint">Cada linha ativa libera horarios de 30 em 30 minutos dentro da faixa informada.</p>
        </div>

        <div class="agenda-availability-grid" id="agenda-disponibilidade-grid">
          <% [
            { value: 1, label: "Segunda-feira" },
            { value: 2, label: "Terca-feira" },
            { value: 3, label: "Quarta-feira" },
            { value: 4, label: "Quinta-feira" },
            { value: 5, label: "Sexta-feira" },
            { value: 6, label: "Sabado" },
            { value: 0, label: "Domingo" },
          ].forEach((day) => { %>
            <article class="agenda-availability-day-card" data-availability-day-card data-dia-semana="<%= day.value %>">
              <label class="agenda-availability-day-head">
                <input type="checkbox" data-availability-enabled />
                <span><%= day.label %></span>
              </label>

              <div class="agenda-availability-time-row">
                <label class="field-wrap">
                  <span class="input-label">Inicio</span>
                  <input class="input-control" type="time" data-availability-start value="08:00" />
                </label>

                <label class="field-wrap">
                  <span class="input-label">Fim</span>
                  <input class="input-control" type="time" data-availability-end value="12:00" />
                </label>
              </div>
            </article>
          <% }) %>
        </div>

        <div class="agenda-form-actions">
          <button type="button" class="btn btn-muted" id="agenda-disponibilidade-cancel">Cancelar</button>
          <button type="button" class="btn btn-primary" id="agenda-disponibilidade-submit">Salvar disponibilidade</button>
        </div>
        <p class="agenda-save-hint">A disponibilidade só é atualizada ao clicar em "Salvar disponibilidade".</p>
      </div>
    </section>
  </div>
<% } %>

<div class="agenda-modal-backdrop" id="agenda-salas-backdrop" hidden>
  <section class="agenda-modal agenda-salas-modal card-elevated" role="dialog" aria-modal="true" aria-labelledby="agenda-salas-title">
    <header class="agenda-modal-head">
      <div>
        <h3 id="agenda-salas-title">Salas de Atendimento</h3>
        <p class="agenda-modal-subtitle">Cadastre e organize as salas disponiveis para a agenda.</p>
      </div>
      <button type="button" class="btn btn-muted agenda-modal-close-btn" id="agenda-salas-close" aria-label="Fechar modal de salas">
        <i class="fa-solid fa-xmark"></i>
        <span>Fechar</span>
      </button>
    </header>

    <div class="agenda-salas-shell">
      <form id="agenda-sala-form" class="agenda-sala-form">
        <input type="hidden" name="salaId" value="" />

        <label class="field-wrap">
          <span class="input-label">Nome da sala *</span>
          <input class="input-control" type="text" name="nome" maxlength="120" required />
        </label>

        <label class="field-wrap">
          <span class="input-label">Descricao</span>
          <input class="input-control" type="text" name="descricao" maxlength="240" />
        </label>

        <div class="agenda-sala-form-actions">
          <button type="button" class="btn btn-muted" id="agenda-sala-reset">Nova sala</button>
          <button type="submit" class="btn btn-primary" id="agenda-sala-submit">Salvar sala</button>
        </div>
        <p class="agenda-save-hint">Clique em "Salvar sala" para gravar as alterações.</p>
      </form>

      <div class="agenda-salas-list" id="agenda-salas-lista">
        <p class="empty-hint">Carregando salas...</p>
      </div>
    </div>
  </section>
</div>

<script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> id="agenda-config" type="application/json"><%- serializeForInlineScript(agendaConfig || {}) %></script>


