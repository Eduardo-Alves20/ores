<section class="page-shell familias-layout" data-page="familia-detalhe" data-familia-id="<%= familia._id %>">
  <nav class="familias-breadcrumb" aria-label="Trilha de navegacao">
    <a class="familias-breadcrumb-link" href="/painel">Painel</a>
    <span class="familias-breadcrumb-sep" aria-hidden="true">/</span>
    <a class="familias-breadcrumb-link" href="/familias">Assistidos</a>
    <span class="familias-breadcrumb-sep" aria-hidden="true">/</span>
    <span class="familias-breadcrumb-current"><%= familia?.responsavel?.nome || "Familia" %></span>
    <span class="familias-breadcrumb-sep" aria-hidden="true" id="familia-breadcrumb-dependente-sep" hidden>/</span>
    <span class="familias-breadcrumb-current" id="familia-breadcrumb-dependente" hidden>Dependente</span>
  </nav>

  <header class="familias-header familias-hero familias-hero-detail card-elevated">
    <div class="familias-hero-main">
      <p class="familias-overline">Prontuario familiar</p>
      <h1 class="familias-title"><%= familia?.responsavel?.nome || "Familia" %></h1>
      <p class="familias-subtitle">
        <%= familia?.responsavel?.telefone || "Sem telefone" %>
        <% if (familia?.responsavel?.parentesco) { %>
          | <%= familia.responsavel.parentesco %>
        <% } %>
      </p>

      <div class="familias-hero-tags">
        <span class="familias-hero-tag <%= familia?.ativo ? 'is-success' : 'is-neutral' %>" id="familia-status-pill">
          <%= familia?.ativo ? "Familia ativa" : "Familia inativa" %>
        </span>
        <span class="familias-hero-tag" id="familia-pacientes-pill">0 dependentes</span>
        <span class="familias-hero-tag" id="familia-atendimentos-pill">0 atendimentos</span>
        <span class="familias-hero-tag" id="familia-presencas-pill">0 consultas agenda</span>
      </div>
    </div>
    <div class="familias-header-actions">
      <a href="/familias" class="btn btn-muted">Voltar</a>
      <% if (viewFlags?.canEditFamily) { %>
        <a href="/familias/<%= familia._id %>/editar" class="btn btn-primary">Editar Família</a>
      <% } %>
    </div>
  </header>

  <nav class="family-record-tabs" aria-label="Secoes da ficha familiar">
    <button
      type="button"
      class="family-record-tab is-active"
      data-record-tab="overview"
      role="tab"
      aria-selected="true"
      aria-controls="family-record-overview"
    >
      <i class="fa-solid fa-id-card-clip" aria-hidden="true"></i>
      <span>Dados gerais</span>
    </button>
    <button
      type="button"
      class="family-record-tab"
      data-record-tab="dependentes"
      role="tab"
      aria-selected="false"
      aria-controls="family-record-workflow"
    >
      <i class="fa-solid fa-people-group" aria-hidden="true"></i>
      <span>Dependentes</span>
    </button>
    <button
      type="button"
      class="family-record-tab"
      data-record-tab="historico"
      role="tab"
      aria-selected="false"
      aria-controls="family-record-workflow"
    >
      <i class="fa-solid fa-notes-medical" aria-hidden="true"></i>
      <span>Historico</span>
    </button>
    <button
      type="button"
      class="family-record-tab"
      data-record-tab="presencas"
      role="tab"
      aria-selected="false"
      aria-controls="family-record-workflow"
    >
      <i class="fa-solid fa-user-check" aria-hidden="true"></i>
      <span>Presencas</span>
    </button>
  </nav>

  <section class="familia-resumo card-elevated" id="family-record-overview">
    <div class="familia-resumo-head">
      <div>
        <p class="familias-overline">Visão geral</p>
        <h2 class="section-title">Resumo da família</h2>
      </div>
      <span class="badge-soft">Ficha social centralizada</span>
    </div>

    <div class="resumo-grid">
      <article class="resumo-item">
        <h2>Contato</h2>
        <p><strong>Nome:</strong> <span id="resumo-nome"><%= familia?.responsavel?.nome || "-" %></span></p>
        <p><strong>Telefone:</strong> <span id="resumo-telefone"><%= familia?.responsavel?.telefone || "-" %></span></p>
        <p><strong>Email:</strong> <span id="resumo-email"><%= familia?.responsavel?.email || "-" %></span></p>
      </article>
      <article class="resumo-item">
        <h2>Endereço</h2>
        <p id="resumo-endereco">
          <%= [familia?.endereco?.rua, familia?.endereco?.numero, familia?.endereco?.bairro, familia?.endereco?.cidade, familia?.endereco?.estado].filter(Boolean).join(", ") || "-" %>
        </p>
      </article>
      <article class="resumo-item">
        <h2>Status</h2>
        <p><span class="status-badge <%= familia?.ativo ? 'status-active' : 'status-inactive' %>" id="resumo-status"><%= familia?.ativo ? "Ativa" : "Inativa" %></span></p>
        <% if (viewFlags?.canToggleFamilyStatus) { %>
          <button class="btn btn-muted" id="familia-toggle-status" type="button">
            <%= familia?.ativo ? "Inativar Familia" : "Reativar Familia" %>
          </button>
        <% } else { %>
          <small class="section-subtitle">Somente administração pode alterar o status da família.</small>
        <% } %>
      </article>
    </div>
    <p class="observacao-livre"><strong>Observações:</strong> <span id="resumo-observacoes"><%= familia?.observacoes || "-" %></span></p>
  </section>

  <section class="detail-workflow card-elevated" id="family-record-workflow" hidden>
    <header class="workflow-toolbar">
      <div>
        <h2 class="section-title" id="workflow-title">Ficha de Dependentes</h2>
        <p class="section-subtitle" id="workflow-subtitle">Gestão dos dependentes vinculados a esta família.</p>
      </div>
      <div class="workflow-actions-top">
        <button type="button" class="btn btn-muted" id="workflow-back-btn" hidden>Voltar</button>
        <button type="button" class="btn btn-primary workflow-main-btn" id="workflow-main-btn">Histórico de atendimento</button>
      </div>
    </header>

    <nav class="workflow-tabs" aria-label="Navegacao da ficha">
      <button type="button" class="workflow-tab is-active" data-workflow-tab="pacientes">
        <i class="fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Dependentes</span>
      </button>
      <button type="button" class="workflow-tab" data-workflow-tab="historico">
        <i class="fa-solid fa-notes-medical" aria-hidden="true"></i>
        <span>Histórico de atendimento</span>
      </button>
      <button type="button" class="workflow-tab" data-workflow-tab="presencas">
        <i class="fa-solid fa-user-check" aria-hidden="true"></i>
        <span>Presenças</span>
      </button>
    </nav>

    <div class="workflow-panels">
      <section id="panel-pacientes" class="workflow-panel is-active">
        <div class="listagem-head">
          <h3 class="section-title panel-title">Dependentes da Família</h3>
          <span class="badge-soft" id="pacientes-count">0</span>
        </div>
        <div id="pacientes-lista" class="stack-list"></div>
        <% if (viewFlags?.canCreatePatient) { %>
          <div class="panel-actions">
            <button type="button" class="btn btn-primary" id="paciente-novo-btn">Registrar Dependente</button>
          </div>
        <% } else { %>
          <div class="panel-actions">
            <small class="section-subtitle">Perfil em modo visualizacao. Somente administração registra ou altera dependentes.</small>
          </div>
        <% } %>

        <form id="paciente-form" class="form-stack panel-inline-form" hidden>
          <h3 class="section-title panel-title">Novo Dependente</h3>
          <label class="field-wrap">
            <span class="input-label">Nome *</span>
            <input class="input-control" type="text" name="nome" required />
          </label>
          <label class="field-wrap">
            <span class="input-label">Data de nascimento</span>
            <input class="input-control" type="date" name="dataNascimento" />
          </label>
          <label class="field-wrap">
            <span class="input-label">Tipo de deficiencia</span>
            <select class="input-control" name="tipoDeficiencia">
              <option value="fisica">fisica</option>
              <option value="intelectual">intelectual</option>
              <option value="auditiva">auditiva</option>
              <option value="visual">visual</option>
              <option value="multipla">multipla</option>
              <option value="transtorno_espectro_autista">transtorno_espectro_autista</option>
              <option value="outra" selected>outra</option>
            </select>
          </label>
          <label class="field-wrap">
            <span class="input-label">Necessidades de apoio</span>
            <textarea class="input-control textarea-control" name="necessidadesApoio" rows="4"></textarea>
          </label>
          <div class="panel-actions">
            <button type="button" class="btn btn-muted" id="paciente-cancelar-btn">Cancelar</button>
            <button class="btn btn-primary" type="submit">Adicionar Dependente</button>
          </div>
        </form>
      </section>

      <section id="panel-dependente" class="workflow-panel" hidden>
        <div class="listagem-head">
          <h3 class="section-title panel-title">Ficha do Dependente</h3>
          <% if (viewFlags?.canEditPatient) { %>
            <div class="panel-head-actions">
              <button type="button" class="btn btn-muted" id="dependente-editar-btn">
                <i class="fa-solid fa-pen-to-square"></i>
                Editar
              </button>
            </div>
          <% } %>
        </div>

        <div id="dependente-detalhe" class="stack-card">
          <p class="empty-hint">Selecione um dependente para visualizar a ficha.</p>
        </div>

        <form id="dependente-form" class="form-stack panel-inline-form" hidden>
          <h3 class="section-title panel-title">Editar Dependente</h3>
          <label class="field-wrap">
            <span class="input-label">Nome *</span>
            <input class="input-control" type="text" name="nome" required />
          </label>
          <label class="field-wrap">
            <span class="input-label">Data de nascimento</span>
            <input class="input-control" type="date" name="dataNascimento" />
          </label>
          <label class="field-wrap">
            <span class="input-label">Tipo de deficiencia</span>
            <select class="input-control" name="tipoDeficiencia">
              <option value="fisica">fisica</option>
              <option value="intelectual">intelectual</option>
              <option value="auditiva">auditiva</option>
              <option value="visual">visual</option>
              <option value="multipla">multipla</option>
              <option value="transtorno_espectro_autista">transtorno_espectro_autista</option>
              <option value="outra">outra</option>
            </select>
          </label>
          <label class="field-wrap">
            <span class="input-label">Necessidades de apoio</span>
            <textarea class="input-control textarea-control" name="necessidadesApoio" rows="4"></textarea>
          </label>
          <label class="field-wrap">
            <span class="input-label">Observações</span>
            <textarea class="input-control textarea-control" name="observacoes" rows="3"></textarea>
          </label>
          <label class="field-wrap">
            <span class="input-label">Diagnostico / laudo (resumo)</span>
            <textarea class="input-control textarea-control" name="diagnosticoResumo" rows="3"></textarea>
          </label>
          <div class="panel-actions">
            <button type="button" class="btn btn-muted" id="dependente-cancelar-btn">Cancelar</button>
            <button class="btn btn-primary" type="submit">Salvar Alteracoes</button>
          </div>
        </form>
      </section>

      <section id="panel-historico" class="workflow-panel" hidden>
        <section class="historico-spotlight">
          <div class="historico-spotlight-copy">
            <p class="familias-overline">Registro social</p>
            <h3><%= viewFlags?.canCreateAttendance ? "Registrar atendimento sem perder o contexto" : "Consultar historico sem alterar registros" %></h3>
            <p><%= viewFlags?.canCreateAttendance ? "Salve resumo, proximos passos e o voluntario atendido direto da linha do tempo da familia." : "Acompanhe o historico da familia em modo de leitura, sem alterar registros existentes." %></p>
          </div>
          <% if (viewFlags?.canCreateAttendance) { %>
            <button type="button" class="btn btn-primary historico-spotlight-btn" id="historico-registrar-btn">Registrar Atendimento</button>
          <% } %>
        </section>

        <div class="listagem-head">
          <h3 class="section-title panel-title">Histórico de Atendimentos</h3>
          <span class="badge-soft" id="atendimentos-count">0</span>
        </div>
        <div id="atendimentos-lista" class="timeline-list consulta-cards-list"></div>
      </section>

      <section id="panel-presencas" class="workflow-panel" hidden>
        <section class="presenca-familiar-hero">
          <div class="presenca-familiar-copy">
            <p class="familias-overline">Controle de comparecimento</p>
            <h3>Consultas, faltas e justificativas desta família</h3>
            <p>Veja rapidamente quem compareceu, onde houve falta e quais consultas tiveram justificativa registrada.</p>
          </div>
        </section>

        <div class="presenca-resumo-grid" id="presencas-resumo">
          <article class="presenca-resumo-card is-total is-active" data-presenca-filter="all" role="button" tabindex="0" aria-label="Mostrar todas as consultas">
            <span>Consultas</span>
            <strong>0</strong>
          </article>
          <article class="presenca-resumo-card is-presente" data-presenca-filter="presente" role="button" tabindex="0" aria-label="Mostrar consultas com presença">
            <span>Presentes</span>
            <strong>0</strong>
          </article>
          <article class="presenca-resumo-card is-falta" data-presenca-filter="falta" role="button" tabindex="0" aria-label="Mostrar consultas com falta">
            <span>Faltas</span>
            <strong>0</strong>
          </article>
          <article class="presenca-resumo-card is-justificada" data-presenca-filter="falta_justificada" role="button" tabindex="0" aria-label="Mostrar consultas com falta justificada">
            <span>Justificadas</span>
            <strong>0</strong>
          </article>
          <article class="presenca-resumo-card is-pendente" data-presenca-filter="pendentes_canceladas" role="button" tabindex="0" aria-label="Mostrar consultas pendentes ou canceladas">
            <span>Pendentes</span>
            <strong>0</strong>
          </article>
        </div>

        <div class="listagem-head">
          <div>
            <h3 class="section-title panel-title">Linha do tempo das consultas</h3>
            <p class="section-subtitle" id="presencas-filter-label">Mostrando todas as consultas da agenda desta família.</p>
          </div>
          <span class="badge-soft" id="presencas-count">0</span>
        </div>
        <div id="presencas-lista" class="timeline-list presenca-cards-list"></div>
      </section>

      <section id="panel-atendimento" class="workflow-panel" hidden>
        <div class="listagem-head">
          <h3 class="section-title panel-title">Ficha do Atendimento</h3>
          <% if (viewFlags?.canEditAttendance) { %>
            <div class="panel-head-actions">
              <button type="button" class="btn btn-muted" id="atendimento-editar-btn">
                <i class="fa-solid fa-pen-to-square"></i>
                Editar
              </button>
            </div>
          <% } %>
        </div>
        <div id="atendimento-detalhe" class="timeline-card consulta-card-detail-wrap">
          <p class="empty-hint">Selecione um atendimento no histórico para visualizar a ficha.</p>
        </div>
      </section>

      <section id="panel-registro" class="workflow-panel" hidden>
        <div class="listagem-head">
          <h3 class="section-title panel-title" id="registro-panel-title">Registrar Atendimento</h3>
        </div>
        <form id="atendimento-form" class="form-stack atendimento-form-box">
          <label class="field-wrap">
            <span class="input-label">Dependente (opcional)</span>
            <select class="input-control" name="pacienteId" id="atendimento-paciente"></select>
          </label>
          <label class="field-wrap">
            <span class="input-label">Profissional / voluntário atendido (opcional)</span>
            <select class="input-control" name="profissionalId" id="atendimento-profissional">
              <option value="">Sem profissional especificado</option>
            </select>
          </label>
          <label class="field-wrap">
            <span class="input-label">Tipo</span>
            <select class="input-control" name="tipo">
              <option value="ligacao">ligacao</option>
              <option value="presencial">presencial</option>
              <option value="mensagem">mensagem</option>
              <option value="whatsapp">whatsapp</option>
              <option value="videochamada">videochamada</option>
              <option value="outro" selected>outro</option>
            </select>
          </label>
          <label class="field-wrap">
            <span class="input-label">Data e hora</span>
            <input class="input-control" type="datetime-local" name="dataHora" />
          </label>
          <label class="field-wrap">
            <span class="input-label">Resumo *</span>
            <textarea class="input-control textarea-control" name="resumo" rows="4" required></textarea>
          </label>
          <label class="field-wrap">
            <span class="input-label">Próximos passos</span>
            <textarea class="input-control textarea-control" name="proximosPassos" rows="3"></textarea>
          </label>
          <div class="panel-actions">
            <button type="button" class="btn btn-muted" id="registro-voltar-btn">Voltar ao Histórico</button>
            <button class="btn btn-primary" type="submit" id="atendimento-submit-btn">Salvar Atendimento</button>
          </div>
        </form>
      </section>
    </div>
  </section>
</section>
<script <%- typeof renderCspNonceAttr === "function" ? renderCspNonceAttr() : "" %> id="familia-detail-flags" type="application/json"><%- serializeForInlineScript(viewFlags || {}) %></script>

