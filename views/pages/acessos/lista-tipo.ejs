<%
  const filtrosAtuais = filtros || {};
  const pageAtual = Number(paginacao?.page || 1);
  const totalPages = Number(paginacao?.totalPages || 1);
  const inicioPag = Math.max(1, pageAtual - 2);
  const fimPag = Math.min(totalPages, pageAtual + 2);

  function encode(v) {
    return encodeURIComponent(String(v || ""));
  }

  function buildQuery(pageValue) {
    const q = [];
    if (filtrosAtuais.busca) q.push(`busca=${encode(filtrosAtuais.busca)}`);
    if (filtrosAtuais.status && filtrosAtuais.status !== "todos") q.push(`status=${encode(filtrosAtuais.status)}`);
    if (String(filtrosAtuais.ativo || "") !== "") q.push(`ativo=${encode(filtrosAtuais.ativo)}`);
    if (filtrosAtuais.limit) q.push(`limit=${encode(filtrosAtuais.limit)}`);
    if (Number(pageValue || 1) > 1) q.push(`page=${encode(pageValue)}`);
    return q.join("&");
  }

  function pageHref(pageValue) {
    const query = buildQuery(pageValue);
    return query ? `${basePath}?${query}` : basePath;
  }

  const currentQuery = buildQuery(pageAtual);
  const returnTo = currentQuery ? `${basePath}?${currentQuery}` : basePath;
  const isVolunteerPage = String(tipoCadastro || "").trim().toLowerCase() === "voluntario";
  const hasCustomFields = Array.isArray(customFields) && customFields.length > 0;
  const volunteerWizardSteps = [
    {
      key: "identificacao",
      label: "Identificacao",
      subtitle: "Quem vai entrar na rede",
      icon: "fa-solid fa-id-card",
    },
    {
      key: "contato",
      label: "Contato",
      subtitle: "Como falar com a pessoa",
      icon: "fa-solid fa-envelope-open-text",
    },
    {
      key: "atuacao",
      label: "Atuacao",
      subtitle: "Area, funcao e repertorio",
      icon: "fa-solid fa-hand-holding-heart",
    },
    {
      key: "disponibilidade",
      label: "Disponibilidade",
      subtitle: "Quando e como pode ajudar",
      icon: "fa-regular fa-clock",
    },
    {
      key: "acesso",
      label: "Acesso",
      subtitle: "Nivel, status e governanca",
      icon: "fa-solid fa-shield-heart",
    },
    {
      key: "finalizacao",
      label: "Finalizacao",
      subtitle: "Senha inicial e campos extras",
      icon: "fa-solid fa-flag-checkered",
    },
  ];
%>

<section class="acessos-page" data-default-tipo-cadastro="<%= tipoCadastro || 'voluntario' %>">
  <% if (Array.isArray(tipoTabs) && tipoTabs.length) { %>
    <nav class="acessos-switcher" aria-label="Tipos de acesso">
      <% tipoTabs.forEach((tab) => { %>
        <a
          href="<%= tab.href %>"
          class="acessos-switcher-link <%= tab.isActive ? 'is-active' : '' %>"
          aria-current="<%= tab.isActive ? 'page' : 'false' %>"
        >
          <span><%= tab.label %></span>
        </a>
      <% }) %>
    </nav>
  <% } %>

  <header class="acessos-hero module-card">
    <div class="acessos-hero-main">
      <span class="acessos-hero-eyebrow">Gestão de acessos</span>
      <h2><%= sectionTitle %></h2>
      <p><%= subtitle %></p>

      <div class="acessos-hero-stats">
        <span class="acessos-hero-stat"><strong><%= resumo?.total || 0 %></strong> cadastros</span>
        <span class="acessos-hero-stat"><strong><%= resumo?.pendentes || 0 %></strong> pendentes</span>
        <span class="acessos-hero-stat"><strong><%= resumo?.ativos || 0 %></strong> com acesso ativo</span>
      </div>
    </div>

    <div class="acessos-hero-side">
      <div class="badge-soft"><%= paginacao?.totalDocs || 0 %> cadastro(s)</div>

      <% if (canManageUsers) { %>
        <button type="button" class="btn acessos-create-btn" data-create-user-open>
          <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
          <span><%= isVolunteerPage ? "Criar voluntario" : "Criar usuario" %></span>
        </button>
      <% } %>
    </div>
  </header>

  <% if (Array.isArray(quickFilters) && quickFilters.length) { %>
    <section class="module-card acessos-panel">
      <div class="acessos-panel-head">
        <div>
          <h3>Filtros rapidos</h3>
          <p>Atalhos definidos pela administração para acelerar consultas frequentes.</p>
        </div>
      </div>
      <div class="acessos-quick-filter-row">
        <% quickFilters.forEach((filter) => { %>
          <a href="<%= filter.href %>" class="badge-soft acessos-quick-filter-link"><%= filter.nome %></a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (errorMessage && errorMessage.length) { %>
    <div class="conta-error"><%= errorMessage[0] %></div>
  <% } %>

  <% if (successMessage && successMessage.length) { %>
    <div class="conta-success"><%= successMessage[0] %></div>
  <% } %>

  <section class="acessos-kpis">
    <article class="module-card">
      <small>Total</small>
      <strong><%= resumo?.total || 0 %></strong>
    </article>
    <article class="module-card">
      <small>Pendentes</small>
      <strong><%= resumo?.pendentes || 0 %></strong>
    </article>
    <article class="module-card">
      <small>Aprovados</small>
      <strong><%= resumo?.aprovados || 0 %></strong>
    </article>
    <article class="module-card">
      <small>Acesso ativo</small>
      <strong><%= resumo?.ativos || 0 %></strong>
    </article>
  </section>

  <section class="module-card acessos-panel">
    <div class="acessos-panel-head">
      <div>
        <h3>Filtros inteligentes</h3>
        <p>Busque por nome, contato, CPF e acompanhe o status do acesso com mais clareza.</p>
      </div>
    </div>

    <form method="get" action="<%= basePath %>" class="acessos-filtros">
      <label class="field-wrap">
        <span class="input-label">Busca</span>
        <input class="input-control" type="text" name="busca" value="<%= filtrosAtuais.busca || '' %>" placeholder="Nome, email, telefone ou CPF" />
      </label>

      <label class="field-wrap">
        <span class="input-label">Aprovação</span>
        <select class="input-control" name="status">
          <option value="todos" <%= filtrosAtuais.status === "todos" ? "selected" : "" %>>Todos</option>
          <option value="pendente" <%= filtrosAtuais.status === "pendente" ? "selected" : "" %>>Pendente</option>
          <option value="aprovado" <%= filtrosAtuais.status === "aprovado" ? "selected" : "" %>>Aprovado</option>
          <option value="rejeitado" <%= filtrosAtuais.status === "rejeitado" ? "selected" : "" %>>Rejeitado</option>
        </select>
      </label>

      <label class="field-wrap">
        <span class="input-label">Acesso</span>
        <select class="input-control" name="ativo">
          <option value="" <%= String(filtrosAtuais.ativo || "") === "" ? "selected" : "" %>>Todos</option>
          <option value="true" <%= String(filtrosAtuais.ativo || "") === "true" ? "selected" : "" %>>Ativo</option>
          <option value="false" <%= String(filtrosAtuais.ativo || "") === "false" ? "selected" : "" %>>Inativo</option>
        </select>
      </label>

      <label class="field-wrap">
        <span class="input-label">Limite</span>
        <select class="input-control" name="limit">
          <% (filtrosAtuais.limitOptions || [10, 20, 50, 100]).forEach((n) => { %>
            <option value="<%= n %>" <%= Number(filtrosAtuais.limit || 10) === Number(n) ? "selected" : "" %>><%= n %></option>
          <% }) %>
        </select>
      </label>

      <div class="acessos-filtros-actions">
        <button class="btn btn-primary" type="submit">Aplicar</button>
        <a href="<%= basePath %>" class="btn btn-muted">Limpar</a>
      </div>
    </form>
  </section>

  <section class="module-card acessos-panel acessos-table-panel">
    <div class="acessos-panel-head">
      <div>
        <h3>Base de cadastros</h3>
        <p>Edite, aprove, rejeite e controle o acesso sem sair da listagem.</p>
      </div>
      <span class="badge-soft"><%= paginacao?.totalDocs || 0 %> resultados</span>
    </div>

    <div class="table-wrap">
      <table class="data-table acessos-table" data-stack-mobile="true">
        <thead>
          <tr>
            <th>Nome</th>
            <th>Contato</th>
            <th>CPF</th>
            <th>Perfil / Tipo</th>
            <th>Aprovação</th>
            <th>Acesso</th>
            <th>Criado em</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!usuarios || !usuarios.length) { %>
            <tr>
              <td colspan="8">Nenhum cadastro encontrado com os filtros atuais.</td>
            </tr>
          <% } else { %>
            <% usuarios.forEach((item) => { %>
              <tr
                class="<%= item.canEdit ? 'acessos-row-clickable' : '' %>"
                <% if (item.canEdit) { %>
                  data-user-row-open="<%= String(item._id || '') %>"
                  tabindex="0"
                  role="button"
                  aria-label="Abrir ficha de <%= item.nome || 'usuario' %>"
                <% } %>
              >
                <td data-label="Nome">
                  <strong><%= item.nome || "-" %></strong>
                  <div class="acesso-row-hint">Login: <%= item.login || "-" %></div>
                  <% if (item.motivoAprovacao) { %>
                    <div class="acesso-row-hint">Motivo: <%= item.motivoAprovacao %></div>
                  <% } %>
                </td>
                <td data-label="Contato">
                  <div><%= item.email || "-" %></div>
                  <small><%= item.telefone || "-" %></small>
                </td>
                <td data-label="CPF"><%= item.cpf || "-" %></td>
                <td data-label="Perfil / Tipo">
                  <div class="acesso-perfil-stack">
                    <span class="badge-soft"><%= item.perfilLabel %></span>
                    <% if (item.perfil !== "usuario") { %>
                      <small><%= item.papelAprovacaoLabel || "Membro votante" %></small>
                    <% } %>
                    <small><%= item.tipoCadastro ? item.tipoCadastroLabel : "-" %></small>
                    <% if (item.nivelAcessoVoluntarioLabel) { %>
                      <small><%= item.nivelAcessoVoluntarioLabel %></small>
                    <% } %>
                  </div>
                </td>
                <td data-label="Aprovacao"><span class="status-badge <%= item.statusAprovacaoClass %>"><%= item.statusAprovacaoLabel %></span></td>
                <td data-label="Acesso">
                  <% if (item.ativo) { %>
                    <span class="status-badge status-active">Ativo</span>
                  <% } else { %>
                    <span class="status-badge status-inactive">Inativo</span>
                  <% } %>
                </td>
                <td data-label="Criado em"><%= item.createdAt ? new Date(item.createdAt).toLocaleString("pt-BR") : "-" %></td>
                <td class="acessos-actions-col" data-label="Acoes">
                  <% if (item.canEdit || item.canAdminister) { %>
                    <div class="acessos-action-stack">
                      <div class="acesso-actions-menu">
                        <button
                          class="acesso-actions-trigger"
                          type="button"
                          data-action="menu-toggle"
                          aria-expanded="false"
                          aria-label="Abrir menu de ações"
                        >
                          <i class="fa-solid fa-ellipsis" aria-hidden="true"></i>
                        </button>
                        <div class="acesso-actions-dropdown" role="menu" aria-label="Ações do cadastro">
                      <% if (item.canEdit) { %>
                        <button
                          class="table-action-btn table-action-btn-edit acessos-action-btn acesso-action-edit acesso-actions-menu-item"
                          type="button"
                          data-action="edit-user"
                          data-user-id="<%= item._id %>"
                          role="menuitem"
                        >
                          <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                          <span>Editar</span>
                        </button>
                      <% } %>

                      <% if (item.canAdminister && item.statusAprovacaoNormalized !== "aprovado") { %>
                        <% if (item.statusAprovacaoNormalized === "pendente" && item.perfil === "usuario") { %>
                          <a
                            href="/acessos/aprovacoes"
                            class="table-action-btn table-action-btn-success acessos-action-btn acesso-action-approve acesso-actions-menu-item"
                            role="menuitem"
                          >
                            <i class="fa-solid fa-check-to-slot" aria-hidden="true"></i>
                            <span>Votar na fila</span>
                          </a>
                        <% } else { %>
                        <form
                          method="post"
                          action="/acessos/<%= item._id %>/aprovar"
                          class="acessos-action-form acesso-actions-menu-item"
                          data-confirm="true"
                          data-confirm-title="Aprovar cadastro?"
                          data-confirm-text="Deseja aprovar o cadastro de <%= item.nome || 'usuario' %>?"
                          data-confirm-icon="question"
                          data-confirm-confirm="Aprovar"
                          data-confirm-cancel="Cancelar"
                        >
                          <%- renderCsrfField() %>
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <button class="table-action-btn table-action-btn-success acessos-action-btn acesso-action-approve" type="submit" role="menuitem">
                            <i class="fa-solid fa-check" aria-hidden="true"></i>
                            <span>Aprovar</span>
                          </button>
                        </form>
                        <% } %>
                      <% } %>

                      <% if (item.canAdminister && item.tipoCadastro === "familia" && item.statusAprovacaoNormalized !== "aprovado" && !(item.statusAprovacaoNormalized === "pendente" && item.perfil === "usuario")) { %>
                        <form
                          method="post"
                          action="/acessos/<%= item._id %>/aprovar"
                          class="acessos-action-form acesso-actions-menu-item"
                          data-confirm="true"
                          data-confirm-title="Aprovar e ativar acesso?"
                          data-confirm-text="Deseja aprovar e ativar o acesso de <%= item.nome || 'usuario' %>?"
                          data-confirm-icon="question"
                          data-confirm-confirm="Aprovar e ativar"
                          data-confirm-cancel="Cancelar"
                        >
                          <%- renderCsrfField() %>
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <input type="hidden" name="ativo" value="true" />
                          <button class="table-action-btn table-action-btn-success acessos-action-btn acesso-action-secondary" type="submit" role="menuitem">
                            <i class="fa-solid fa-user-check" aria-hidden="true"></i>
                            <span>Aprovar + ativar</span>
                          </button>
                        </form>
                      <% } %>

                      <% if (item.canAdminister && item.statusAprovacaoNormalized !== "rejeitado" && !(item.statusAprovacaoNormalized === "pendente" && item.perfil === "usuario")) { %>
                        <form
                          method="post"
                          action="/acessos/<%= item._id %>/rejeitar"
                          class="acessos-action-form acesso-actions-menu-item"
                          data-confirm="true"
                          data-confirm-title="Rejeitar cadastro?"
                          data-confirm-text="Deseja rejeitar o cadastro de <%= item.nome || 'usuario' %>? Essa acao bloqueia o acesso."
                          data-confirm-icon="warning"
                          data-confirm-confirm="Rejeitar"
                          data-confirm-cancel="Cancelar"
                        >
                          <%- renderCsrfField() %>
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <button class="table-action-btn table-action-btn-danger acessos-action-btn acesso-action-reject" type="submit" role="menuitem">
                            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                            <span>Rejeitar</span>
                          </button>
                        </form>
                      <% } %>

                      <% if (item.canAdminister && item.statusAprovacaoNormalized === "aprovado") { %>
                        <form
                          method="post"
                          action="/acessos/<%= item._id %>/status"
                          class="acessos-action-form acesso-actions-menu-item"
                          data-confirm="true"
                          data-confirm-title="<%= item.ativo ? 'Inativar acesso?' : 'Ativar acesso?' %>"
                          data-confirm-text="<%= item.ativo ? ('Deseja inativar o acesso de ' + (item.nome || 'usuario') + '?') : ('Deseja ativar o acesso de ' + (item.nome || 'usuario') + '?') %>"
                          data-confirm-icon="warning"
                          data-confirm-confirm="<%= item.ativo ? 'Inativar' : 'Ativar' %>"
                          data-confirm-cancel="Cancelar"
                        >
                          <%- renderCsrfField() %>
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <input type="hidden" name="ativo" value="<%= item.ativo ? 'false' : 'true' %>" />
                          <button class="table-action-btn table-action-btn-neutral acessos-action-btn acesso-action-neutral" type="submit" role="menuitem">
                            <i class="fa-solid <%= item.ativo ? 'fa-user-slash' : 'fa-power-off' %>" aria-hidden="true"></i>
                            <span><%= item.ativo ? "Inativar" : "Ativar" %></span>
                          </button>
                        </form>
                      <% } %>
                        </div>
                      </div>
                    </div>
                  <% } else { %>
                    <small>-</small>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <% if (totalPages > 1) { %>
    <nav class="acessos-pagination">
      <a class="btn btn-muted btn-xxs <%= !paginacao?.hasPrevPage ? 'is-disabled' : '' %>" href="<%= paginacao?.hasPrevPage ? pageHref(paginacao.prevPage) : '#' %>">Anterior</a>
      <% for (let p = inicioPag; p <= fimPag; p += 1) { %>
        <a class="btn btn-xxs <%= p === pageAtual ? 'btn-primary' : 'btn-muted' %>" href="<%= pageHref(p) %>"><%= p %></a>
      <% } %>
      <a class="btn btn-muted btn-xxs <%= !paginacao?.hasNextPage ? 'is-disabled' : '' %>" href="<%= paginacao?.hasNextPage ? pageHref(paginacao.nextPage) : '#' %>">Próxima</a>
    </nav>
  <% } %>

  <% if (canManageUsers) { %>
    <div class="acessos-modal" hidden data-create-user-modal>
      <div class="acessos-modal-backdrop" data-create-user-close="true"></div>

      <section
        class="acessos-modal-dialog card-elevated <%= isVolunteerPage ? 'acessos-modal-dialog-volunteer' : '' %>"
        role="dialog"
        aria-modal="true"
        aria-labelledby="acessos-create-user-title"
      >
        <header class="acessos-modal-head">
          <div>
            <h3 id="acessos-create-user-title" data-user-modal-title>Criar novo usuário</h3>
            <p data-user-modal-description>Preencha os dados abaixo para liberar um novo acesso manualmente.</p>
          </div>

          <button
            type="button"
            class="btn btn-muted btn-icon-sm"
            data-create-user-close="true"
            aria-label="Fechar cadastro"
          >
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        </header>

        <div class="acessos-modal-error" data-create-user-error hidden></div>

        <% if (isVolunteerPage) { %>
          <form
            class="acessos-create-form acessos-create-form-wizard"
            data-create-user-form
            data-create-user-layout="volunteer-wizard"
            autocomplete="off"
          >
            <input type="hidden" name="tipoCadastro" value="voluntario" />

            <div class="acessos-wizard-shell" data-volunteer-wizard-root>
              <section class="acessos-wizard-hero">
                <div>
                  <span class="acessos-wizard-eyebrow">Criacao guiada</span>
                  <h4 class="acessos-wizard-title">Novo voluntario com fluxo por etapas</h4>
                  <p class="acessos-wizard-subtitle">
                    O formulario foi reorganizado para acompanhar o raciocinio da equipe: identificar, qualificar, encaixar a disponibilidade e so depois fechar o acesso.
                  </p>
                </div>

                <div class="acessos-wizard-meta">
                  <span class="acessos-wizard-counter" data-wizard-step-counter>Etapa 1 de <%= volunteerWizardSteps.length %></span>
                  <strong class="acessos-wizard-meta-title" data-wizard-step-label><%= volunteerWizardSteps[0].label %></strong>
                </div>
              </section>

              <nav class="acessos-wizard-nav" aria-label="Etapas do cadastro do voluntario" data-wizard-nav>
                <% volunteerWizardSteps.forEach((step, index) => { %>
                  <button
                    type="button"
                    class="acessos-wizard-step <%= index === 0 ? 'is-current' : '' %>"
                    data-wizard-step
                    data-step-index="<%= index %>"
                  >
                    <span class="acessos-wizard-step-badge" aria-hidden="true">
                      <i class="<%= step.icon %>"></i>
                    </span>
                    <span class="acessos-wizard-step-copy">
                      <strong><%= step.label %></strong>
                      <small><%= step.subtitle %></small>
                    </span>
                  </button>
                <% }) %>
              </nav>

              <div class="acessos-wizard-progress" aria-hidden="true">
                <span class="acessos-wizard-progress-fill" data-wizard-progress-fill></span>
              </div>

              <div class="acessos-wizard-panels">
                <section class="acessos-wizard-panel is-current" data-wizard-panel data-step-index="0">
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-id-card"></i>
                    </span>
                    <div>
                      <h4>Identificacao do voluntario</h4>
                      <p>Comecamos pelos dados de referencia para localizar e reconhecer a pessoa no fluxo operacional.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap span-2">
                      <span class="input-label">Nome completo *</span>
                      <input class="input-control" type="text" name="nome" maxlength="120" required />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">CPF</span>
                      <input class="input-control" type="text" name="cpf" maxlength="14" inputmode="numeric" data-user-mask="cpf" />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Data de nascimento</span>
                      <input class="input-control" type="date" name="dataNascimento" />
                    </label>
                  </div>
                </section>

                <section class="acessos-wizard-panel" data-wizard-panel data-step-index="1" hidden>
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-envelope-open-text"></i>
                    </span>
                    <div>
                      <h4>Contato e entrada</h4>
                      <p>Esses dados garantem contato com a equipe e definem como o voluntario entra no portal.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap span-2">
                      <span class="input-label">Email *</span>
                      <input class="input-control" type="email" name="email" maxlength="140" required />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Telefone *</span>
                      <input class="input-control" type="text" name="telefone" maxlength="20" required data-user-mask="phone" />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Usuario para login *</span>
                      <input class="input-control" type="text" name="login" maxlength="40" required />
                    </label>
                  </div>
                </section>

                <section class="acessos-wizard-panel" data-wizard-panel data-step-index="2" hidden>
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-hand-holding-heart"></i>
                    </span>
                    <div>
                      <h4>Atuacao e repertorio</h4>
                      <p>Mapeamos a funcao desejada, a area de contribuicao e aquilo que ja faz parte do repertorio dessa pessoa.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap">
                      <span class="input-label">Funcao principal *</span>
                      <input
                        class="input-control"
                        type="text"
                        name="dadosCadastro_funcao"
                        maxlength="120"
                        required
                        placeholder="Ex: Mediacao, apoio pedagogico, acolhimento"
                        data-user-signup-field="funcao"
                      />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Area de atuacao *</span>
                      <input
                        class="input-control"
                        type="text"
                        name="dadosCadastro_area_atuacao"
                        maxlength="160"
                        required
                        placeholder="Ex: Educacao, saude, esporte, tecnologia"
                        data-user-signup-field="area_atuacao"
                      />
                    </label>

                    <label class="field-wrap span-2">
                      <span class="input-label">Habilidades e pontos fortes</span>
                      <textarea
                        class="input-control textarea-control"
                        name="dadosCadastro_habilidades"
                        rows="4"
                        maxlength="800"
                        placeholder="Liste habilidades, certificacoes, recursos tecnicos ou temas em que essa pessoa pode apoiar com mais seguranca."
                        data-user-signup-field="habilidades"
                      ></textarea>
                    </label>

                    <label class="field-wrap span-2">
                      <span class="input-label">Experiencia relevante</span>
                      <textarea
                        class="input-control textarea-control"
                        name="dadosCadastro_experiencia"
                        rows="4"
                        maxlength="800"
                        placeholder="Descreva experiencias anteriores, publico com que ja trabalhou ou projetos em que ja atuou."
                        data-user-signup-field="experiencia"
                      ></textarea>
                    </label>
                  </div>
                </section>

                <section class="acessos-wizard-panel" data-wizard-panel data-step-index="3" hidden>
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-regular fa-clock"></i>
                    </span>
                    <div>
                      <h4>Disponibilidade</h4>
                      <p>Essa etapa ajuda a equipe a entender quando o voluntario pode entrar em campo e em qual formato.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap span-2">
                      <span class="input-label">Disponibilidade geral *</span>
                      <textarea
                        class="input-control textarea-control"
                        name="dadosCadastro_disponibilidade"
                        rows="4"
                        maxlength="500"
                        required
                        placeholder="Ex: Segundas e quartas a tarde, com abertura para eventos aos sabados."
                        data-user-signup-field="disponibilidade"
                      ></textarea>
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Dias preferenciais</span>
                      <input
                        class="input-control"
                        type="text"
                        name="dadosCadastro_dias_disponiveis"
                        maxlength="120"
                        placeholder="Ex: Segunda, quarta e sexta"
                        data-user-signup-field="dias_disponiveis"
                      />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Turno preferencial</span>
                      <select class="input-control" name="dadosCadastro_turno_preferencial" data-user-signup-field="turno_preferencial">
                        <option value="">Selecione</option>
                        <option value="manha">Manha</option>
                        <option value="tarde">Tarde</option>
                        <option value="noite">Noite</option>
                        <option value="flexivel">Flexivel</option>
                      </select>
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Carga horaria desejada</span>
                      <input
                        class="input-control"
                        type="text"
                        name="dadosCadastro_carga_horaria"
                        maxlength="120"
                        placeholder="Ex: 4 horas por semana"
                        data-user-signup-field="carga_horaria"
                      />
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Formato de atuacao</span>
                      <select class="input-control" name="dadosCadastro_formato_atuacao" data-user-signup-field="formato_atuacao">
                        <option value="">Selecione</option>
                        <option value="presencial">Presencial</option>
                        <option value="remoto">Remoto</option>
                        <option value="hibrido">Hibrido</option>
                      </select>
                    </label>

                    <label class="field-wrap span-2">
                      <span class="input-label">Observacoes de agenda</span>
                      <textarea
                        class="input-control textarea-control"
                        name="dadosCadastro_observacoes_disponibilidade"
                        rows="3"
                        maxlength="500"
                        placeholder="Inclua restricoes, preferencias e qualquer detalhe que ajude a equipe a encaixar melhor esse voluntario."
                        data-user-signup-field="observacoes_disponibilidade"
                      ></textarea>
                    </label>
                  </div>
                </section>

                <section class="acessos-wizard-panel" data-wizard-panel data-step-index="4" hidden>
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-shield-heart"></i>
                    </span>
                    <div>
                      <h4>Acesso e governanca</h4>
                      <p>Defina como o voluntario nasce dentro do sistema: perfil, nivel operacional e situacao inicial.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap">
                      <span class="input-label">Perfil *</span>
                      <select class="input-control" name="perfil" required>
                        <% (createProfileOptions || []).forEach((option) => { %>
                          <option value="<%= option.value %>"><%= option.label %></option>
                        <% }) %>
                      </select>
                    </label>

                    <label class="field-wrap" data-create-user-approval-role-wrap hidden>
                      <span class="input-label">Papel na aprovacao</span>
                      <select class="input-control" name="papelAprovacao">
                        <% (approvalRoleOptions || []).forEach((option) => { %>
                          <option value="<%= option.value %>"><%= option.label %></option>
                        <% }) %>
                      </select>
                    </label>

                    <label class="field-wrap" data-create-user-access-wrap hidden>
                      <span class="input-label">Nivel do voluntario</span>
                      <select class="input-control" name="nivelAcessoVoluntario">
                        <option value="">Escolha o nivel</option>
                        <% (volunteerAccessOptions || []).forEach((option) => { %>
                          <option value="<%= option.value %>"><%= option.label %></option>
                        <% }) %>
                      </select>
                    </label>

                    <label class="field-wrap" data-create-user-status-wrap>
                      <span class="input-label">Status de aprovacao</span>
                      <select class="input-control" name="statusAprovacao">
                        <option value="aprovado">Aprovado</option>
                        <option value="pendente">Pendente</option>
                        <option value="rejeitado">Rejeitado</option>
                      </select>
                    </label>

                    <label class="field-wrap">
                      <span class="input-label">Acesso inicial</span>
                      <select class="input-control" name="ativo">
                        <option value="true" selected>Ativo</option>
                        <option value="false">Inativo</option>
                      </select>
                    </label>
                  </div>

                  <p class="acessos-create-hint acessos-wizard-inline-hint" data-create-user-hint>
                    Usuarios do portal podem nascer aprovados, pendentes ou rejeitados. Perfis internos sobem aprovados automaticamente.
                  </p>
                </section>

                <section class="acessos-wizard-panel" data-wizard-panel data-step-index="5" hidden>
                  <header class="acessos-wizard-panel-head">
                    <span class="acessos-wizard-panel-icon" aria-hidden="true">
                      <i class="fa-solid fa-flag-checkered"></i>
                    </span>
                    <div>
                      <h4>Finalizacao</h4>
                      <p>Agora fechamos credenciais, anexos protegidos e a revisao final do cadastro antes de salvar.</p>
                    </div>
                  </header>

                  <div class="acessos-create-grid">
                    <label class="field-wrap" data-user-password-field>
                      <span class="input-label">Senha *</span>
                      <input class="input-control" type="password" name="senha" required />
                    </label>

                    <label class="field-wrap" data-user-password-field>
                      <span class="input-label">Confirmar senha *</span>
                      <input class="input-control" type="password" name="confirmarSenha" required />
                    </label>
                  </div>

                  <p class="acessos-create-hint" data-user-password-hint>
                    Defina uma senha inicial para esse acesso.
                  </p>

                  <section class="acessos-secure-upload-section">
                    <div class="section-title-wrap">
                      <h4 class="section-title">Anexos protegidos para aprovacao</h4>
                      <p class="section-subtitle">
                        O documento e a foto ficam fora da pasta publica, criptografados em repouso e so aparecem na ficha de aprovacao para administracao e assistencia social autorizada.
                      </p>
                    </div>

                    <div class="acessos-create-grid">
                      <label class="field-wrap span-2 acessos-secure-upload-card">
                        <span class="input-label">Documento de identidade (RG ou CNH) *</span>
                        <input
                          class="input-control"
                          type="file"
                          name="documentoIdentidadeArquivo"
                          accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp"
                          data-user-secure-upload-input="documentoIdentidade"
                          data-user-secure-upload-required-create="true"
                        />
                        <small>Aceita PDF, JPG, PNG ou WEBP. Esse arquivo vai ficar restrito ao fluxo de aprovacao.</small>
                        <div class="acessos-secure-upload-summary" data-user-secure-upload-summary="documentoIdentidade">
                          <strong data-user-secure-upload-name="documentoIdentidade">Nenhum documento anexado.</strong>
                          <span data-user-secure-upload-size="documentoIdentidade"></span>
                          <small data-user-secure-upload-note="documentoIdentidade">Obrigatorio no cadastro novo de voluntario.</small>
                        </div>
                      </label>

                      <label class="field-wrap span-2 acessos-secure-upload-card">
                        <span class="input-label">Foto do rosto ou meio corpo *</span>
                        <input
                          class="input-control"
                          type="file"
                          name="fotoPerfilArquivo"
                          accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                          capture="user"
                          data-user-secure-upload-input="fotoPerfil"
                          data-user-secure-upload-required-create="true"
                        />
                        <small>Use uma foto limpa para perfil e cracha futuro. Em celular, o aparelho pode abrir a camera frontal.</small>
                        <div class="acessos-secure-upload-summary acessos-secure-upload-summary-photo" data-user-secure-upload-summary="fotoPerfil">
                          <img
                            class="acessos-secure-upload-preview"
                            src=""
                            alt="Pre-visualizacao da foto selecionada"
                            hidden
                            data-user-secure-upload-preview="fotoPerfil"
                          />
                          <div class="acessos-secure-upload-summary-body">
                            <strong data-user-secure-upload-name="fotoPerfil">Nenhuma foto anexada.</strong>
                            <span data-user-secure-upload-size="fotoPerfil"></span>
                            <small data-user-secure-upload-note="fotoPerfil">Obrigatoria no cadastro novo de voluntario.</small>
                          </div>
                        </div>
                      </label>
                    </div>
                  </section>

                  <% if (hasCustomFields) { %>
                    <div class="acessos-custom-fields">
                      <div class="section-title-wrap">
                        <h4 class="section-title">Campos extras do cadastro</h4>
                        <p class="section-subtitle">Configurados pela central de administracao.</p>
                      </div>
                      <div class="acessos-create-grid">
                        <% customFields.forEach((field) => { %>
                          <% if (field.tipo === 'textarea') { %>
                            <label class="field-wrap span-2">
                              <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                              <textarea class="input-control textarea-control" name="campoExtra_<%= field.chave %>" rows="3" <%= field.obrigatorio ? 'required' : '' %> placeholder="<%= field.placeholder || '' %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>"></textarea>
                              <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                            </label>
                          <% } else if (field.tipo === 'select') { %>
                            <label class="field-wrap">
                              <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                              <select class="input-control" name="campoExtra_<%= field.chave %>" <%= field.obrigatorio ? 'required' : '' %> data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>">
                                <option value="">Selecione</option>
                                <% (field.opcoes || []).forEach((option) => { %>
                                  <option value="<%= option %>"><%= option %></option>
                                <% }) %>
                              </select>
                              <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                            </label>
                          <% } else if (field.tipo === 'booleano') { %>
                            <label class="field-wrap">
                              <span class="input-label"><%= field.label %></span>
                              <select class="input-control" name="campoExtra_<%= field.chave %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>">
                                <option value="false">Nao</option>
                                <option value="true">Sim</option>
                              </select>
                              <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                            </label>
                          <% } else { %>
                            <label class="field-wrap">
                              <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                              <input class="input-control" type="<%= field.tipo === 'numero' ? 'number' : field.tipo === 'data' ? 'date' : 'text' %>" name="campoExtra_<%= field.chave %>" <%= field.obrigatorio ? 'required' : '' %> placeholder="<%= field.placeholder || '' %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>" />
                              <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                            </label>
                          <% } %>
                        <% }) %>
                      </div>
                    </div>
                  <% } %>

                  <section class="acessos-password-reset-box" data-user-password-reset-wrap hidden>
                    <div>
                      <strong>Redefinicao de senha</strong>
                      <p>Use este fluxo quando precisar trocar a senha e registrar o motivo na auditoria.</p>
                    </div>
                    <button type="button" class="btn btn-muted" data-user-password-reset-open>
                      <i class="fa-solid fa-key" aria-hidden="true"></i>
                      <span>Redefinir senha</span>
                    </button>
                  </section>
                </section>
              </div>

              <div class="acessos-wizard-actions">
                <button type="button" class="btn btn-muted" data-wizard-back disabled>Anterior</button>

                <div class="acessos-wizard-actions-end">
                  <button type="button" class="btn btn-muted" data-create-user-close="true">Cancelar</button>
                  <button type="button" class="btn btn-primary" data-wizard-next>Proximo</button>
                  <button type="submit" class="btn btn-primary" data-user-modal-submit hidden>Criar voluntario</button>
                </div>
              </div>
            </div>
          </form>
        <% } else { %>

        <form class="acessos-create-form" data-create-user-form autocomplete="off">
          <div class="acessos-create-grid">
            <label class="field-wrap">
              <span class="input-label">Nome completo *</span>
              <input class="input-control" type="text" name="nome" maxlength="120" required />
            </label>

            <label class="field-wrap">
              <span class="input-label">Email *</span>
              <input class="input-control" type="email" name="email" maxlength="140" required />
            </label>

            <label class="field-wrap">
              <span class="input-label">Usuário para login *</span>
              <input class="input-control" type="text" name="login" maxlength="40" required />
            </label>

            <label class="field-wrap">
              <span class="input-label">Perfil *</span>
              <select class="input-control" name="perfil" required>
                <% (createProfileOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
              </select>
            </label>

            <label class="field-wrap" data-create-user-approval-role-wrap hidden>
              <span class="input-label">Papel na aprovação</span>
              <select class="input-control" name="papelAprovacao">
                <% (approvalRoleOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
              </select>
            </label>

            <label class="field-wrap">
              <span class="input-label">Tipo de cadastro</span>
              <select class="input-control" name="tipoCadastro">
                <option value="voluntario" <%= tipoCadastro === "voluntario" ? "selected" : "" %>>Voluntário</option>
                <option value="familia" <%= tipoCadastro === "familia" ? "selected" : "" %>>Família</option>
                <option value="orgao_publico" <%= tipoCadastro === "orgao_publico" ? "selected" : "" %>>Órgão Público</option>
              </select>
            </label>

            <label class="field-wrap" data-create-user-access-wrap hidden>
              <span class="input-label">Nível do voluntário</span>
              <select class="input-control" name="nivelAcessoVoluntario">
                <option value="">Escolha o nível</option>
                <% (volunteerAccessOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
              </select>
            </label>

            <label class="field-wrap" data-create-user-status-wrap>
              <span class="input-label">Status de aprovação</span>
              <select class="input-control" name="statusAprovacao">
                <option value="aprovado">Aprovado</option>
                <option value="pendente">Pendente</option>
                <option value="rejeitado">Rejeitado</option>
              </select>
            </label>

            <label class="field-wrap">
              <span class="input-label">Acesso inicial</span>
              <select class="input-control" name="ativo">
                <option value="true" selected>Ativo</option>
                <option value="false">Inativo</option>
              </select>
            </label>

            <label class="field-wrap">
              <span class="input-label">CPF</span>
              <input class="input-control" type="text" name="cpf" maxlength="14" inputmode="numeric" />
            </label>

            <label class="field-wrap">
              <span class="input-label">Telefone</span>
              <input class="input-control" type="text" name="telefone" maxlength="20" />
            </label>

            <label class="field-wrap">
              <span class="input-label">Data de nascimento</span>
              <input class="input-control" type="date" name="dataNascimento" />
            </label>

            <% if (Array.isArray(customFields) && customFields.length) { %>
              <div class="acessos-custom-fields span-2">
                <div class="section-title-wrap">
                  <h4 class="section-title">Campos extras do cadastro</h4>
                  <p class="section-subtitle">Configurados pela central de administração.</p>
                </div>
                <div class="acessos-create-grid">
                  <% customFields.forEach((field) => { %>
                    <% if (field.tipo === 'textarea') { %>
                      <label class="field-wrap span-2">
                        <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                        <textarea class="input-control textarea-control" name="campoExtra_<%= field.chave %>" rows="3" <%= field.obrigatorio ? 'required' : '' %> placeholder="<%= field.placeholder || '' %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>"></textarea>
                        <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                      </label>
                    <% } else if (field.tipo === 'select') { %>
                      <label class="field-wrap">
                        <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                        <select class="input-control" name="campoExtra_<%= field.chave %>" <%= field.obrigatorio ? 'required' : '' %> data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>">
                          <option value="">Selecione</option>
                          <% (field.opcoes || []).forEach((option) => { %>
                            <option value="<%= option %>"><%= option %></option>
                          <% }) %>
                        </select>
                        <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                      </label>
                    <% } else if (field.tipo === 'booleano') { %>
                      <label class="field-wrap">
                        <span class="input-label"><%= field.label %></span>
                        <select class="input-control" name="campoExtra_<%= field.chave %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>">
                          <option value="false">Não</option>
                          <option value="true">Sim</option>
                        </select>
                        <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                      </label>
                    <% } else { %>
                      <label class="field-wrap">
                        <span class="input-label"><%= field.label %><%= field.obrigatorio ? ' *' : '' %></span>
                        <input class="input-control" type="<%= field.tipo === 'numero' ? 'number' : field.tipo === 'data' ? 'date' : 'text' %>" name="campoExtra_<%= field.chave %>" <%= field.obrigatorio ? 'required' : '' %> placeholder="<%= field.placeholder || '' %>" data-user-custom-field="<%= field.chave %>" data-user-custom-type="<%= field.tipo %>" />
                        <% if (field.ajuda) { %><small><%= field.ajuda %></small><% } %>
                      </label>
                    <% } %>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <label class="field-wrap" data-user-password-field>
              <span class="input-label">Senha *</span>
              <input class="input-control" type="password" name="senha" required />
            </label>

            <label class="field-wrap" data-user-password-field>
              <span class="input-label">Confirmar senha *</span>
              <input class="input-control" type="password" name="confirmarSenha" required />
            </label>
          </div>

          <p class="acessos-create-hint" data-user-password-hint>
            Defina uma senha inicial para esse acesso.
          </p>

          <section class="acessos-password-reset-box" data-user-password-reset-wrap hidden>
            <div>
              <strong>Redefinicao de senha</strong>
              <p>Use este fluxo quando precisar trocar a senha de família ou voluntário e registrar o motivo na auditoria.</p>
            </div>
            <button type="button" class="btn btn-muted" data-user-password-reset-open>
              <i class="fa-solid fa-key" aria-hidden="true"></i>
              <span>Redefinir senha</span>
            </button>
          </section>

          <p class="acessos-create-hint" data-create-user-hint>
            Perfis internos são aprovados automaticamente e podem não aparecer nesta lista filtrada.
          </p>

          <div class="acessos-create-actions">
            <button type="submit" class="btn btn-primary" data-user-modal-submit>Salvar usuário</button>
            <button type="button" class="btn btn-muted" data-create-user-close="true">Cancelar</button>
          </div>
        </form>
        <% } %>
      </section>
    </div>

    <div class="acessos-modal" hidden data-reset-password-modal>
      <div class="acessos-modal-backdrop" data-reset-password-close="true"></div>

      <section
        class="acessos-modal-dialog acessos-reset-modal-dialog card-elevated"
        role="dialog"
        aria-modal="true"
        aria-labelledby="acessos-reset-password-title"
      >
        <header class="acessos-modal-head">
          <div>
            <h3 id="acessos-reset-password-title">Redefinir senha</h3>
            <p data-reset-password-description>Informe a nova senha e o motivo da redefinicao para auditoria.</p>
          </div>

          <button
            type="button"
            class="btn btn-muted btn-icon-sm"
            data-reset-password-close="true"
            aria-label="Fechar redefinicao de senha"
          >
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        </header>

        <div class="acessos-modal-error" data-reset-password-error hidden></div>

        <form class="acessos-create-form" data-reset-password-form autocomplete="off">
          <div class="acessos-reset-password-grid">
            <label class="field-wrap">
              <span class="input-label">Nova senha *</span>
              <input class="input-control" type="password" name="senha" required />
            </label>

            <label class="field-wrap">
              <span class="input-label">Confirmar nova senha *</span>
              <input class="input-control" type="password" name="confirmarSenha" required />
            </label>

            <label class="field-wrap span-2">
              <span class="input-label">Motivo da redefinicao *</span>
              <textarea
                class="input-control textarea-control"
                name="motivo"
                rows="4"
                maxlength="500"
                placeholder="Ex.: família perdeu o acesso, troca solicitada pela equipe, senha provisoria para primeiro login..."
                required
              ></textarea>
            </label>
          </div>

          <div class="acessos-create-actions">
            <button type="submit" class="btn btn-primary" data-reset-password-submit>Salvar nova senha</button>
            <button type="button" class="btn btn-muted" data-reset-password-close="true">Cancelar</button>
          </div>
        </form>
      </section>
    </div>
  <% } %>
</section>
