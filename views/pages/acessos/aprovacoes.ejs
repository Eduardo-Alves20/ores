<%
  const filtrosAtuais = filtros || {};
  const pageAtual = Number(paginacao?.page || 1);
  const totalPages = Number(paginacao?.totalPages || 1);
  const inicioPag = Math.max(1, pageAtual - 2);
  const fimPag = Math.min(totalPages, pageAtual + 2);

  function encode(v) {
    return encodeURIComponent(String(v || ""));
  }

  function buildQuery(pageValue) {
    const q = [];
    if (filtrosAtuais.busca) q.push(`busca=${encode(filtrosAtuais.busca)}`);
    if (filtrosAtuais.tipo && filtrosAtuais.tipo !== "todos") q.push(`tipo=${encode(filtrosAtuais.tipo)}`);
    if (filtrosAtuais.limit) q.push(`limit=${encode(filtrosAtuais.limit)}`);
    if (Number(pageValue || 1) > 1) q.push(`page=${encode(pageValue)}`);
    return q.join("&");
  }

  function pageHref(pageValue) {
    const query = buildQuery(pageValue);
    return query ? `/acessos/aprovacoes?${query}` : "/acessos/aprovacoes";
  }

  const currentQuery = buildQuery(pageAtual);
  const returnTo = currentQuery ? `/acessos/aprovacoes?${currentQuery}` : "/acessos/aprovacoes";
%>

<section class="acessos-page">
  <header class="acessos-hero module-card">
    <div class="acessos-hero-main">
      <span class="acessos-hero-eyebrow">Triagem de acessos</span>
      <h2>Aprovações Pendentes</h2>
      <p><%= subtitle %></p>

      <div class="acessos-hero-stats">
        <span class="acessos-hero-stat"><strong><%= totalPendente || 0 %></strong> aguardando decisão</span>
        <span class="acessos-hero-stat"><strong><%= usuarios?.length || 0 %></strong> exibidos na página</span>
        <span class="acessos-hero-stat"><strong><%= Number(filtrosAtuais.limit || 10) %></strong> por página</span>
      </div>
    </div>

    <div class="acessos-hero-side">
      <div class="badge-soft"><%= totalPendente || 0 %> pendente(s)</div>
    </div>
  </header>

  <% if (errorMessage && errorMessage.length) { %>
    <div class="conta-error"><%= errorMessage[0] %></div>
  <% } %>

  <% if (successMessage && successMessage.length) { %>
    <div class="conta-success"><%= successMessage[0] %></div>
  <% } %>

  <section class="module-card acessos-panel">
    <div class="acessos-panel-head">
      <div>
        <h3>Refinar fila</h3>
        <p>Na tabela ficam só os ícones. A ficha completa abre quando você clicar para avaliar.</p>
      </div>
    </div>

    <form method="get" action="/acessos/aprovacoes" class="acessos-filtros aprovacoes-filtros">
      <label class="field-wrap">
        <span class="input-label">Busca</span>
        <input class="input-control" type="text" name="busca" value="<%= filtrosAtuais.busca || '' %>" placeholder="Nome, email, telefone ou CPF" />
      </label>

      <label class="field-wrap">
        <span class="input-label">Tipo</span>
        <select class="input-control" name="tipo">
          <option value="todos" <%= filtrosAtuais.tipo === "todos" ? "selected" : "" %>>Todos</option>
          <option value="familia" <%= filtrosAtuais.tipo === "familia" ? "selected" : "" %>>Família</option>
          <option value="voluntario" <%= filtrosAtuais.tipo === "voluntario" ? "selected" : "" %>>Voluntário</option>
          <option value="orgao_publico" <%= filtrosAtuais.tipo === "orgao_publico" ? "selected" : "" %>>Órgão Público</option>
        </select>
      </label>

      <label class="field-wrap">
        <span class="input-label">Limite</span>
        <select class="input-control" name="limit">
          <% (filtrosAtuais.limitOptions || [10, 20, 50, 100]).forEach((n) => { %>
            <option value="<%= n %>" <%= Number(filtrosAtuais.limit || 10) === Number(n) ? "selected" : "" %>><%= n %></option>
          <% }) %>
        </select>
      </label>

      <div class="acessos-filtros-actions">
        <button class="btn btn-primary" type="submit">Aplicar</button>
        <a href="/acessos/aprovacoes" class="btn btn-muted">Limpar</a>
      </div>
    </form>
  </section>

  <section class="module-card acessos-panel acessos-table-panel">
    <div class="acessos-panel-head">
      <div>
        <h3>Fila de aprovação</h3>
        <p>Aprove, rejeite ou abra a ficha para revisar os dados completos antes da decisão.</p>
        <p class="aprovacao-icon-legend">
          <span><i class="fa-solid fa-thumbs-up" aria-hidden="true"></i> Aprovar</span>
          <span><i class="fa-solid fa-thumbs-down" aria-hidden="true"></i> Rejeitar</span>
          <span><i class="fa-solid fa-file-lines" aria-hidden="true"></i> Abrir ficha</span>
        </p>
      </div>
      <span class="badge-soft"><%= totalPendente || 0 %> em análise</span>
    </div>

    <div class="table-wrap">
      <table class="data-table acessos-table" data-stack-mobile="true">
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Nome</th>
            <th>Contato</th>
            <th>CPF</th>
            <th>Criado em</th>
            <th>Aprovação</th>
          </tr>
        </thead>
        <tbody>
          <% if (!usuarios || !usuarios.length) { %>
            <tr>
              <td colspan="6">Nenhum cadastro pendente com os filtros atuais.</td>
            </tr>
          <% } else { %>
            <% usuarios.forEach((item) => { %>
              <tr>
                <td data-label="Tipo">
                  <span class="badge-soft"><%= item.tipoCadastroLabel %></span>
                </td>
                <td data-label="Nome">
                  <strong><%= item.nome || "-" %></strong>
                  <div class="acesso-row-hint"><%= item.workflowResumo?.stateLabel || "Aguardando decisão administrativa" %></div>
                </td>
                <td data-label="Contato">
                  <div><%= item.email || "-" %></div>
                  <small><%= item.telefone || "-" %></small>
                </td>
                <td data-label="CPF"><%= item.cpf || "-" %></td>
                <td data-label="Criado em"><%= item.createdAt ? new Date(item.createdAt).toLocaleString("pt-BR") : "-" %></td>
                <td class="acessos-actions-col" data-label="Aprovacao">
                  <% if (isAdmin) { %>
                    <div class="aprovacao-icon-strip">
                      <% if (item.tipoCadastro === "voluntario") { %>
                        <button
                          class="aprovacao-vote-btn aprovacao-vote-btn-approve"
                          type="button"
                          data-approval-open
                          data-user-id="<%= item._id %>"
                          title="Abrir ficha para aprovar e definir nível"
                          aria-label="Abrir ficha para aprovar e definir nível"
                        >
                          <i class="fa-solid fa-thumbs-up" aria-hidden="true"></i>
                        </button>
                      <% } else { %>
                        <form method="post" action="/acessos/<%= item._id %>/aprovar" class="aprovacao-vote-form">
                          <%- renderCsrfField() %>
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <button
                            class="aprovacao-vote-btn aprovacao-vote-btn-approve"
                            type="submit"
                            title="Aprovar cadastro"
                            aria-label="Aprovar cadastro"
                          >
                            <i class="fa-solid fa-thumbs-up" aria-hidden="true"></i>
                          </button>
                        </form>
                      <% } %>

                      <form method="post" action="/acessos/<%= item._id %>/rejeitar" class="aprovacao-vote-form">
                        <%- renderCsrfField() %>
                        <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                        <button
                          class="aprovacao-vote-btn aprovacao-vote-btn-reject"
                          type="submit"
                          title="Rejeitar cadastro"
                          aria-label="Rejeitar cadastro"
                        >
                          <i class="fa-solid fa-thumbs-down" aria-hidden="true"></i>
                        </button>
                      </form>

                      <button
                        type="button"
                        class="aprovacao-open-btn"
                        data-approval-open
                        data-user-id="<%= item._id %>"
                        title="Abrir ficha de aprovação"
                        aria-label="Abrir ficha de aprovação"
                      >
                        <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                      </button>
                    </div>
                  <% } else if (canReviewSensitiveApprovalData) { %>
                    <div class="aprovacao-icon-strip">
                      <button
                        type="button"
                        class="aprovacao-open-btn"
                        data-approval-open
                        data-user-id="<%= item._id %>"
                        title="Abrir ficha de aprovacao"
                        aria-label="Abrir ficha de aprovacao"
                      >
                        <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                      </button>
                    </div>
                  <% } else { %>
                    <small>Somente administracao e assistencia social autorizada podem abrir a ficha.</small>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <% if (totalPages > 1) { %>
    <nav class="acessos-pagination">
      <a class="btn btn-muted btn-xxs <%= !paginacao?.hasPrevPage ? 'is-disabled' : '' %>" href="<%= paginacao?.hasPrevPage ? pageHref(paginacao.prevPage) : '#' %>">Anterior</a>
      <% for (let p = inicioPag; p <= fimPag; p += 1) { %>
        <a class="btn btn-xxs <%= p === pageAtual ? 'btn-primary' : 'btn-muted' %>" href="<%= pageHref(p) %>"><%= p %></a>
      <% } %>
      <a class="btn btn-muted btn-xxs <%= !paginacao?.hasNextPage ? 'is-disabled' : '' %>" href="<%= paginacao?.hasNextPage ? pageHref(paginacao.nextPage) : '#' %>">Próxima</a>
    </nav>
  <% } %>

  <div class="acessos-modal" hidden data-approval-modal>
    <div class="acessos-modal-backdrop" data-approval-close="true"></div>

    <section
      class="acessos-modal-dialog card-elevated aprovacao-modal-dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="approval-modal-title"
    >
      <header class="acessos-modal-head">
        <div>
          <h3 id="approval-modal-title">Ficha de aprovação</h3>
          <p data-approval-description>Veja os dados do cadastro antes de decidir.</p>
        </div>

        <button
          type="button"
          class="btn btn-muted btn-icon-sm"
          data-approval-close="true"
          aria-label="Fechar ficha"
        >
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </header>

      <div class="acessos-modal-error" data-approval-error hidden></div>

      <div class="aprovacao-modal-content">
        <div class="aprovacao-detail-grid">
          <label class="field-wrap">
            <span class="input-label">Nome</span>
            <input class="input-control" type="text" readonly data-approval-field="nome" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Email</span>
            <input class="input-control" type="text" readonly data-approval-field="email" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Login</span>
            <input class="input-control" type="text" readonly data-approval-field="login" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Telefone</span>
            <input class="input-control" type="text" readonly data-approval-field="telefone" />
          </label>

          <label class="field-wrap">
            <span class="input-label">CPF</span>
            <input class="input-control" type="text" readonly data-approval-field="cpf" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Tipo de cadastro</span>
            <input class="input-control" type="text" readonly data-approval-field="tipoCadastroLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Perfil</span>
            <input class="input-control" type="text" readonly data-approval-field="perfilLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Criado em</span>
            <input class="input-control" type="text" readonly data-approval-field="createdAtLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Status</span>
            <input class="input-control" type="text" readonly data-approval-field="statusAprovacaoLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Aprovações registradas</span>
            <input class="input-control" type="text" readonly data-approval-field="approveVotesLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Rejeições registradas</span>
            <input class="input-control" type="text" readonly data-approval-field="rejectVotesLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Status administrativo</span>
            <input class="input-control" type="text" readonly data-approval-field="actorVoteLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Etapa atual</span>
            <input class="input-control" type="text" readonly data-approval-field="workflowStateLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Decisor</span>
            <input class="input-control" type="text" readonly data-approval-field="presidentNameLabel" />
          </label>

          <label class="field-wrap">
            <span class="input-label">Pendências</span>
            <input class="input-control" type="text" readonly data-approval-field="pendingRegularVotesLabel" />
          </label>
        </div>

        <section class="aprovacao-review-form aprovacao-sensitive-panel" data-approval-sensitive-wrap hidden>
          <div class="aprovacao-voting-head">
            <div>
              <h4>Anexos protegidos</h4>
              <p>Documento e foto ficam criptografados em repouso e so podem ser abertos neste fluxo restrito.</p>
            </div>
            <span class="badge-soft">Uso LGPD</span>
          </div>

          <div class="aprovacao-sensitive-grid">
            <article class="aprovacao-sensitive-card">
              <div class="aprovacao-sensitive-card-head">
                <strong data-approval-attachment-name="documentoIdentidade">Documento de identidade</strong>
                <span data-approval-attachment-meta="documentoIdentidade">Nao enviado</span>
              </div>
              <p class="acesso-row-hint" data-approval-attachment-note="documentoIdentidade">
                Aceita RG ou CNH em PDF ou imagem.
              </p>
              <div class="aprovacao-sensitive-actions">
                <a
                  href="#"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-muted btn-sm"
                  hidden
                  data-approval-attachment-link="documentoIdentidade"
                >
                  Abrir documento
                </a>
              </div>
            </article>

            <article class="aprovacao-sensitive-card">
              <div class="aprovacao-sensitive-card-head">
                <strong data-approval-attachment-name="fotoPerfil">Foto para perfil/cracha</strong>
                <span data-approval-attachment-meta="fotoPerfil">Nao enviada</span>
              </div>
              <p class="acesso-row-hint" data-approval-attachment-note="fotoPerfil">
                Foto usada para validacao visual e futura identificacao interna.
              </p>
              <div class="aprovacao-sensitive-photo-wrap">
                <img
                  class="aprovacao-sensitive-photo"
                  src=""
                  alt="Foto protegida do voluntario"
                  hidden
                  data-approval-attachment-preview="fotoPerfil"
                />
              </div>
              <div class="aprovacao-sensitive-actions">
                <a
                  href="#"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-muted btn-sm"
                  hidden
                  data-approval-attachment-link="fotoPerfil"
                >
                  Abrir foto
                </a>
              </div>
            </article>
          </div>
        </section>

        <section class="aprovacao-review-form aprovacao-voting-panel">
          <div class="aprovacao-voting-head">
            <div>
              <h4>Decisão administrativa</h4>
              <p>Use a ficha para aprovar ou rejeitar este cadastro.</p>
            </div>
            <span class="badge-soft" data-approval-actor-vote-pill>Aguardando decisão</span>
          </div>

          <form
            method="post"
            class="aprovacao-vote-form-inline"
            data-approval-vote-approve-form
          >
            <%- renderCsrfField() %>
            <input type="hidden" name="returnTo" value="<%= returnTo %>" />

            <label class="field-wrap" data-approval-access-wrap hidden>
              <span class="input-label">Nível do voluntário</span>
              <select class="input-control" name="nivelAcessoVoluntario" data-approval-access-select>
                <option value="">Escolha o nível</option>
                <% (volunteerAccessOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
              </select>
            </label>

            <div class="aprovacao-voting-actions">
              <button
                class="aprovacao-vote-btn aprovacao-vote-btn-approve"
                type="submit"
                data-approval-vote-btn="aprovar"
                title="Aprovar cadastro"
                aria-label="Aprovar cadastro"
              >
                <i class="fa-solid fa-thumbs-up" aria-hidden="true"></i>
                <span class="aprovacao-vote-count" data-approval-vote-count="aprovar">0</span>
              </button>

              <button
                class="aprovacao-vote-btn aprovacao-vote-btn-reject"
                type="button"
                data-approval-reject-open
                title="Rejeitar cadastro"
                aria-label="Rejeitar cadastro"
              >
                <i class="fa-solid fa-thumbs-down" aria-hidden="true"></i>
                <span class="aprovacao-vote-count" data-approval-vote-count="rejeitar">0</span>
              </button>
            </div>
          </form>
        </section>

        <section class="aprovacao-review-form aprovacao-reasons-panel" data-approval-reasons-wrap hidden>
          <div class="aprovacao-voting-head">
            <div>
              <h4>Motivos de rejeição</h4>
              <p>Quando houver justificativa registrada, ela aparece aqui na ficha.</p>
            </div>
          </div>

          <div class="aprovacao-reasons-list" data-approval-reasons-list></div>
        </section>

        <section class="aprovacao-review-form aprovacao-levels-panel" data-approval-level-votes-wrap hidden>
          <div class="aprovacao-voting-head">
            <div>
              <h4>Nível de acesso selecionado</h4>
              <p>Defina o nível antes de aprovar o voluntário.</p>
            </div>
            <span class="badge-soft" data-approval-level-leader-pill>Nenhum nível líder</span>
          </div>

          <div class="aprovacao-levels-list" data-approval-level-votes-list></div>
        </section>
      </div>
    </section>
  </div>

  <div class="acessos-modal" hidden data-reject-vote-modal>
    <div class="acessos-modal-backdrop" data-reject-vote-close="true"></div>

    <section
      class="acessos-modal-dialog card-elevated aprovacao-reject-modal-dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="reject-vote-modal-title"
    >
      <header class="acessos-modal-head">
        <div>
          <h3 id="reject-vote-modal-title">Confirmar rejeição</h3>
          <p data-reject-vote-description>Se quiser, adicione uma justificativa para aparecer na ficha.</p>
        </div>

        <button
          type="button"
          class="btn btn-muted btn-icon-sm"
          data-reject-vote-close="true"
          aria-label="Fechar confirmação de rejeição"
        >
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </header>

      <form
        method="post"
        class="aprovacao-review-form"
        data-approval-reject-vote-form
      >
        <%- renderCsrfField() %>
        <input type="hidden" name="returnTo" value="<%= returnTo %>" />

        <label class="field-wrap">
          <span class="input-label">Motivo da rejeição</span>
          <textarea class="input-control textarea-control" name="motivo" rows="4" placeholder="Opcional"></textarea>
        </label>

        <div class="aprovacao-review-actions">
          <button type="button" class="btn btn-muted" data-reject-vote-close="true">Cancelar</button>
          <button class="btn btn-muted acesso-action-reject" type="submit">
            <i class="fa-solid fa-thumbs-down" aria-hidden="true"></i>
            <span>Rejeitar cadastro</span>
          </button>
        </div>
      </form>
    </section>
  </div>
</section>
