<section class="conta-page">
  <header class="conta-header">
    <div>
      <h2>Editar Perfil</h2>
      <p>
        <% if (isSuperAdmin) { %>
          Como SuperAdmin, você pode editar todos os campos.
        <% } else if (isAdmin) { %>
          Como administrador, você pode editar campos operacionais da conta.
        <% } else { %>
          Você pode editar apenas email e telefone.
        <% } %>
      </p>
    </div>
    <a href="/perfil" class="btn btn-muted">Voltar</a>
  </header>

  <section class="module-card">
    <% if (errorMessage && errorMessage.length) { %>
      <div class="conta-error">
        <%= errorMessage[0] %>
      </div>
    <% } %>

    <% if (successMessage && successMessage.length) { %>
      <div class="conta-success">
        <%= successMessage[0] %>
      </div>
    <% } %>

    <form method="post" action="/perfil/editar" class="form-stack conta-form-grid" id="conta-perfil-editar-form" novalidate>
      <%- renderCsrfField() %>
      <div class="conta-inline-feedback" id="conta-perfil-feedback" hidden></div>
      <% if (isAdmin) { %>
        <label class="field-wrap">
          <span class="input-label">Nome</span>
          <input class="input-control" type="text" name="nome" required value="<%= usuario?.nome || '' %>" data-validate-field="nome" />
          <small class="conta-field-feedback" data-feedback-for="nome" hidden></small>
        </label>
      <% } else { %>
        <label class="field-wrap">
          <span class="input-label">Nome</span>
          <input class="input-control" type="text" value="<%= usuario?.nome || '' %>" disabled />
        </label>
      <% } %>

      <label class="field-wrap">
        <span class="input-label">Email</span>
        <input class="input-control" type="email" name="email" required value="<%= usuario?.email || '' %>" data-validate-field="email" />
        <small class="conta-field-feedback" data-feedback-for="email" hidden></small>
      </label>

      <% if (isAdmin) { %>
        <label class="field-wrap">
          <span class="input-label">Usuário de login</span>
          <input class="input-control" type="text" name="login" required value="<%= usuario?.login || '' %>" data-validate-field="login" />
          <small class="conta-field-feedback" data-feedback-for="login" hidden></small>
        </label>
      <% } else { %>
        <label class="field-wrap">
          <span class="input-label">Usuário de login</span>
          <input class="input-control" type="text" value="<%= usuario?.login || '-' %>" disabled />
        </label>
      <% } %>

      <label class="field-wrap">
        <span class="input-label">Telefone</span>
        <input class="input-control" type="text" name="telefone" value="<%= usuario?.telefone || '' %>" data-validate-field="telefone" />
        <small class="conta-field-feedback" data-feedback-for="telefone" hidden></small>
      </label>

      <% if (isAdmin) { %>
        <label class="field-wrap">
          <span class="input-label">CPF</span>
          <input class="input-control" type="text" name="cpf" value="<%= usuario?.cpf || '' %>" data-validate-field="cpf" />
          <small class="conta-field-feedback" data-feedback-for="cpf" hidden></small>
        </label>

        <% if (isSuperAdmin) { %>
          <label class="field-wrap">
            <span class="input-label">Perfil</span>
            <select class="input-control" name="perfil" required>
              <% perfisDisponiveis.forEach((perfil) => { %>
                <option value="<%= perfil %>" <%= usuario?.perfil === perfil ? 'selected' : '' %>><%= perfil %></option>
              <% }) %>
            </select>
          </label>

          <label class="field-wrap">
            <span class="input-label">Tipo de cadastro</span>
            <select class="input-control" name="tipoCadastro" required>
              <option value="voluntario" <%= usuario?.tipoCadastro === 'voluntario' ? 'selected' : '' %>>voluntário</option>
              <option value="familia" <%= usuario?.tipoCadastro === 'familia' ? 'selected' : '' %>>família</option>
              <option value="orgao_publico" <%= usuario?.tipoCadastro === 'orgao_publico' ? 'selected' : '' %>>órgão público</option>
            </select>
          </label>

          <label class="field-wrap">
            <span class="input-label">Status da conta</span>
            <select class="input-control" name="ativo" required>
              <option value="true" <%= usuario?.ativo ? 'selected' : '' %>>ativo</option>
              <option value="false" <%= !usuario?.ativo ? 'selected' : '' %>>inativo</option>
            </select>
          </label>
        <% } else { %>
          <label class="field-wrap">
            <span class="input-label">Perfil</span>
            <input class="input-control" type="text" value="<%= usuario?.perfil || '' %>" disabled />
          </label>

          <label class="field-wrap">
            <span class="input-label">Tipo de cadastro</span>
            <input class="input-control" type="text" value="<%= usuario?.tipoCadastro || '' %>" disabled />
          </label>

          <label class="field-wrap">
            <span class="input-label">Status da conta</span>
            <input class="input-control" type="text" value="<%= usuario?.ativo ? 'ativo' : 'inativo' %>" disabled />
          </label>
        <% } %>
      <% } else { %>
        <label class="field-wrap">
          <span class="input-label">Perfil</span>
          <input class="input-control" type="text" value="<%= usuario?.perfil || '' %>" disabled />
        </label>
      <% } %>

      <div class="conta-form-actions">
        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        <a href="/perfil" class="btn btn-muted">Cancelar</a>
      </div>
    </form>
  </section>
</section>
