<main class="board-canvas" data-board-id="<%= board._id %>" data-user-id="<%= userId %>">
  <header>
    <div class="title">
      <h1><%= board.title %></h1>
      <% if (myRole === "admin") { %>
        <button type="button" onclick="openSettingsModal()">
          <i class="ri-edit-line"></i>
        </button>
      <% } %>
    </div>

    <div class="details">
    <div class="buttons">
    <a href="/board/<%= board._id %>?view=boards" class="<%= view === "boards" && "active" %>">
        <div class="icon board"></div>
        <span>Quadro</span>
    </a>

    <!-- <a>
        <div class="icon table"></div>
        <span>Tabela</span>
    </a> -->

    <a href="/board/<%= board._id %>?view=calendar" class="<%= view === "calendar" && "active" %>">
        <div class="icon calendar"></div>
        <span>Calendário</span>
    </a>

    <a href="/board/<%= board._id %>/export" target="_blank">
        <i class="ri-file-excel-2-line"></i> Baixar Relatório
    </a>
    </div>
    
    <div class="actions">
        <button title="Arquivados" id="archive-btn" onclick="abrirGavetaArquivados()">
            <i class="ri-inbox-archive-line"></i>
            <span id="archive-count"><%= totalArchivedItems %></span>
        </button>
        <div class="members">
            <button onclick="openModal()">Membros: </button>
            <div>
                <% board.members.forEach(member => { %>
                <%
                    const names = member.user.name.trim().split(" ");
                    let initials = names[0].charAt(0).toUpperCase();
        
                    if (names.length > 1) {
                        initials += names[names.length - 1].charAt(0).toUpperCase();
                    }
                %>
                <div title="<%= member.user.name %>" class="member"><%= initials %></div>
                <% }) %>
            </div>
        </div>
    </div>

    </div>
  </header>

  <% if (view === "boards") { %>
    <%- include('./partials/boards') %>
  <% } else if (view === "calendar") { %>
    <%- include('./partials/calendar') %>
  <% } %>

</main>

<%- include('../../partials/modals') %>
<%- include('../../partials/archived-drawer') %>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

<script src="/socket.io/socket.io.js"></script>
<script>
  // Inicializa o socket
  const socket = io();

  const currentBoardId = "<%= board._id %>";

  socket.emit("joinBoard", currentBoardId);

  socket.on("boardUpdated", (data) => {
    if (isMe(data.senderId)) return;

    console.log("Board atualizado remotamente:");
    
    updateBoardVisuals(data.board);
  });


  socket.on("cardMoved", (data) => {
    console.log("Evento recebido no servidor: ", data);
    
    if (typeof handleRemoteCardMove === 'function') {
      handleRemoteCardMove(data);
    }
  });

  socket.on('listMoved', (data) => {
    if (isMe(data.senderId)) return;

    console.log(`Lista ${data.listId} movida para posição ${data.newIndex}`);
    
    // Chama a função visual
    moveListVisuals(data.listId, data.newIndex);
  });
    
  
  socket.on('listCreated', (data) => {
    if (isMe(data.senderId)) return;

    const listsContainer = document.querySelector('.boards-wrapper'); // O container das listas
    const addListBtn = document.querySelector('.add-list-wrapper');

    // Insere o HTML que veio do servidor ANTES do botão de adicionar
    if (listsContainer && addListBtn) {
        // insertAdjacentHTML é mais rápido e seguro que innerHTML +=
        addListBtn.insertAdjacentHTML('beforebegin', data.html);
        
        console.log("Lista renderizada via Server-Side Socket!");
    }
  });

  socket.on('listUpdated', (data) => {
      // Se fui eu que mudei, ignora
      if (isMe(data.senderId)) return;

      const titleDisplay = document.getElementById(`list-title-display-${data.listId}`);
      if (titleDisplay) {
          titleDisplay.innerText = data.title;
          // Atualiza o value do input escondido também, para a próxima edição
          const titleInput = document.getElementById(`list-title-input-${data.listId}`);
          if(titleInput) titleInput.value = data.title;
      }
  });

  socket.on('listDeleted', (data) => {
      // A função isMe() evita tentar deletar o que já deletei
      if (isMe(data.senderId)) return;
      
      removeListFromDOM(data.listId);
  });

  socket.on('listArchiveToggled', (data) => {
    const { listId, isArchived, list, cards, senderId } = data;

    // Atualiza o contador de arquivados
    updateCounterArchived(isArchived);

    // ATUALIZA A TELA PRINCIPAL
    if (isArchived) {
        // Remove a lista inteira da tela
        const listEl = document.querySelector(`[data-list-id="${listId}"]`);
        if (listEl) {
            const wrapper = listEl.closest('.list-wrapper');
            if (wrapper) wrapper.remove();
        }
    } else {
        // Se foi restaurada, desenha ela de volta
        if (!document.querySelector(`[data-list-id="${listId}"]`)) {
            // Reaproveitamos a função que já criamos antes!
            appendListToDom(list); 

            if (cards && cards.length > 0) {
                cards.forEach(card => {
                    appendCardToDom(card);
                });
            }
        }
    }

    // ATUALIZA A GAVETA DE ARQUIVADOS
    if (isArchived) {
        estadoArquivados.dados.lists.unshift(list);
    } else {
        estadoArquivados.dados.lists = estadoArquivados.dados.lists.filter(l => l._id !== listId);
    }

    if (document.getElementById('archived-drawer').classList.contains('aberto')) {
        renderizarArquivados();
    }
  });

  socket.on('cardCreated', (data) => {
      console.log("Evento de criar card");

      if (isMe(data.senderId)) return;

      // Acha a lista correta
      const listCardsContainer = document.querySelector(`[data-list-id="${data.listId}"] .js-list-cards`);

      if (listCardsContainer) {
          // Insere o HTML no final da lista
          listCardsContainer.insertAdjacentHTML('beforeend', data.html);
          
          // Scroll até o fim e pisca
          listCardsContainer.scrollTop = listCardsContainer.scrollHeight;
          const newCard = listCardsContainer.lastElementChild;
          flashElement(newCard);
      }
  });

  socket.on('cardDeleted', (data) => {
      console.log("Evento de deletar card");
    
      if (isMe(data.senderId)) return;

      // Busca pelo atributo data-card-id
      const cardElement = document.querySelector(`[data-card-id="${data.cardId}"]`);
      
      
      if (cardElement) {
          cardElement.style.opacity = '0';
          cardElement.style.transform = 'scale(0.9)';
          setTimeout(() => cardElement.remove(), 300);
      }
  });

  socket.on('cardUpdated', (data) => {
      console.log("Evento de atualizar card");
      if (isMe(data.senderId)) return;

      const cardElement = document.querySelector(`[data-card-id="${data.cardId}"]`);
      
      if (!cardElement) return;

      if (cardElement) {
          console.log("Recebi update via socket, atualizando visual...");
          updateCardVisuals(cardElement, data.updatedCard);
      }
  });

  socket.on('cardArchiveToggled', (data) => {
    const { card, senderId } = data;
    const isArchived = card.isArchived;

    // Atualiza o contador de arquivados
    updateCounterArchived(isArchived);

    // Atualiza o quadro
    if (isArchived) {
        // Some com o card da tela
        const cardEl = document.querySelector(`[data-card-id="${card._id}"]`);
        if (cardEl) cardEl.remove(); 
    } else {
        // Se foi restaurado, desenha ele de volta (se já não estiver na tela)
        if (!document.querySelector(`[data-card-id="${card._id}"]`)) {
            // Reaproveitamos a sua função mágica de criar cards na tela!
            appendCardToDom(card); 
        }
    }

    // Atualiza a lista de arquivados
    if (isArchived) {
        estadoArquivados.dados.cards = estadoArquivados.dados.cards.filter(cardF => String(cardF._id) !== String(card._id));
        estadoArquivados.dados.cards.push(card);
    } else {
        estadoArquivados.dados.cards = estadoArquivados.dados.cards.filter(cardF => cardF._id !== card._id); // Remove da lista
    }
    
    // Se a gaveta estiver visível, manda re-renderizar
    if (document.getElementById('archived-drawer').classList.contains('aberto')) {
        renderizarArquivados();
    }
  });

  function moveListVisuals(listId, newIndex) {
    const container = document.querySelector(".js-lists-container");
    const itemToMove = document.querySelector(`[data-list-id="${listId}"]`); 

    if (!container || !itemToMove) return;

    const addListBtn = container.querySelector('.add-list-wrapper');

    // Isso garante que o índice bata com o array do backend
    const allLists = Array.from(container.querySelectorAll('.list-wrapper'));
    const siblings = allLists.filter(element => element !== itemToMove);

    if (newIndex >= siblings.length) {
        // Se for para a última posição, insere ANTES do botão, e não no fim do container
        if (addListBtn) {
            container.insertBefore(itemToMove, addListBtn);
        } else {
            // Só usa append se o botão não existir (fallback)
            container.appendChild(itemToMove);
        }
    } else {
        // insere antes do vizinho daquele índice
        const neighbor = siblings[newIndex];
        if (neighbor) {
            container.insertBefore(itemToMove, neighbor);
        }
    }

    itemToMove.style.transition = "background-color 0.5s";
    itemToMove.style.backgroundColor = "#00000025";
    setTimeout(() => itemToMove.style.backgroundColor = "", 500);
  }

  function updateBoardVisuals(boardData) {

    // Atualiza o título
    const headerTitle = document.querySelector('header .title h1');
    if (headerTitle) {
        headerTitle.innerText = boardData.title;
    }


    // Atualiza a cor de fundo
    if (boardData.color) {
      document.body.style.backgroundColor = boardData.color;
    }

    // Atualiza o title da pagina
    document.title = `${boardData.title} | HDI`;


    // Atualiza os inputs dos modais
    const modalTitleInput = document.getElementById('settings-title-input');
    const modalColorInput = document.getElementById('settings-color-input');
    if (modalTitleInput) modalTitleInput.value = boardData.title;
    if (modalColorInput) modalColorInput.value = boardData.color;

    // Atualiza o item na sidebar
    const sidebarItem = document.querySelector(`.sidebar-board-item[href="/board/${boardData._id}"]`);
    
    if (sidebarItem) {
      // Atualiza Texto
      const nameSpan = sidebarItem.querySelector('span');
      if (nameSpan) nameSpan.innerText = boardData.title;
    }
  }

  function updateCardVisuals(cardElement, cardData) {
      // atualiza o json que enviamos para o modal
      cardElement.setAttribute('data-card-json', JSON.stringify(cardData));

      // Atualiza o Titulo
      const titleEl = cardElement.querySelector('h3'); 
      if (titleEl) titleEl.innerText = cardData.title;

      // atualiza Capa
      let coverEl = cardElement.querySelector('.card-cover');
      
      if (cardData.coverImage) {
          // Se tem imagem, mas não tem div, cria
          if (!coverEl) {
              coverEl = document.createElement('div');
              coverEl.className = 'card-cover';
              // Copie os estilos do seu CSS ou mantenha inline se necessário
              coverEl.style.height = '120px'; 
              coverEl.style.backgroundSize = 'cover';
              coverEl.style.backgroundPosition = 'center';
              cardElement.prepend(coverEl); // Insere no topo
          }
          // Atualiza a URL
          coverEl.style.backgroundImage = `url('${cardData.coverImage}')`;
      } else {
          // Se não tem imagem no objeto, remove a div se ela existir
          if (coverEl) coverEl.remove();
      }

      // Atualiza Etiquetas
      const labelsContainer = cardElement.querySelector('.card-labels');
      if (labelsContainer) {
        labelsContainer.innerHTML = ''; // Limpa tudo
        if (cardData.labels && cardData.labels.length > 0) {
          cardData.labels.forEach(color => {
              const span = document.createElement('span');
              span.className = 'label';
              span.style.backgroundColor = color;
              labelsContainer.appendChild(span);
          });
        }
      }

      // Badges (Data, Descrição, Checklist)
      const badgesContainer = cardElement.querySelector('.badges');
      
      if (badgesContainer) {
          let htmlContent = '';

          // Badge Descrição
          if (cardData.description && cardData.description.trim().length > 0) {
              htmlContent += `<span><i class="ri-align-left"></i></span>`;
          }

          // Badge Checklist
          if (cardData.checklist && cardData.checklist.length > 0) {
              const done = cardData.checklist.filter(i => i.done).length;
              const total = cardData.checklist.length;
              const colorStyle = (done === total) ? 'background: #61bd4f; color: white; padding: 2px 4px; border-radius: 3px;' : '';
              
              htmlContent += `
                  <div class="deadline" style="${colorStyle}">
                      <i class="ri-checkbox-line"></i> ${done}/${total}
                  </div>
              `;
          }

          // Badge Data
          if (cardData.dueDate) {
              const due = new Date(cardData.dueDate);
              const now = new Date();
              const isLate = due < now && due.getDate() !== now.getDate();
              const dateStr = due.toLocaleDateString('pt-BR', { 
                day: 'numeric', 
                month: 'short' 
              });
              
              htmlContent += `
                  <span class="badge-date ${isLate ? 'badge-late' : ''}" title="Data de entrega">
                      <i class="ri-time-line"></i> ${dateStr}
                  </span>
              `;
          }

          // Badge Anexo
          if (cardData.attachments.length > 0 ) {
              htmlContent += `
                <span title="Anexos">
                  <i class="ri-attachment-2"></i> ${cardData.attachments.length}
                </span>
              `;
          }

          badgesContainer.innerHTML = htmlContent;
      }

      const membersContainer = cardElement.querySelector('.card-members');
      if (membersContainer) {
        membersContainer.innerHTML = ''; 
        if (cardData.assignees && cardData.assignees.length > 0) {
            cardData.assignees.forEach(user => {
                // Previne erro se o user vier só como ID string
                if (typeof user !== 'object') return; 

                const memberDiv = document.createElement('div');
                memberDiv.className = 'card-member-ball';
                memberDiv.title = user.name;
                
                // Lógica de Iniciais
                const names = user.name.trim().split(" ");
                let initials = names[0].charAt(0).toUpperCase();
                if (names.length > 1) {
                    initials += names[names.length - 1].charAt(0).toUpperCase();
                }
                
                memberDiv.innerText = initials;

                membersContainer.appendChild(memberDiv);
            });
        }
    }
      

      flashElement(cardElement);
  }

  function flashElement(elemento) {
      elemento.style.transition = "background 0.5s";
      const originalBg = elemento.style.background;
      elemento.style.background = "#fff9c4";
      setTimeout(() => {
          elemento.style.background = originalBg || "";
      }, 1000);
  }
</script>

<script src="/js/drag-drop.js"></script>
<script src="/js/ui.js"></script>
<script src="/js/api.js"></script>
