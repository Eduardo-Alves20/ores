<div id="edit-modal" class="modal-overlay" style="display: none">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Editar Cartão</h2>
      <i class="ri-close-line close-modal-btn" onclick="closeEditModal()"></i>
    </div>

    <div class="modal-scroll-area">
      <div id="cover-preview-area">
        <img
          id="cover-preview-img"
          src=""
        />

        <form id="remove-cover-form" onsubmit="handleCoverRemove(event)" style="margin-top: 5px">
          <% if (myRole !== 'observer') { %>
            <button type="submit">
              <i class="ri-delete-bin-line"></i> Remover Capa
            </button>
          <% } %>
        </form>
      </div>

      <div class="assignees-section">
        <label>Membros do Cartão</label>
        <div class="assignees-list">
          <% if (board.members && board.members.length > 0) { %>
              <% board.members.forEach(member => { %>
                  <% if (member.user) { %>
                    <div class="assignee-option" 
                        id="assignee-option-<%= member.user._id %>"
                        onclick="toggleAssignee('<%= member.user._id %>', '<%= myRole %>')"
                        title="<%= member.user.name %>"
                    >
                        <div class="member">
                            <%= member.user.name.charAt(0).toUpperCase() %>
                        </div>

                        <div class="assignee-check">
                            <i class="ri-check-line"></i>
                        </div>
                    </div>
                  <% } %>
              <% }) %>
          <% } else { %>
              <small style="color: #666;">Convide pessoas para o quadro para atribuí-las.</small>
          <% } %>
        </div>
      </div>

      <div class="attachments-section">
          <label for="attachment-input">
              <i class="ri-attachment-2"></i> Anexos
          </label>

          <div id="attachments-list">
          </div>
          
          <input type="file" id="attachment-input" style="display: none;" onchange="handleAttachmentUpload(this, '<%= myRole %>')">
          
          <% if (myRole !== 'observer') { %>
            
            <button type="button" class="btn-secondary" onclick="document.getElementById('attachment-input').click()">
              <i class="ri-add-line"></i> Adicionar Anexo
            </button>
          <% } %>
      </div>

      <form
        id="upload-cover-form"
        onsubmit="handleCoverUpload(event)"
        style="<%= myRole !== 'observer' ? "" : "background-color: transparent; margin: 0; padding: 0;" %>"
      >
        <% if (myRole !== 'observer') { %>
          <label
            style="
              font-size: 12px;
              font-weight: bold;
              display: block;
              margin-bottom: 5px;
            "
            >Capa do Cartão</label
          >
          <div style="display: flex; gap: 5px">
            <input
              type="file"
              name="cover"
              accept="image/*"
              required
            />
            <button
              type="submit"
              class="btn-primary"
            >
              Enviar
            </button>
          </div>
        <% } %>
      </form>

      <hr />

      <form id="edit-form" onsubmit="handleEditFormSubmit(event)">
        <label>Título do cartão</label>
        <input
          type="text"
          name="title"
          id="edit-title-input"
          class="input-form"
          <%= myRole !== "observer" ? "" : "disabled" %>
          required
        />

        <label>Etiquetas</label>
        <div class="label-picker">
          <div class="label-option" style="background-color: #61bd4f">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#61bd4f" />
          </div>
          <div class="label-option" style="background-color: #f2d600">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#f2d600" />
          </div>
          <div class="label-option" style="background-color: #ff9f1a">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#ff9f1a" />
          </div>
          <div class="label-option" style="background-color: #eb5a46">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#eb5a46" />
          </div>
          <div class="label-option" style="background-color: #c377e0">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#c377e0" />
          </div>
          <div class="label-option" style="background-color: #0079bf">
            <input type="checkbox" <%= myRole !== "observer" ? "" : "disabled" %>  name="labels" value="#0079bf" />
          </div>
        </div>

        <label>Data de Entrega</label>
        <input
          type="date"
          name="dueDate"
          id="edit-date-input"
          class="input-form"
          style="width: auto"
          <%= myRole !== "observer" ? "" : "disabled" %> 
        />

        <label for="description">Descrição Detalhada</label>

        <div id="editor-container" style="height: 200px; background: white; border-radius: 0 0 4px 4px;"></div>

        <input type="hidden" name="description" id="description">

        <!-- CHECKLIST SECTION -->
        <div class="checklist-section modal-section">
          <label
            for="new-checklist-item"
          >
            <span><i class="ri-checkbox-line"></i> Checklist</span>
            <span id="checklist-progress-text">0%</span
            >
          </label>

          <div class="progress-bar-bg">
            <div id="checklist-progress-bar"></div>
          </div>

          <div
            id="checklist-items-container"
          ></div>

          <div class="checklist-container">
            <input
              type="text"
              id="new-checklist-item"
              placeholder="Adicionar um item..."
              class="input-form"
              style="margin: 0"
              <%= myRole !== "observer" ? "" : "disabled" %> 
            />

            <% if (myRole !== "observer") { %>
              <button type="button" class="btn-secondary" onclick="addCheckitem()">
                Adicionar
              </button>
            <% } %>
          </div>
        </div>

        <% if (myRole !== "observer") { %>
          <div class="modal-actions">
            <button type="submit" class="btn-primary">Salvar Alterações</button>
            <button type="button" class="btn-secondary" onclick="closeEditModal()">
              Cancelar
            </button>
          </div>
        <% } %>
      </form>
        
      <% if (myRole !== "observer") { %>
        <hr />
        <button type="button" class="btn-danger" id="btn-archive-card-modal">
          <i class="ri-delete-bin-line"></i> Arquivar Cartão
        </button>
      <% } %>
    </div>

    <%- include('./mention-side-painel') %>

  </div>
</div>
<script src="/js/card-modal.js"></script>
