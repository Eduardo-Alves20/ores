<div id="edit-list-modal" class="modal-overlay" style="display: none">
  <div class="modal-content">
    <div class="modal-scroll-area">
      <h3>Configurações da Lista</h3>
  
      <form id="edit-list-form" method="POST">
        <label>Nome da lista</label>
        <input
          type="text"
          name="title"
          id="edit-list-title-input"
          class="input-form"
          required
        />
  
        <div class="modal-actions">
          <button type="submit" class="btn-primary">Salvar Nome</button>
          <button type="button" class="btn-secondary" onclick="closeListModal()">
            Cancelar
          </button>
        </div>
      </form>
  
      <hr />
  
      <div
        style="
          background: #fff0f0;
          padding: 10px;
          border-radius: 4px;
          margin-bottom: 10px;
        "
      >
        <small style="color: #c9372c"
          >Atenção: Isso excluirá todos os cartões desta lista.</small
        >
      </div>
  
      <form id="delete-list-form" method="POST">
        <button type="submit" class="btn-danger">
          <i class="ri-delete-bin-line"></i> Excluir Lista
        </button>
      </form>
    </div>
  </div>
</div>

<script src="/js/list-modal.js"></script>