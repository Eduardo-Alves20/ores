<div id="invite-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Convidar Membro</h2>
            <i class="ri-close-line close-modal-btn" onclick="closeInviteModal()"></i>
        </div>
        
        <form action="/board/<%= board._id %>/invite" method="POST" style="padding: 20px;">
            <label for="invite-search-input">Buscar Usuário</label>
            <div class="autocomplete-container">
                <input type="text" 
                      id="invite-search-input" 
                      name="invite-search-input"
                      class="input-form" 
                      placeholder="Digite nome ou email..." 
                      autocomplete="off"
                      oninput="handleUserSearch(this.value)">

                <input type="hidden" name="email" id="invite-email-hidden" required>

                <div id="invite-results-list" class="autocomplete-results"></div>
            </div>
            <small>
                Listando apenas usuários dos grupos: <%= user.groups.join(', ') %>
            </small>

            <label  for="role">Papel</label>
            <select id="role" name="role" class="input-form">
                <option value="editor" selected>Editor (Pode mover e editar)</option>
                <option value="observer">Observador (Só visualiza)</option>
                <option value="admin">Admin (Pode excluir)</option>
            </select>
            
            <div class="modal-actions">
                <button type="submit" class="btn-primary">Enviar Convite</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/invite-modal.js"></script>