<div id="patch-notes-modal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h2>Novidades da Versão 1.0.3</h2>
                <span>Descrição mais interessante e menções</span>
            </div>
            <i class="ri-close-line close-modal-btn" onclick="closePatchNotes()"></i>
        </div>

        <div class="modal-scroll-area">
            
            <div class="patch-section">
                <h4>
                    ✅ Menções
                </h4>
                <ul>
                    <li>
                        <i class="ri-checkbox-circle-fill" style="color: #36b37e; margin-top: 3px;"></i>
                        <span>
                            <strong>Menção a pessoa:</strong> Agora é possível marcar pessoas dentro da descrição do cartão
                        </span>
                    </li>
                    <li style="margin-bottom: 12px; display: flex; gap: 10px; color: #172b4d;">
                        <i class="ri-checkbox-circle-fill" style="color: #36b37e; margin-top: 3px;"></i>
                        <span>
                            <strong>Menção ao cartão:</strong> Agora é possível adicionar a descrição uma mensão a um cartão de qualquer QUADRO que o usuário fizer parte.
                        </span>
                    </li>
                </ul>
            </div>

            <div class="patch-section">
                <h4>
                    🗃️ Arquivamento
                </h4>
                <ul>
                    <li>
                        <i class="ri-checkbox-circle-fill" style="color: #36b37e; margin-top: 3px;"></i>
                        <span>
                            <strong>Arquivar cartão:</strong> Agora é possível arquivar cartões e restaurá-lo
                        </span>
                    </li>
                    <li style="margin-bottom: 12px; display: flex; gap: 10px; color: #172b4d;">
                        <i class="ri-checkbox-circle-fill" style="color: #36b37e; margin-top: 3px;"></i>
                        <span>
                            <strong>Arquivar listas:</strong> Agora é possível arquivar listas e restaurá-lo
                        </span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="modal-footer" style="padding: 15px 20px; background: #f4f5f7; display: flex; justify-content: flex-end;border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;">
            <button class="btn-primary" onclick="closePatchNotes()" style="padding: 10px 24px; font-weight: bold;">
                Entendi, vamos lá! 🚀
            </button>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        checkPatchNotes();
    });

    const CURRENT_VERSION = 'v1.0.3';

    function checkPatchNotes() {
        const lastSeen = localStorage.getItem('patch_notes_version');
        
        // Se a versão salva for diferente da atual, mostra o modal
        if (lastSeen !== CURRENT_VERSION) {
            const modal = document.getElementById('patch-notes-modal');
            if (modal) {
                // Pequeno delay para não assustar o usuário assim que a página carrega
                setTimeout(() => {
                    modal.style.display = 'flex';
                    // Efeito de entrada suave (opcional)
                    const content = modal.querySelector('.modal-content');
                    content.style.transform = 'translateY(20px)';
                    content.style.opacity = '0';
                    content.style.transition = 'all 0.3s ease';
                    
                    requestAnimationFrame(() => {
                        content.style.transform = 'translateY(0)';
                        content.style.opacity = '1';
                    });

                }, 1000);
            }
        }
    }

    function closePatchNotes() {
        const modal = document.getElementById('patch-notes-modal');
        if (modal) {
            modal.style.display = 'none';
            // Salva que o usuário já viu essa versão
            localStorage.setItem('patch_notes_version', CURRENT_VERSION);
        }
    }
</script>