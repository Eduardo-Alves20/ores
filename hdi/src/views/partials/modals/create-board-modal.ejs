<div id="create-board-modal" class="modal-overlay" style="display: none">
  <div class="modal-content">
    <div class="modal-scroll-area">
      <h3>Criar quadro</h3>

      <form action="/boards" method="POST">
        <label>Título do quadro</label>
        <input
          type="text"
          name="title"
          required
          placeholder="Ex: Planejamento Semanal"
          class="input-form"
        />

        <label for="color">Cor de fundo</label>
        <div style="display: flex; align-items: center; gap: 10px;">
          <input type="color" 
                  id="color" 
                  name="color"
                  style="width: 50px; height: 40px; border: none; cursor: pointer;">
          <span style="font-size: 12px; color: #666;">Clique na cor para alterar</span>
        </div>

        <div class="modal-actions">
          <button type="submit" class="btn-primary">Criar Quadro</button>
          <button
            type="button"
            class="btn-secondary"
            onclick="closeCreateBoardModal()"
          >
            Cancelar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

